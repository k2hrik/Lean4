  simp [terminalAffineMapFixedPointCondition, r4r3m0FixedPointNumerator,
    r4r3m0FixedPointDenominator, r4r3m0FixedCoordinateEquation]
  omega
theorem r4m2_fixed_coordinate_implies_target (W : List TerminalLetter)
    (h : r4m2FixedCoordinateEquation W) :
    r4m2TargetEquation W :=
  (r4m2_fixed_coordinate_iff_target W).mp h
theorem r4r3m0_fixed_coordinate_implies_target (W : List TerminalLetter)
    (h : r4r3m0FixedCoordinateEquation W) :
    r4r3m0TargetEquation W :=
  (r4r3m0_fixed_coordinate_iff_target W).mp h
theorem r4m2_composed_affine_map_fixed_point_derivation
    (W : List TerminalLetter) :
    terminalAffineMapFixedPointCondition W r4m2FixedPointNumerator
      r4m2FixedPointDenominator ↔ r4m2TargetEquation W := by
  exact (r4m2_composed_affine_map_fixed_point_iff_fixed_coordinate W).trans
    (r4m2_fixed_coordinate_iff_target W)
theorem r4r3m0_composed_affine_map_fixed_point_derivation
    (W : List TerminalLetter) :
    terminalAffineMapFixedPointCondition W r4r3m0FixedPointNumerator
      r4r3m0FixedPointDenominator ↔ r4r3m0TargetEquation W := by
  exact (r4r3m0_composed_affine_map_fixed_point_iff_fixed_coordinate W).trans
