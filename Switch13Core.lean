  128 * r + m0
def c5PiTermKeys (graph : List C5PiTermState) : List C5PiTermKey :=
  graph.map C5PiTermState.key
def c5PiTermQuotient (graph : List C5PiTermState) : Finset C5PiTermKey :=
  (c5PiTermKeys graph).toFinset
def c5PiTermStepOK (graph : List C5PiTermState) : C5PiTermStep -> Prop
  | C5PiTermStep.pureD _ childKey => childKey ∈ c5PiTermKeys graph
  | C5PiTermStep.nonD outcome => outcome ∈ c5PiTermAllowedNonDOutcomes
def c5PiTermStepOKBool (graph : List C5PiTermState) : C5PiTermStep -> Bool
  | C5PiTermStep.pureD _ childKey => decide (childKey ∈ c5PiTermKeys graph)
  | C5PiTermStep.nonD outcome => decide (outcome ∈ c5PiTermAllowedNonDOutcomes)
def c5PiTermGraphClosed (graph : List C5PiTermState) : Prop :=
  ∀ state ∈ graph, ∀ step ∈ state.steps, c5PiTermStepOK graph step
def c5PiTermGraphStepsClosedBool
    (graph states : List C5PiTermState) : Bool :=
  states.all (fun state =>
    state.steps.all (fun step => c5PiTermStepOKBool graph step))
def c5PiTermGraphClosedBool (graph : List C5PiTermState) : Bool :=
  c5PiTermGraphStepsClosedBool graph graph
structure C5PiTermInitialEntry where
  r : Nat
