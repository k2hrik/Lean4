    C5PiTermStateRealizesTerminalAffineK state
      (c5TerminalAffineFamilyOfPiTermState state)
      (c5KStateOfPiTermState state) := by
  unfold c5PiTermStateRealizesTerminalAffineKBool at h
  unfold C5PiTermStateRealizesTerminalAffineK
  unfold c5TerminalAffineFamilyOfPiTermState
  unfold c5KStateOfPiTermState
  simp at h
  refine ⟨rfl, rfl, rfl, rfl, rfl, rfl, rfl,
    h.1.1.1.1.1.2, h.1.1.1.1.2, rfl, rfl, h.1.2, rfl, ?_, h.2⟩
  unfold C5AffineFamilyCenteredAt
  exact ⟨Nat.dvd_of_mod_eq_zero h.1.1.1.2, h.1.1.2⟩
