    C13Closeout q c := by
  cases hc with
  | one =>
      exact C13Closeout.finiteOne c13_bounded_tail_exit_1
  | five =>
      exact C13Closeout.finiteThree c13_bounded_tail_exit_5
  | thirteen =>
      exact C13Closeout.strictSeven c13_bounded_tail_exit_13
