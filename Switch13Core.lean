    (graph : List C5PiTermState) (entries : List C5PiTermInitialEntry) : Prop :=
  ∀ entry ∈ entries, entry.stateKey ∈ c5PiTermKeys graph
def c5PiTermInitialEntriesCoveredBool
    (graph : List C5PiTermState) (entries : List C5PiTermInitialEntry) : Bool :=
  entries.all (fun entry => decide (entry.stateKey ∈ c5PiTermKeys graph))
theorem c5PiTermStepOK_of_bool
    {graph : List C5PiTermState} {step : C5PiTermStep}
    (hstep : c5PiTermStepOKBool graph step = true) :
    c5PiTermStepOK graph step := by
  cases step with
  | pureD letter childKey =>
      unfold c5PiTermStepOKBool at hstep
      unfold c5PiTermStepOK
      exact of_decide_eq_true hstep
  | nonD outcome =>
      unfold c5PiTermStepOKBool at hstep
      unfold c5PiTermStepOK
      exact of_decide_eq_true hstep
theorem c5PiTermStateStepsClosed_of_bool
    {graph : List C5PiTermState} :
    ∀ {steps : List C5PiTermStep},
      steps.all (fun step => c5PiTermStepOKBool graph step) = true ->
      ∀ step ∈ steps, c5PiTermStepOK graph step
  | [], _h, step, hmem => by
      cases hmem
  | head :: tail, h, step, hmem => by
      simp only [List.all_cons, Bool.and_eq_true] at h
      have hhead : c5PiTermStepOKBool graph head = true := by
        exact h.1
      have htail : tail.all (fun step => c5PiTermStepOKBool graph step) = true := by
        exact h.2
      simp only [List.mem_cons] at hmem
      rcases hmem with hsame | htailmem
      · subst step
        exact c5PiTermStepOK_of_bool hhead
      · exact c5PiTermStateStepsClosed_of_bool htail step htailmem
theorem c5PiTermGraphStepsClosed_of_bool
    {graph : List C5PiTermState} :
    ∀ {states : List C5PiTermState},
      c5PiTermGraphStepsClosedBool graph states = true ->
      ∀ state ∈ states, ∀ step ∈ state.steps, c5PiTermStepOK graph step
  | [], _h, state, hmem, _step, _hstep => by
      cases hmem
  | head :: tail, h, state, hmem, step, hstep => by
      simp only [c5PiTermGraphStepsClosedBool, List.all_cons, Bool.and_eq_true] at h
      have hhead :
          head.steps.all (fun step => c5PiTermStepOKBool graph step) = true := by
        exact h.1
      have htail : c5PiTermGraphStepsClosedBool graph tail = true := by
        simpa [c5PiTermGraphStepsClosedBool] using h.2
      simp only [List.mem_cons] at hmem
      rcases hmem with hsame | htailmem
      · subst state
        exact c5PiTermStateStepsClosed_of_bool hhead step hstep
      · exact c5PiTermGraphStepsClosed_of_bool htail state htailmem step hstep
theorem c5PiTermGraphClosed_of_bool
    {graph : List C5PiTermState}
    (hclosed : c5PiTermGraphClosedBool graph = true) :
    c5PiTermGraphClosed graph := by
  unfold c5PiTermGraphClosedBool at hclosed
  exact c5PiTermGraphStepsClosed_of_bool hclosed
theorem c5PiTermInitialEntriesCovered_of_bool
    {graph : List C5PiTermState} {entries : List C5PiTermInitialEntry}
    (hcovered : c5PiTermInitialEntriesCoveredBool graph entries = true) :
    c5PiTermInitialEntriesCovered graph entries := by
  unfold c5PiTermInitialEntriesCoveredBool at hcovered
  induction entries with
  | nil =>
      intro entry hentry
      cases hentry
  | cons head tail ih =>
      simp only [List.all_cons, Bool.and_eq_true] at hcovered
      intro entry hentry
      have hhead : decide (head.stateKey ∈ c5PiTermKeys graph) = true := by
        exact hcovered.1
      have htail :
          tail.all (fun entry => decide (entry.stateKey ∈ c5PiTermKeys graph)) = true := by
        exact hcovered.2
      simp only [List.mem_cons] at hentry
      rcases hentry with hsame | htailmem
      · subst entry
        exact of_decide_eq_true hhead
      · exact ih htail entry htailmem
theorem c5PiTerm_state_key_mem_quotient
    {graph : List C5PiTermState} {state : C5PiTermState}
    (hstate : state ∈ graph) :
    state.key ∈ c5PiTermQuotient graph := by
  have hkey : state.key ∈ c5PiTermKeys graph := by
    exact List.mem_map.mpr ⟨state, hstate, rfl⟩
  simpa [c5PiTermQuotient] using hkey
theorem c5PiTermGraphClosedBool_sound
    {graph : List C5PiTermState}
    (hclosed : c5PiTermGraphClosedBool graph = true) :
    (∀ state ∈ graph, state.key ∈ c5PiTermQuotient graph) ∧
    (∀ state ∈ graph, ∀ letter childKey,
      C5PiTermStep.pureD letter childKey ∈ state.steps ->
        childKey ∈ c5PiTermQuotient graph) ∧
    (∀ state ∈ graph, ∀ outcome,
      C5PiTermStep.nonD outcome ∈ state.steps ->
        outcome ∈ c5PiTermAllowedNonDOutcomes) := by
  have hprop := c5PiTermGraphClosed_of_bool hclosed
  refine ⟨?hkeys, ?hchild, ?hnond⟩
  · intro state hstate
    exact c5PiTerm_state_key_mem_quotient hstate
