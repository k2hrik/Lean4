theorem r4r3m0_parameter_nonintegral :
    ¬ ∃ k : Int, 503 * k = 269 := by
  intro h
  rcases h with ⟨k, hk⟩
  omega
theorem c5_fixed_extremal_coordinates_yield_targets :
    (∀ W : List TerminalLetter,
      r4m2FixedCoordinateEquation W -> r4m2TargetEquation W) ∧
    (∀ W : List TerminalLetter,
      terminalAffineMapFixedPointCondition W r4m2FixedPointNumerator
        r4m2FixedPointDenominator -> r4m2TargetEquation W) ∧
    (∀ W : List TerminalLetter,
      r4r3m0FixedCoordinateEquation W -> r4r3m0TargetEquation W) ∧
    (∀ W : List TerminalLetter,
      terminalAffineMapFixedPointCondition W r4r3m0FixedPointNumerator
        r4r3m0FixedPointDenominator -> r4r3m0TargetEquation W) := by
  exact ⟨r4m2_fixed_coordinate_implies_target,
    fun W h => (r4m2_composed_affine_map_fixed_point_derivation W).mp h,
    r4r3m0_fixed_coordinate_implies_target,
    fun W h => (r4r3m0_composed_affine_map_fixed_point_derivation W).mp h⟩
theorem c5_target_equations_force_self_extremal_words :
    (∀ U : List TerminalLetter,
      r4m2TargetEquation (TerminalLetter.r4m2 :: U) ↔
        r4m2TargetEquation U) ∧
    (∀ W : List TerminalLetter,
      r4m2TargetEquation W -> allLettersAre TerminalLetter.r4m2 W) ∧
    (∀ U : List TerminalLetter,
      r4r3m0TargetEquation (TerminalLetter.r4r3m0 :: U) ↔
        r4r3m0TargetEquation U) ∧
    (∀ W : List TerminalLetter,
      r4r3m0TargetEquation W -> allLettersAre TerminalLetter.r4r3m0 W) := by
  exact ⟨r4m2_target_peel_identity,
    r4m2_target_equation_forces_all_self_extremal,
    r4r3m0_target_peel_identity,
    r4r3m0_target_equation_forces_all_self_extremal⟩
theorem c5_self_extremal_parameters_nonintegral :
    (¬ ∃ k : Int, 29 * k = 15) ∧
    (¬ ∃ k : Int, 503 * k = 269) := by
  exact ⟨r4m2_parameter_nonintegral, r4r3m0_parameter_nonintegral⟩
theorem c5_lowbit_periodic_obstruction_core :
    (∀ W : List TerminalLetter,
      r4m2FixedCoordinateEquation W -> r4m2TargetEquation W) ∧
    (∀ W : List TerminalLetter,
      terminalAffineMapFixedPointCondition W r4m2FixedPointNumerator
        r4m2FixedPointDenominator -> r4m2TargetEquation W) ∧
    (∀ U : List TerminalLetter,
      r4m2TargetEquation (TerminalLetter.r4m2 :: U) ↔
        r4m2TargetEquation U) ∧
    (∀ W : List TerminalLetter,
      r4m2TargetEquation W -> allLettersAre TerminalLetter.r4m2 W) ∧
    (¬ ∃ k : Int, 29 * k = 15) ∧
    (∀ W : List TerminalLetter,
      r4r3m0FixedCoordinateEquation W -> r4r3m0TargetEquation W) ∧
    (∀ W : List TerminalLetter,
      terminalAffineMapFixedPointCondition W r4r3m0FixedPointNumerator
        r4r3m0FixedPointDenominator -> r4r3m0TargetEquation W) ∧
    (∀ U : List TerminalLetter,
      r4r3m0TargetEquation (TerminalLetter.r4r3m0 :: U) ↔
        r4r3m0TargetEquation U) ∧
    (∀ W : List TerminalLetter,
      r4r3m0TargetEquation W -> allLettersAre TerminalLetter.r4r3m0 W) ∧
    (¬ ∃ k : Int, 503 * k = 269) := by
  exact ⟨r4m2_fixed_coordinate_implies_target,
    fun W h => (r4m2_composed_affine_map_fixed_point_derivation W).mp h,
    r4m2_target_peel_identity,
    r4m2_target_equation_forces_all_self_extremal,
    r4m2_parameter_nonintegral,
    r4r3m0_fixed_coordinate_implies_target,
    fun W h => (r4r3m0_composed_affine_map_fixed_point_derivation W).mp h,
    r4r3m0_target_peel_identity,
    r4r3m0_target_equation_forces_all_self_extremal,
    r4r3m0_parameter_nonintegral⟩

