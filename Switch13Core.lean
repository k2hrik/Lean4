    have hmul :
        ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) <=
          (residual_QNext z : Int) *
            ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
              (3 : Int) ^ residual_LNext z) := by
      nlinarith [mul_nonneg (by omega : (0 : Int) <= (residual_QNext z : Int)) hcoeff_nonneg]
    nlinarith
  rw [Eq.symm hsign] at hnonneg
  nlinarith
theorem residual_tail_equality_impossible_odd (t s : Nat) (hs : Odd s)
    (h : 2 ^ (t + 4) * (2 ^ s - 1) = 3 ^ s - 1) : False := by
  have hleft : ((2 ^ (t + 4) * (2 ^ s - 1) : Nat) : ZMod 4) = 0 := by
    have hpow : ((2 : ZMod 4) ^ (t + 4)) = 0 := by
      rw [pow_add]
      rw [show ((2 : ZMod 4) ^ 4) = 0 by native_decide]
      simp
    simp only [Nat.cast_mul, Nat.cast_pow, Nat.cast_ofNat]
    rw [hpow]
    simp
  have hright : ((3 ^ s - 1 : Nat) : ZMod 4) = 2 := by
    have hge : 1 <= 3 ^ s := Nat.one_le_pow s 3 (by norm_num)
    rw [Nat.cast_sub hge]
    have h3 : (3 : ZMod 4) = -1 := by native_decide
    simp only [Nat.cast_pow, Nat.cast_one, Nat.cast_ofNat]
    rw [h3, Odd.neg_one_pow hs]
    native_decide
  have heq : ((2 ^ (t + 4) * (2 ^ s - 1) : Nat) : ZMod 4) =
      ((3 ^ s - 1 : Nat) : ZMod 4) := by
    rw [h]
  rw [hleft, hright] at heq
  exact (show Ne (0 : ZMod 4) 2 by native_decide) heq
theorem residual_tail_equality_impossible_even (t s : Nat) (hs : Even s) (hspos : 1 <= s)
    (h : 2 ^ (t + 4) * (2 ^ s - 1) = 3 ^ s - 1) : False := by
  have hleft : ((2 ^ (t + 4) * (2 ^ s - 1) : Nat) : ZMod 3) = 0 := by
    have hinner : ((2 ^ s - 1 : Nat) : ZMod 3) = 0 := by
      have hge : 1 <= 2 ^ s := Nat.one_le_pow s 2 (by norm_num)
      rw [Nat.cast_sub hge]
      have h2 : (2 : ZMod 3) = -1 := by native_decide
      simp only [Nat.cast_pow, Nat.cast_one, Nat.cast_ofNat]
      rw [h2, Even.neg_one_pow hs]
      native_decide
    simp only [Nat.cast_mul, Nat.cast_pow, Nat.cast_ofNat]
    rw [hinner]
    simp
  have hright : ((3 ^ s - 1 : Nat) : ZMod 3) = 2 := by
    have hge : 1 <= 3 ^ s := Nat.one_le_pow s 3 (by norm_num)
    rw [Nat.cast_sub hge]
    have hpow : ((3 : ZMod 3) ^ s) = 0 := by
      cases s with
      | zero => omega
      | succ s =>
          rw [pow_succ]
          rw [show (3 : ZMod 3) = 0 by native_decide]
          simp
    simp only [Nat.cast_pow, Nat.cast_one, Nat.cast_ofNat]
    rw [hpow]
    native_decide
  have heq : ((2 ^ (t + 4) * (2 ^ s - 1) : Nat) : ZMod 3) =
      ((3 ^ s - 1 : Nat) : ZMod 3) := by
    rw [h]
  rw [hleft, hright] at heq
  exact (show Ne (0 : ZMod 3) 2 by native_decide) heq
theorem residual_tail_equality_impossible (t s : Nat) (hspos : 1 <= s)
    (h : 2 ^ (t + 4) * (2 ^ s - 1) = 3 ^ s - 1) : False := by
  cases Nat.even_or_odd s with
  | inl hs => exact residual_tail_equality_impossible_even t s hs hspos h
  | inr hs => exact residual_tail_equality_impossible_odd t s hs h
theorem residual_tail_contracting_strict_of_coeff_large (z : Nat)
    (hlarge :
      (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z >=
        (2 : Int) ^ (residual_tNext z + 4) - 1) :
    (residual_QReentry z : Int) < (residual_Q4 z : Int) := by
  have hle := residual_tail_contracting_non_strict_of_coeff_large z hlarge
  by_contra hnot
  have heqQR : (residual_QReentry z : Int) = (residual_Q4 z : Int) := by
    omega
  have hsign := residual_tail_sign_identity_int z
  have hzero :
      (residual_QNext z : Int) *
          ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) -
        (2 : Int) ^ (residual_tNext z + 4) + 1 = 0 := by
    rw [Eq.symm hsign]
    rw [heqQR]
    ring
  have hcoeff_nonneg :
      0 <=
        (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z := by
    have hB : (1 : Int) <= (2 : Int) ^ (residual_tNext z + 4) := by
      exact one_le_pow₀ (by norm_num : (1 : Int) <= 2)
    nlinarith
  have hq : (1 : Int) <= (residual_QNext z : Int) := by
    exact_mod_cast residual_QNext_pos z
  have hcoeff_eq :
      (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z =
        (2 : Int) ^ (residual_tNext z + 4) - 1 := by
    have hmul :
        ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) <=
          (residual_QNext z : Int) *
            ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
              (3 : Int) ^ residual_LNext z) := by
      nlinarith [mul_nonneg (by omega : (0 : Int) <= (residual_QNext z : Int)) hcoeff_nonneg]
    nlinarith
  have hnat :
      2 ^ (residual_tNext z + 4) * (2 ^ residual_LNext z - 1) =
        3 ^ residual_LNext z - 1 := by
    have hsge : 1 <= 2 ^ residual_LNext z :=
      Nat.one_le_pow (residual_LNext z) 2 (by norm_num)
    have h3ge : 1 <= 3 ^ residual_LNext z :=
      Nat.one_le_pow (residual_LNext z) 3 (by norm_num)
    have hcast : ((2 ^ (residual_tNext z + 4) *
          (2 ^ residual_LNext z - 1) : Nat) : Int) =
        ((3 ^ residual_LNext z - 1 : Nat) : Int) := by
      have hpow : (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) =
          (2 : Int) ^ (residual_tNext z + 4) *
            (2 : Int) ^ residual_LNext z := by
        have hidx : residual_tNext z + residual_LNext z + 4 =
            (residual_tNext z + 4) + residual_LNext z := by omega
        rw [hidx, pow_add]
      rw [hpow] at hcoeff_eq
      rw [Nat.cast_mul, Nat.cast_sub hsge, Nat.cast_sub h3ge]
      norm_num
      nlinarith
    exact_mod_cast hcast
  exact residual_tail_equality_impossible (residual_tNext z) (residual_LNext z)
    (residual_LNext_pos z) hnat
theorem pow3_gt_pow2_shift4_aux (k : Nat) :
    (3 : Int) ^ (7 + k) > (2 : Int) ^ (11 + k) := by
  induction k with
  | zero => norm_num
  | succ k ih =>
      change (3 : Int) ^ ((7 + k) + 1) > (2 : Int) ^ ((11 + k) + 1)
      rw [pow_succ, pow_succ]
      have hpos : (0 : Int) < (2 : Int) ^ (11 + k) := pow_pos (by norm_num) _
      nlinarith
theorem pow3_gt_pow2_shift4_of_ge7 (s : Nat) (hs : 7 <= s) :
    (3 : Int) ^ s > (2 : Int) ^ (s + 4) := by
  cases Nat.exists_eq_add_of_le hs with
  | intro k hk =>
      subst s
      have h := pow3_gt_pow2_shift4_aux k
      have hidx : 7 + k + 4 = 11 + k := by omega
      rwa [hidx]
