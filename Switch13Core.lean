theorem l1_forbidden_burst_row_mono
    (e0 e m qIn : Nat)
    (he : e0 <= e)
    (hfirst :
      3 ^ e0 * (3 ^ m * (qIn - 1)) <
        4 ^ m * (3 * 8 ^ e0 - 3 ^ e0)) :
    3 ^ e * (3 ^ m * (qIn - 1)) <
      4 ^ m * (3 * 8 ^ e - 3 ^ e) := by
  match Nat.exists_eq_add_of_le he with
  | Exists.intro d hd =>
      subst e
      have hmul3 :
          (3 ^ e0 * (3 ^ m * (qIn - 1))) * 3 ^ d <
            (4 ^ m * (3 * 8 ^ e0 - 3 ^ e0)) * 3 ^ d := by
        exact Nat.mul_lt_mul_of_pos_right hfirst (pow_pos (by norm_num : 0 < 3) d)
      have hleft :
          3 ^ (e0 + d) * (3 ^ m * (qIn - 1)) =
            (3 ^ e0 * (3 ^ m * (qIn - 1))) * 3 ^ d := by
        rw [Nat.pow_add]
        ring
      have hgap_mono :
          (3 * 8 ^ e0 - 3 ^ e0) * 3 ^ d <=
            3 * 8 ^ (e0 + d) - 3 ^ (e0 + d) := by
        have hpow_le : 3 ^ d <= 8 ^ d :=
          Nat.pow_le_pow_left (by norm_num : 3 <= 8) d
        have hmain : 3 * 8 ^ e0 * 3 ^ d <= 3 * 8 ^ e0 * 8 ^ d :=
          Nat.mul_le_mul_left (3 * 8 ^ e0) hpow_le
        have hsub :
            3 * 8 ^ e0 * 3 ^ d - 3 ^ e0 * 3 ^ d <=
              3 * 8 ^ e0 * 8 ^ d - 3 ^ e0 * 3 ^ d :=
          Nat.sub_le_sub_right hmain (3 ^ e0 * 3 ^ d)
        have hL : (3 * 8 ^ e0 - 3 ^ e0) * 3 ^ d =
            3 * 8 ^ e0 * 3 ^ d - 3 ^ e0 * 3 ^ d := by
          rw [Nat.sub_mul]
        have hR : 3 * 8 ^ (e0 + d) - 3 ^ (e0 + d) =
            3 * 8 ^ e0 * 8 ^ d - 3 ^ e0 * 3 ^ d := by
          rw [Nat.pow_add, Nat.pow_add]
          ring
        simpa [hL, hR] using hsub
      have hright_le :
          (4 ^ m * (3 * 8 ^ e0 - 3 ^ e0)) * 3 ^ d <=
            4 ^ m * (3 * 8 ^ (e0 + d) - 3 ^ (e0 + d)) := by
        calc
          (4 ^ m * (3 * 8 ^ e0 - 3 ^ e0)) * 3 ^ d =
              4 ^ m * ((3 * 8 ^ e0 - 3 ^ e0) * 3 ^ d) := by ring
          _ <= 4 ^ m * (3 * 8 ^ (e0 + d) - 3 ^ (e0 + d)) :=
              Nat.mul_le_mul_left (4 ^ m) hgap_mono
      have hchain := lt_of_lt_of_le hmul3 hright_le
      simpa [hleft] using hchain
