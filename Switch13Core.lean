    (hbeta_pos : 0 < beta) (hbeta_pos' : 0 < beta') :
    c7TwoStepParentResidual r beta h1 h2 = c7TwoStepParentResidual r' beta' h1 h2 := by
  unfold c7TwoStepParentResidual
  rw [c7_least_lift_agrees_on_finite_state r r' beta beta' h1 hh1 (by omega) (by omega),
    c7_second_least_lift_agrees_on_state r r' beta beta' h1 h2 hh1 hh2 hr hb hbeta_pos hbeta_pos']
theorem c7_child_beta_after_first_pos
    (r beta h1 : Nat) (hh1 : h1 = 1 ∨ h1 = 2) (hbeta_pos : 0 < beta) :
    0 < c7ChildBetaAfterFirst r beta h1 := by
  rcases hh1 with rfl | rfl
  · have hnum_ge : 2 ≤ c7ChildBetaNumerator r beta 1 (c7LeastResidual r beta 1) := by
      dsimp [c7ChildBetaNumerator]
      have hcoeff : 0 < c7Coeff r := c7_coeff_pos r
      omega
    unfold c7ChildBetaAfterFirst c7ChildBeta
    dsimp
    exact Nat.div_pos hnum_ge (by norm_num)
  · have hnum_ge : 4 ≤ c7ChildBetaNumerator r beta 2 (c7LeastResidual r beta 2) := by
      dsimp [c7ChildBetaNumerator]
      have hcoeff : 0 < c7Coeff r := c7_coeff_pos r
      omega
    unfold c7ChildBetaAfterFirst c7ChildBeta
    simp only [if_neg (by norm_num : (2 : Nat) ≠ 1)]
    exact Nat.div_pos hnum_ge (by norm_num)
theorem c7_third_least_lift_agrees_on_state
    (r r' beta beta' h1 h2 h3 : Nat)
    (hh1 : h1 = 1 ∨ h1 = 2) (hh2 : h2 = 1 ∨ h2 = 2) (hh3 : h3 = 1 ∨ h3 = 2)
    (hr : r % 16 = r' % 16) (hb : beta % 64 = beta' % 64)
    (hbeta_pos : 0 < beta) (hbeta_pos' : 0 < beta') :
    c7ThirdLeastLift r beta h1 h2 h3 = c7ThirdLeastLift r' beta' h1 h2 h3 := by
  unfold c7ThirdLeastLift c7ChildBetaAfterSecond c7SecondLeastLift c7ChildBetaAfterFirst
  have hr16 : Nat.ModEq 16 r r' := by unfold Nat.ModEq; omega
  have hb64 : Nat.ModEq 64 beta beta' := by unfold Nat.ModEq; omega
  have hchild1_pos := c7_child_beta_after_first_pos r beta h1 hh1 hbeta_pos
  have hchild1_pos' := c7_child_beta_after_first_pos r' beta' h1 hh1 hbeta_pos'
  have hchild1_16 :=
    c7_child_beta_mod16_agrees_on_state r r' beta beta' h1 hh1 hr16 hb64 hbeta_pos hbeta_pos'
  have hr1 : Nat.ModEq 4 (r + 1) (r' + 1) := by unfold Nat.ModEq; omega
  have hchild2_mod4 :=
    c7_child_beta_mod4_agrees_on_state (r + 1) (r' + 1)
      (c7ChildBetaAfterFirst r beta h1) (c7ChildBetaAfterFirst r' beta' h1) h2 hh2
      hr1 (Nat.ModEq.of_dvd (by norm_num : 16 ∣ 2 ^ 4) hchild1_16)
      hchild1_pos hchild1_pos'
  have hr2 : (r + 2) % 2 = (r' + 2) % 2 := by omega
  have hb2 : c7ChildBetaAfterSecond r beta h1 h2 % 4 =
      c7ChildBetaAfterSecond r' beta' h1 h2 % 4 := by
    unfold Nat.ModEq at hchild2_mod4
    exact hchild2_mod4
  exact c7_least_lift_agrees_on_finite_state (r + 2) (r' + 2)
    (c7ChildBetaAfterSecond r beta h1 h2) (c7ChildBetaAfterSecond r' beta' h1 h2) h3 hh3 hr2 hb2
theorem c7_three_step_parent_residual_agrees_on_state
    (r r' beta beta' h1 h2 h3 : Nat)
    (hh1 : h1 = 1 ∨ h1 = 2) (hh2 : h2 = 1 ∨ h2 = 2) (hh3 : h3 = 1 ∨ h3 = 2)
    (hr : r % 16 = r' % 16) (hb : beta % 64 = beta' % 64)
    (hbeta_pos : 0 < beta) (hbeta_pos' : 0 < beta') :
    c7ThreeStepParentResidual r beta h1 h2 h3 =
      c7ThreeStepParentResidual r' beta' h1 h2 h3 := by
  unfold c7ThreeStepParentResidual
  have hr4 : r % 4 = r' % 4 := by omega
  have hb16 : beta % 16 = beta' % 16 := by omega
  rw [c7_two_step_parent_residual_agrees_on_state r r' beta beta' h1 h2 hh1 hh2 hr4 hb16 hbeta_pos hbeta_pos',
    c7_third_least_lift_agrees_on_state r r' beta beta' h1 h2 h3 hh1 hh2 hh3 hr hb hbeta_pos hbeta_pos']
theorem c7_sibling_key_cross_add_mod
    (K b₁ b₁' b₂ b₂' : Nat)
    (hb₁ : Nat.ModEq K b₁ b₁')
    (hb₂ : Nat.ModEq K b₂ b₂') :
    Nat.ModEq K (b₂ + b₁') (b₂' + b₁) := by
  exact hb₂.add hb₁.symm
theorem c7_sibling_key_difference_mod
    (K b₁ b₁' b₂ b₂' x x' : Nat)
    (hb₁ : Nat.ModEq K b₁ b₁')
    (hb₂ : Nat.ModEq K b₂ b₂')
    (hx : x + b₁ = b₂)
    (hx' : x' + b₁' = b₂') :
    Nat.ModEq K x x' := by
  have hcross := c7_sibling_key_cross_add_mod K b₁ b₁' b₂ b₂' hb₁ hb₂
  have hrewrite : Nat.ModEq K (x + b₁ + b₁') (x' + b₁' + b₁) := by
    simpa [hx, hx', Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hcross
  have hbb : Nat.ModEq K (b₁ + b₁') (b₁' + b₁) := by
    rw [Nat.add_comm]
  exact hbb.add_right_cancel
    (by simpa [Nat.add_assoc] using hrewrite)
theorem c7_low_valued_sibling_key_of_parent_state
    (M r r' beta beta' q₁ q₂ b₁ b₁' b₂ b₂' x x' : Nat)
    (hM : 2 <= M)
    (hr : Nat.ModEq (2 ^ M) r r')
    (hbeta : Nat.ModEq (2 ^ (M + 2)) beta beta')
    (hb₁ :
      2 * b₁ = 3 * beta + 3 ^ (r + 2) * q₁ + 1)
    (hb₁' :
      2 * b₁' = 3 * beta' + 3 ^ (r' + 2) * q₁ + 1)
    (hb₂ :
      4 * b₂ = 3 * beta + 3 ^ (r + 2) * q₂ + 2)
    (hb₂' :
      4 * b₂' = 3 * beta' + 3 ^ (r' + 2) * q₂ + 2)
    (hx : x + b₁ = b₂)
    (hx' : x' + b₁' = b₂') :
    Nat.ModEq (2 ^ M) b₁ b₁' ∧ Nat.ModEq (2 ^ M) x x' := by
  have hb1mod :=
    c7_child_beta_h1_mod_pow_of_parent_state
      M r r' beta beta' q₁ b₁ b₁' hM hr hbeta hb₁ hb₁'
  have hb2mod :=
    c7_child_beta_h2_mod_pow_of_parent_state
      M r r' beta beta' q₂ b₂ b₂' hM hr hbeta hb₂ hb₂'
  exact ⟨hb1mod,
    c7_sibling_key_difference_mod (2 ^ M) b₁ b₁' b₂ b₂' x x' hb1mod hb2mod hx hx'⟩
theorem c7_two_step_parent_residual_mod
    (h₁ h₂ q₁ q₂ t t₁ : Nat)
    (ht : t = q₁ + 2 ^ h₁ * t₁)
    (ht₁ : Nat.ModEq (2 ^ h₂) t₁ q₂) :
    Nat.ModEq (2 ^ (h₁ + h₂)) t (q₁ + 2 ^ h₁ * q₂) := by
  subst t
  have hmul :
      Nat.ModEq (2 ^ h₁ * 2 ^ h₂)
        (2 ^ h₁ * t₁) (2 ^ h₁ * q₂) :=
    Nat.ModEq.mul_left' (2 ^ h₁) ht₁
  have hrewrite :
      Nat.ModEq (2 ^ (h₁ + h₂))
        (2 ^ h₁ * t₁) (2 ^ h₁ * q₂) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left q₁ hrewrite
theorem c7_two_step_full_residue_mod
    (P : C7ParentCylinder) (h₁ h₂ q₁ q₂ n t t₁ : Nat)
    (hparam : P.Param n t)
    (ht : t = q₁ + 2 ^ h₁ * t₁)
    (ht₁ : Nat.ModEq (2 ^ h₂) t₁ q₂) :
    Nat.ModEq (2 ^ (P.S + 1 + (h₁ + h₂))) n
      (P.m + 2 ^ (P.S + 1) * (q₁ + 2 ^ h₁ * q₂)) := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have htmod := c7_two_step_parent_residual_mod h₁ h₂ q₁ q₂ t t₁ ht ht₁
  have hmul :
      Nat.ModEq (2 ^ (P.S + 1) * 2 ^ (h₁ + h₂))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * (q₁ + 2 ^ h₁ * q₂)) :=
    Nat.ModEq.mul_left' (2 ^ (P.S + 1)) htmod
  have hrewrite :
      Nat.ModEq (2 ^ (P.S + 1 + (h₁ + h₂)))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * (q₁ + 2 ^ h₁ * q₂)) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left P.m hrewrite
theorem c7_two_step_parent_residual_unique
    (h₁ h₂ q₁ q₂ t t' t₁ t₁' : Nat)
    (ht : t = q₁ + 2 ^ h₁ * t₁)
    (ht' : t' = q₁ + 2 ^ h₁ * t₁')
    (ht₁ : Nat.ModEq (2 ^ h₂) t₁ q₂)
    (ht₁' : Nat.ModEq (2 ^ h₂) t₁' q₂) :
    Nat.ModEq (2 ^ (h₁ + h₂)) t t' := by
  have htmod := c7_two_step_parent_residual_mod h₁ h₂ q₁ q₂ t t₁ ht ht₁
  have htmod' := c7_two_step_parent_residual_mod h₁ h₂ q₁ q₂ t' t₁' ht' ht₁'
  exact Nat.ModEq.trans htmod (Nat.ModEq.symm htmod')
theorem c7_two_step_full_residue_unique
    (P : C7ParentCylinder) (h₁ h₂ q₁ q₂ n n' t t' t₁ t₁' : Nat)
    (hparam : P.Param n t)
    (hparam' : P.Param n' t')
    (ht : t = q₁ + 2 ^ h₁ * t₁)
    (ht' : t' = q₁ + 2 ^ h₁ * t₁')
    (ht₁ : Nat.ModEq (2 ^ h₂) t₁ q₂)
    (ht₁' : Nat.ModEq (2 ^ h₂) t₁' q₂) :
    Nat.ModEq (2 ^ (P.S + 1 + (h₁ + h₂))) n n' := by
  have hnmod :=
    c7_two_step_full_residue_mod P h₁ h₂ q₁ q₂ n t t₁ hparam ht ht₁
  have hnmod' :=
    c7_two_step_full_residue_mod P h₁ h₂ q₁ q₂ n' t' t₁' hparam' ht' ht₁'
  exact Nat.ModEq.trans hnmod (Nat.ModEq.symm hnmod')
theorem c7_three_step_parent_residual_mod
    (h₁ h₂ h₃ q₁ q₂ q₃ t t₂ : Nat)
    (ht : t = q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * t₂)
    (ht₂ : Nat.ModEq (2 ^ h₃) t₂ q₃) :
    Nat.ModEq (2 ^ (h₁ + h₂ + h₃)) t
      (q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * q₃) := by
  subst t
  have hmul :
      Nat.ModEq (2 ^ (h₁ + h₂) * 2 ^ h₃)
        (2 ^ (h₁ + h₂) * t₂) (2 ^ (h₁ + h₂) * q₃) :=
    Nat.ModEq.mul_left' (2 ^ (h₁ + h₂)) ht₂
  have hrewrite :
      Nat.ModEq (2 ^ (h₁ + h₂ + h₃))
        (2 ^ (h₁ + h₂) * t₂) (2 ^ (h₁ + h₂) * q₃) := by
    simpa [pow_add, Nat.add_assoc, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left (q₁ + 2 ^ h₁ * q₂) hrewrite
theorem c7_three_step_full_residue_mod
    (P : C7ParentCylinder) (h₁ h₂ h₃ q₁ q₂ q₃ n t t₂ : Nat)
    (hparam : P.Param n t)
    (ht : t = q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * t₂)
    (ht₂ : Nat.ModEq (2 ^ h₃) t₂ q₃) :
    Nat.ModEq (2 ^ (P.S + 1 + (h₁ + h₂ + h₃))) n
      (P.m + 2 ^ (P.S + 1) *
        (q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * q₃)) := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have htmod := c7_three_step_parent_residual_mod h₁ h₂ h₃ q₁ q₂ q₃ t t₂ ht ht₂
  have hmul :
      Nat.ModEq (2 ^ (P.S + 1) * 2 ^ (h₁ + h₂ + h₃))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) *
          (q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * q₃)) :=
    Nat.ModEq.mul_left' (2 ^ (P.S + 1)) htmod
  have hrewrite :
      Nat.ModEq (2 ^ (P.S + 1 + (h₁ + h₂ + h₃)))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) *
          (q₁ + 2 ^ h₁ * q₂ + 2 ^ (h₁ + h₂) * q₃)) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left P.m hrewrite
theorem c7_two_step_least_lift_cylinder
    (P : C7ParentCylinder) (r beta h1 h2 n t : Nat)
    (_hh1 : h1 = 1 ∨ h1 = 2) (_hh2 : h2 = 1 ∨ h2 = 2)
    (hparam : P.Param n t)
    (hres : Nat.ModEq (2 ^ (h1 + h2)) t (c7TwoStepParentResidual r beta h1 h2)) :
    Nat.ModEq (2 ^ (P.S + 1 + (h1 + h2))) n
      (P.m + 2 ^ (P.S + 1) * c7TwoStepParentResidual r beta h1 h2) := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have hmul :=
      Nat.ModEq.mul_left' (2 ^ (P.S + 1)) hres
  have htmod :
      Nat.ModEq (2 ^ (P.S + 1 + (h1 + h2)))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * c7TwoStepParentResidual r beta h1 h2) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left P.m htmod
theorem c7_three_step_least_lift_cylinder
    (P : C7ParentCylinder) (r beta h1 h2 h3 n t : Nat)
    (_hh1 : h1 = 1 ∨ h1 = 2) (_hh2 : h2 = 1 ∨ h2 = 2) (_hh3 : h3 = 1 ∨ h3 = 2)
    (hparam : P.Param n t)
    (hres : Nat.ModEq (2 ^ (h1 + h2 + h3)) t (c7ThreeStepParentResidual r beta h1 h2 h3)) :
    Nat.ModEq (2 ^ (P.S + 1 + (h1 + h2 + h3))) n
      (P.m + 2 ^ (P.S + 1) * c7ThreeStepParentResidual r beta h1 h2 h3) := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have hmul :=
      Nat.ModEq.mul_left' (2 ^ (P.S + 1)) hres
  have htmod :
      Nat.ModEq (2 ^ (P.S + 1 + (h1 + h2 + h3)))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * c7ThreeStepParentResidual r beta h1 h2 h3) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hmul
  exact Nat.ModEq.add_left P.m htmod
theorem c7_common_start_forces_common_coarse_residue
    (T_A T_B n c_A c_B : Nat)
    (hA : Nat.ModEq (2 ^ T_A) n c_A)
    (hB : Nat.ModEq (2 ^ T_B) n c_B) :
    Nat.ModEq (2 ^ Nat.min T_A T_B) c_A c_B := by
  have hAmin : Nat.ModEq (2 ^ Nat.min T_A T_B) n c_A :=
    Nat.ModEq.of_dvd (Nat.pow_dvd_pow 2 (Nat.min_le_left T_A T_B)) hA
  have hBmin : Nat.ModEq (2 ^ Nat.min T_A T_B) n c_B :=
    Nat.ModEq.of_dvd (Nat.pow_dvd_pow 2 (Nat.min_le_right T_A T_B)) hB
  exact Nat.ModEq.trans (Nat.ModEq.symm hAmin) hBmin
theorem c7_low_valued_two_step_conflict
    (T_A T_B n c_A c_B : Nat)
    (hconflict : ¬ Nat.ModEq (2 ^ Nat.min T_A T_B) c_A c_B)
    (hA : Nat.ModEq (2 ^ T_A) n c_A)
    (hB : Nat.ModEq (2 ^ T_B) n c_B) :
    False := by
  exact hconflict (c7_common_start_forces_common_coarse_residue T_A T_B n c_A c_B hA hB)
theorem c7_low_valued_two_step_parent_residual_four_state_menu
    (r beta h1 h2 t : Nat)
    (hh1 : h1 = 1 ∨ h1 = 2)
    (hh2 : h2 = 1 ∨ h2 = 2)
    (hres : Nat.ModEq (2 ^ (h1 + h2)) t (c7TwoStepParentResidual r beta h1 h2)) :
    Nat.ModEq (2 ^ (1 + 1)) t (c7TwoStepParentResidual r beta 1 1) ∨
      Nat.ModEq (2 ^ (1 + 2)) t (c7TwoStepParentResidual r beta 1 2) ∨
      Nat.ModEq (2 ^ (2 + 1)) t (c7TwoStepParentResidual r beta 2 1) ∨
      Nat.ModEq (2 ^ (2 + 2)) t (c7TwoStepParentResidual r beta 2 2) := by
  rcases hh1 with rfl | rfl
  · rcases hh2 with rfl | rfl
    · exact Or.inl hres
    · exact Or.inr (Or.inl hres)
  · rcases hh2 with rfl | rfl
    · exact Or.inr (Or.inr (Or.inl hres))
    · exact Or.inr (Or.inr (Or.inr hres))
theorem c7_low_valued_two_step_full_four_state_menu
    (P : C7ParentCylinder) (r beta h1 h2 n t : Nat)
    (hh1 : h1 = 1 ∨ h1 = 2)
    (hh2 : h2 = 1 ∨ h2 = 2)
    (hparam : P.Param n t)
    (hres : Nat.ModEq (2 ^ (h1 + h2)) t (c7TwoStepParentResidual r beta h1 h2)) :
    Nat.ModEq (2 ^ (P.S + 1 + (1 + 1))) n
        (P.m + 2 ^ (P.S + 1) * c7TwoStepParentResidual r beta 1 1) ∨
      Nat.ModEq (2 ^ (P.S + 1 + (1 + 2))) n
        (P.m + 2 ^ (P.S + 1) * c7TwoStepParentResidual r beta 1 2) ∨
      Nat.ModEq (2 ^ (P.S + 1 + (2 + 1))) n
        (P.m + 2 ^ (P.S + 1) * c7TwoStepParentResidual r beta 2 1) ∨
      Nat.ModEq (2 ^ (P.S + 1 + (2 + 2))) n
        (P.m + 2 ^ (P.S + 1) * c7TwoStepParentResidual r beta 2 2) := by
  rcases hh1 with rfl | rfl
  · rcases hh2 with rfl | rfl
    · exact Or.inl
        (c7_two_step_least_lift_cylinder P r beta 1 1 n t
          (Or.inl rfl) (Or.inl rfl) hparam hres)
    · exact Or.inr (Or.inl
        (c7_two_step_least_lift_cylinder P r beta 1 2 n t
          (Or.inl rfl) (Or.inr rfl) hparam hres))
  · rcases hh2 with rfl | rfl
    · exact Or.inr (Or.inr (Or.inl
        (c7_two_step_least_lift_cylinder P r beta 2 1 n t
          (Or.inr rfl) (Or.inl rfl) hparam hres)))
    · exact Or.inr (Or.inr (Or.inr
        (c7_two_step_least_lift_cylinder P r beta 2 2 n t
          (Or.inr rfl) (Or.inr rfl) hparam hres)))
def c7ListMax : List Nat → Nat
  | [] => 0
  | x :: xs => max x (c7ListMax xs)
theorem c7_list_max_ge_mem {menu : List Nat} {bound : Nat → Nat} {h₀ : Nat}
    (hmem : h₀ ∈ menu) :
    bound h₀ ≤ c7ListMax (menu.map bound) := by
  induction menu with
  | nil => simp at hmem
  | cons x xs ih =>
      simp only [c7ListMax, List.map, List.mem_cons] at hmem ⊢
      rcases hmem with rfl | hmem
      · exact le_max_left _ _
      · exact le_trans (ih hmem) (le_max_right _ _)
theorem c7_finite_live_child_length_bound
    (r len : Nat) (menu : List Nat) (bound : Nat → Nat)
    (_hmenu_bound : ∀ h ∈ menu, r + 1 ≤ bound h)
    (hcase : len ≤ r ∨ ∃ h ∈ menu, len ≤ bound h) :
    len ≤ max r (c7ListMax (menu.map bound)) := by
  rcases hcase with hshort | hex
  · exact le_trans hshort (Nat.le_max_left r (c7ListMax (menu.map bound)))
  · rcases hex with ⟨h₀, hmem, hlen⟩
    exact le_trans hlen (le_max_of_le_right (c7_list_max_ge_mem hmem))
def c7FourTwoStepBound (D11 D12 D21 D22 : Nat) : Nat :=
  max (max D11 D12) (max D21 D22)
theorem c7_two_step_live_child_length_bound
    (r len D11 D12 D21 D22 : Nat)
    (hD11 : r + 1 <= D11)
    (hcase :
      len <= r + 1 ∨
        len <= D11 ∨ len <= D12 ∨ len <= D21 ∨ len <= D22) :
    len <= c7FourTwoStepBound D11 D12 D21 D22 := by
  unfold c7FourTwoStepBound
  rcases hcase with hshort | hlong
  · exact le_trans hshort (le_trans hD11 (le_trans (Nat.le_max_left D11 D12)
      (Nat.le_max_left (max D11 D12) (max D21 D22))))
  · rcases hlong with h11 | h12 | h21 | h22
    · exact le_trans h11 (le_trans (Nat.le_max_left D11 D12)
        (Nat.le_max_left (max D11 D12) (max D21 D22)))
    · exact le_trans h12 (le_trans (Nat.le_max_right D11 D12)
        (Nat.le_max_left (max D11 D12) (max D21 D22)))
    · exact le_trans h21 (le_trans (Nat.le_max_left D21 D22)
        (Nat.le_max_right (max D11 D12) (max D21 D22)))
    · exact le_trans h22 (le_trans (Nat.le_max_right D21 D22)
        (Nat.le_max_right (max D11 D12) (max D21 D22)))
theorem c7_two_step_live_child_length_bound_from_two_step_bounds
    (r len D11 D12 D21 D22 : Nat)
    (hD11 : r + 2 <= D11)
    (_hD12 : r + 2 <= D12)
    (_hD21 : r + 2 <= D21)
    (_hD22 : r + 2 <= D22)
    (hcase :
      len <= r + 1 ∨
