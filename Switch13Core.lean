theorem c17TerminalOutcomeCert_baseTemplate_family_sound
    (qm qb u leaf : Nat) (hqm : qm % 6 = 0)
    (hqb : qb % 6 = 1 ∨ qb % 6 = 3) :
    FinalTerminalOutcome.Sound (.baseTemplate (qm * u + qb) leaf) := by
  unfold FinalTerminalOutcome.Sound
  have hmod : (qm * u + qb) % 6 = qb % 6 := by
    rw [Nat.add_mod, Nat.mul_mod, hqm]
    simp
  cases hqb with
  | inl h =>
      left
      rw [hmod, h]
  | inr h =>
      right
      rw [hmod, h]
theorem no_positive_nat_divisible_by_all_powers_two
    (x : Nat) (hx : 0 < x) (hdiv : ∀ k, 2 ^ k ∣ x) : False := by
  have hbad := hdiv (x + 1)
  obtain ⟨c, hc⟩ := hbad
  have hpow : x < 2 ^ (x + 1) := by
    have hs : x + 1 < 2 ^ (x + 1) := Nat.lt_two_pow_self
    omega
  have hle : 2 ^ (x + 1) ≤ x := by
    cases c with
    | zero =>
        omega
    | succ c =>
        calc
          2 ^ (x + 1) ≤ 2 ^ (x + 1) * (c + 1) :=
            Nat.le_mul_of_pos_right (2 ^ (x + 1)) (Nat.succ_pos c)
          _ = x := hc.symm
  omega
theorem noNaturalInfiniteSpine_terminal_value
    (mNextM mNextB u : Nat)
    (hspine : ∀ k, 2 ^ k ∣ mNextM * u + (mNextB + 1)) : False := by
  exact no_positive_nat_divisible_by_all_powers_two
    (mNextM * u + (mNextB + 1)) (by omega) hspine

