      InterfaceClosed GlobalEntryRow.baseTemplate.interface := by
  have hs : (c17GeneratedNaturalTailCert.outcome i u).Sound :=
    c17GeneratedNaturalTailCert_closes i u hi
  exact ⟨rfl, trivial⟩

def c5V2Fuel : Nat -> Nat -> Nat
  | 0, _ => 0
  | fuel + 1, n =>
      if n = 0 then
        0
      else if n % 2 = 0 then
        1 + c5V2Fuel fuel (n / 2)
      else
        0
def c5V2 (n : Nat) : Nat := c5V2Fuel n n
def c5ExactBreakSuccessor (q : Nat) : Nat :=
  let m := 2 * q - 1
  let L := c5V2 (m + 1)
  let qCurr := (m + 1) / (2 ^ L)
  let raw := (3 ^ L) * qCurr - 1
  let r := c5V2 raw
  let mNext := raw / (2 ^ r)
  let LNext := c5V2 (mNext + 1)
  (mNext + 1) / (2 ^ LNext)
theorem c5_funnel_378341 : c5ExactBreakSuccessor 378341 = 70939 := by native_decide
theorem c5_funnel_70939 : c5ExactBreakSuccessor 70939 = 6651 := by native_decide
theorem c5_funnel_6651 : c5ExactBreakSuccessor 6651 = 39 := by native_decide
theorem c5_funnel_39 : c5ExactBreakSuccessor 39 = 15 := by native_decide
theorem c5_funnel_15 : c5ExactBreakSuccessor 15 = 3 := by native_decide
theorem c5_funnel_3 : c5ExactBreakSuccessor 3 = 1 := by native_decide
theorem c5_funnel_1_fixed : c5ExactBreakSuccessor 1 = 1 := by native_decide
theorem c5_funnel_reaches_one_core :
    c5ExactBreakSuccessor 378341 = 70939 ∧
    c5ExactBreakSuccessor 70939 = 6651 ∧
    c5ExactBreakSuccessor 6651 = 39 ∧
    c5ExactBreakSuccessor 39 = 15 ∧
    c5ExactBreakSuccessor 15 = 3 ∧
    c5ExactBreakSuccessor 3 = 1 ∧
    c5ExactBreakSuccessor 1 = 1 := by
  exact ⟨c5_funnel_378341, c5_funnel_70939, c5_funnel_6651,
    c5_funnel_39, c5_funnel_15, c5_funnel_3, c5_funnel_1_fixed⟩
def c5BreakIter (q : Nat) : Nat -> Nat
  | 0 => q
  | n + 1 => c5BreakIter (c5ExactBreakSuccessor q) n
theorem c5_breakIter_one (n : Nat) : c5BreakIter 1 n = 1 := by
  induction n with
  | zero => rfl
  | succ k ih =>
      show c5BreakIter (c5ExactBreakSuccessor 1) k = 1
      rw [c5_funnel_1_fixed]
      exact ih
