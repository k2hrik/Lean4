def c10V2Fuel : Nat -> Nat -> Nat
  | 0, _ => 0
  | fuel + 1, n =>
      if n = 0 then
        0
      else if n % 2 = 0 then
        1 + c10V2Fuel fuel (n / 2)
      else
        0
def c10V2 (n : Nat) : Nat := c10V2Fuel n n
def c10TOdd (n : Nat) : Nat :=
  (3 * n + 1) / 2 ^ c10V2 (3 * n + 1)
def c10TOddIter (n : Nat) : Nat -> Nat
  | 0 => n
  | k + 1 => c10TOdd (c10TOddIter n k)
theorem c10V2Fuel_eq_c3V2_of_le (fuel n : Nat) (hn : n <= fuel) :
    c10V2Fuel fuel n = c3V2 n := by
  induction fuel generalizing n with
  | zero =>
      have hn0 : n = 0 := by omega
      subst hn0
      simp [c10V2Fuel, c3V2]
  | succ fuel ih =>
      cases n with
      | zero =>
          simp [c10V2Fuel, c3V2]
      | succ m =>
          unfold c10V2Fuel c3V2
          by_cases heven : (m + 1) % 2 = 0
          · simp [heven]
            have hhalf : (m + 1) / 2 <= fuel := by omega
            exact ih ((m + 1) / 2) hhalf
          · simp [heven]
theorem c10V2_eq_c3V2 (n : Nat) :
    c10V2 n = c3V2 n := by
  exact c10V2Fuel_eq_c3V2_of_le n n (by omega)
theorem c10TOdd_eq_c3OddStep (n : Nat) :
    c10TOdd n = c3OddStep n := by
  unfold c10TOdd c3OddStep
  rw [c10V2_eq_c3V2]
def c10ReachesOneOdd (n : Nat) : Prop :=
  Exists (fun k : Nat => c10TOddIter n k = 1)
def c10ReachesSmallerOdd (n : Nat) : Prop :=
  Exists (fun k : Nat =>
    Exists (fun m : Nat =>
      0 < m ∧ Odd m ∧ m < n ∧ c10TOddIter n k = m))
def c10OddDescentStatement : Prop :=
  forall n : Nat, 0 < n -> Odd n -> 1 < n ->
    c10ReachesOneOdd n ∨ c10ReachesSmallerOdd n
theorem c10_iter_append (n a b : Nat) :
    c10TOddIter (c10TOddIter n a) b = c10TOddIter n (a + b) := by
  induction b with
  | zero =>
      simp [c10TOddIter]
  | succ b ih =>
      simp [c10TOddIter, ih]
theorem c10_reaches_one_trans (n m : Nat)
    (hnm : Exists (fun k : Nat => c10TOddIter n k = m))
    (hm : c10ReachesOneOdd m) :
    c10ReachesOneOdd n := by
  rcases hnm with ⟨k, hk⟩
  rcases hm with ⟨j, hj⟩
  refine ⟨k + j, ?_⟩
  rw [← c10_iter_append n k j, hk, hj]
theorem c10_prefix_endpoint_one_to_reaches_one
    (original source prefixK k : Nat)
    (hprefix : c10TOddIter original prefixK = source)
    (hend : c10TOddIter source k = 1) :
    c10ReachesOneOdd original := by
  refine ⟨prefixK + k, ?_⟩
  rw [← c10_iter_append original prefixK k, hprefix, hend]
theorem c10_prefix_endpoint_smaller_to_reaches_smaller
    (original source prefixK k endpoint : Nat)
    (hprefix : c10TOddIter original prefixK = source)
    (hend : c10TOddIter source k = endpoint)
    (hendpos : 0 < endpoint)
    (hendodd : endpoint % 2 = 1)
    (hendlt : endpoint < original) :
    c10ReachesSmallerOdd original := by
  refine ⟨prefixK + k, endpoint, hendpos, Nat.odd_iff.mpr hendodd, hendlt, ?_⟩
  rw [← c10_iter_append original prefixK k, hprefix, hend]
theorem c10_prefix_closeout_to_descent_alternative
    (original source prefixK : Nat)
    (hprefix : c10TOddIter original prefixK = source)
    (hsource_lt : source < original)
    (hcloseout : c10ReachesOneOdd source ∨ c10ReachesSmallerOdd source) :
    c10ReachesOneOdd original ∨ c10ReachesSmallerOdd original := by
  cases hcloseout with
  | inl hone =>
      rcases hone with ⟨k, hend⟩
      exact Or.inl
        (c10_prefix_endpoint_one_to_reaches_one
          original source prefixK k hprefix hend)
  | inr hsmall =>
      rcases hsmall with ⟨k, endpoint, hendpos, hendodd, hendlt, hend⟩
      exact Or.inr
        (c10_prefix_endpoint_smaller_to_reaches_smaller
          original source prefixK k endpoint hprefix hend
          hendpos (Nat.odd_iff.mp hendodd) (Nat.lt_trans hendlt hsource_lt))
theorem c10_endpoint_one_to_reaches_one (n k : Nat)
    (hend : c10TOddIter n k = 1) :
    c10ReachesOneOdd n :=
  ⟨k, hend⟩
theorem c10_endpoint_smaller_to_reaches_smaller (n k m : Nat)
    (hmpos : 0 < m)
    (hmodd : m % 2 = 1)
    (hmlt : m < n)
    (hend : c10TOddIter n k = m) :
    c10ReachesSmallerOdd n := by
  exact ⟨k, m, hmpos, Nat.odd_iff.mpr hmodd, hmlt, hend⟩
theorem c10_endpoint_closeout_to_descent_alternative (n k m : Nat)
    (hend : c10TOddIter n k = m)
    (hclose : m = 1 ∨ (0 < m ∧ m % 2 = 1 ∧ m < n)) :
    c10ReachesOneOdd n ∨ c10ReachesSmallerOdd n := by
  cases hclose with
  | inl hm1 =>
      exact Or.inl (c10_endpoint_one_to_reaches_one n k (by rw [hend, hm1]))
  | inr hsmall =>
      exact Or.inr
        (c10_endpoint_smaller_to_reaches_smaller n k m
          hsmall.1 hsmall.2.1 hsmall.2.2 hend)
theorem c10_todd_exit13_endpoint (q : Nat) (h : q % 16 = 13) :
    c10TOdd q = 6 * (q / 16) + 5 := by
  rw [c10TOdd_eq_c3OddStep]
  have hform := Nat.mod_add_div q 16
  rw [h] at hform
  conv_lhs =>
    arg 1
    rw [show q = 16 * (q / 16) + 13 by omega]
  exact c3OddStep_tunnel 16 13 3 6 5
    (by decide) (by decide) (by decide) (by decide) (q / 16)
theorem c10_exit13_to_descent_alternative (q : Nat) (h : q % 16 = 13) :
    c10ReachesOneOdd q ∨ c10ReachesSmallerOdd q := by
  have hend : c10TOddIter q 1 = 6 * (q / 16) + 5 := by
    simp [c10TOddIter, c10_todd_exit13_endpoint q h]
  exact Or.inr
    (c10_endpoint_smaller_to_reaches_smaller q 1 (6 * (q / 16) + 5)
      (by omega) (by omega) (by
        have hform := Nat.mod_add_div q 16
        rw [h] at hform
        omega) hend)
theorem c10_exit5_to_descent_alternative (q : Nat) (h : q % 16 = 5) :
    c10ReachesOneOdd q ∨ c10ReachesSmallerOdd q := by
  let m := c10TOdd q
  have hform := Nat.mod_add_div q 16
  rw [h] at hform
  have hqform : q = 16 * (q / 16) + 5 := by omega
  have hraw : 3 * q + 1 = 16 * (3 * (q / 16) + 1) := by omega
  have hraw_pos : 0 < 3 * q + 1 := by omega
  have hodd : m % 2 = 1 := by
    simp [m, c10TOdd_eq_c3OddStep, c3OddStep]
    exact c3_v2_quot_odd (3 * q + 1) hraw_pos
  have hpos : 0 < m := by
    have hodd' := hodd
    omega
  have hlt : m < q := by
    have hpow_dvd : 16 ∣ 2 ^ c3V2 (3 * q + 1) := by
      have hv_ge : 4 <= c3V2 (3 * q + 1) := by
        have hdiv16 : 2 ^ 4 ∣ 3 * q + 1 := by
          rw [hraw]
          exact ⟨3 * (q / 16) + 1, by norm_num⟩
        exact c3_pow_dvd_le_v2 4 (3 * q + 1) hraw_pos hdiv16
      simpa using Nat.pow_dvd_pow 2 hv_ge
    rcases hpow_dvd with ⟨s, hs⟩
    have hpow_pos : 0 < 2 ^ c3V2 (3 * q + 1) := Nat.pow_pos (by omega)
    have hs_pos : 0 < s := by
      by_contra hs0
      have hs_eq : s = 0 := by omega
      rw [hs_eq, Nat.mul_zero] at hs
      omega
    have hden_ge16 : 16 <= 2 ^ c3V2 (3 * q + 1) := by
      rw [hs]
      nlinarith [hs_pos]
    have hm_le : m <= (3 * q + 1) / 16 := by
      unfold m c10TOdd
      rw [c10V2_eq_c3V2]
      exact Nat.div_le_div_left hden_ge16 (by decide : 0 < 16)
    have hquot : (3 * q + 1) / 16 = 3 * (q / 16) + 1 := by
      rw [hraw]
      exact Nat.mul_div_right _ (by decide : 0 < 16)
    omega
  have hend : c10TOddIter q 1 = m := by
    simp [c10TOddIter, m]
  exact Or.inr
    (c10_endpoint_smaller_to_reaches_smaller q 1 m
      hpos hodd hlt hend)
theorem c10_todd_64a43_step1 (a : Nat) :
    c10TOdd (64 * a + 43) = 96 * a + 65 := by
  rw [c10TOdd_eq_c3OddStep]
  exact c3OddStep_tunnel 64 43 1 96 65
    (by decide) (by decide) (by decide) (by decide) a
theorem c10_todd_64a43_step2 (a : Nat) :
    c10TOdd (96 * a + 65) = 72 * a + 49 := by
  rw [c10TOdd_eq_c3OddStep]
  exact c3OddStep_tunnel 96 65 2 72 49
    (by decide) (by decide) (by decide) (by decide) a
theorem c10_todd_64a43_step3 (a : Nat) :
    c10TOdd (72 * a + 49) = 54 * a + 37 := by
  rw [c10TOdd_eq_c3OddStep]
  exact c3OddStep_tunnel 72 49 2 54 37
    (by decide) (by decide) (by decide) (by decide) a
theorem c10_todd_iter_64a43_to_54a37 (a : Nat) :
    c10TOddIter (64 * a + 43) 3 = 54 * a + 37 := by
  simp [c10TOddIter, c10_todd_64a43_step1,
    c10_todd_64a43_step2, c10_todd_64a43_step3]
theorem c10_direct43_mod64_to_descent_alternative (a : Nat) :
    c10ReachesOneOdd (64 * a + 43) ∨
      c10ReachesSmallerOdd (64 * a + 43) :=
  Or.inr
    (c10_endpoint_smaller_to_reaches_smaller
      (64 * a + 43) 3 (54 * a + 37)
      (by omega) (by omega) (by omega)
      (c10_todd_iter_64a43_to_54a37 a))
theorem c10_todd_type11_res1_endpoint (q : Nat) (h : q % 16 = 1) :
    c10TOdd q = 12 * (q / 16) + 1 := by
  rw [c10TOdd_eq_c3OddStep]
  have hform := Nat.mod_add_div q 16
  rw [h] at hform
  conv_lhs =>
    arg 1
    rw [show q = 16 * (q / 16) + 1 by omega]
  exact c3OddStep_tunnel 16 1 2 12 1
    (by decide) (by decide) (by decide) (by decide) (q / 16)
theorem c10_todd_type11_res9_endpoint (q : Nat) (h : q % 16 = 9) :
    c10TOdd q = 12 * (q / 16) + 7 := by
  rw [c10TOdd_eq_c3OddStep]
  have hform := Nat.mod_add_div q 16
  rw [h] at hform
  conv_lhs =>
