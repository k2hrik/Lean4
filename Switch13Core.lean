    have hnonneg : (0 : Rat) <= (1 : Rat) / (2 ^ N) := by positivity
    nlinarith
  exact rat_pow_le_pow_of_nonneg_of_le _ _ n hbase_nonneg hbase_le
theorem l1_dangerous_tuple_mass_truncation_lt_budget (N n : Nat) (hn : 1 <= n) :
