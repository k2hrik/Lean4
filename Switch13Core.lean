  | strictSeven (hQ : c13Qexit c = 7) (hdesc : c13Qexit c < q) : C13Closeout q c
theorem c13_bounded_tail_endpoint_table :
    c13Qexit 1 = 1 ∧ c13Qexit 5 = 3 ∧ c13Qexit 13 = 7 := by
  exact ⟨c13_bounded_tail_exit_1, c13_bounded_tail_exit_5, c13_bounded_tail_exit_13⟩
theorem c13_bounded_tail_endpoint_exact (c : Nat) (hc : C13BoundedTail c) :
    (c = 1 ∧ c13Qexit c = 1) ∨
    (c = 5 ∧ c13Qexit c = 3) ∨
    (c = 13 ∧ c13Qexit c = 7) := by
  cases hc with
  | one =>
      exact Or.inl ⟨rfl, c13_bounded_tail_exit_1⟩
  | five =>
      exact Or.inr (Or.inl ⟨rfl, c13_bounded_tail_exit_5⟩)
  | thirteen =>
      exact Or.inr (Or.inr ⟨rfl, c13_bounded_tail_exit_13⟩)
