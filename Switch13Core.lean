    pairLabel := state.pairLabel }
def c5PiTermStateRealizesTerminalAffineKBool
    (state : C5PiTermState) : Bool :=
  let family := c5TerminalAffineFamilyOfPiTermState state
  let kState := c5KStateOfPiTermState state
  family.qM == 2 ^ family.centeredExponent * 3 ^ 16 &&
  family.tailModulus == 2 ^ family.tailExponent &&
  family.tailResidue < family.tailModulus &&
  (3 * family.qB - 1) % (2 ^ family.centeredExponent) == 0 &&
  kState.centeredC == (3 * family.qB - 1) / (2 ^ family.centeredExponent) &&
  kState.tParity == c5ParityOfExponent family.centeredExponent &&
  kState.centeredC < 3 ^ 17
theorem c5PiTermStateRealizesTerminalAffineK_of_bool
    {state : C5PiTermState}
