  apply Nat.not_even_iff_odd.mp
  intro hEven
  have hmod : twoAdicOddPart n % 2 = 0 := Nat.even_iff.mp hEven
  have h2dvd : Dvd.dvd 2 (twoAdicOddPart n) := Nat.dvd_iff_mod_eq_zero.mpr hmod
  rw [twoAdicOddPart_eq_ordCompl n hn] at h2dvd
  exact (Nat.not_dvd_ordCompl Nat.prime_two hn) h2dvd
theorem twoAdicOddPart_factorization (n : Nat) :
    n = 2 ^ padicValNat 2 n * twoAdicOddPart n := by
  unfold twoAdicOddPart
  rw [Nat.mul_div_cancel' (pow_padicValNat_dvd (p := 2) (n := n))]
def residual_tNext (z : Nat) : Nat :=
  padicValNat 2 (243 * z + 215)
noncomputable def residual_cNext (z : Nat) : Nat :=
  twoAdicOddPart (243 * z + 215)
theorem residual_pullback_core_pos (z : Nat) :
    Ne (243 * z + 215) 0 := by
  omega
theorem residual_pullback_factorization (z : Nat) :
    243 * z + 215 = 2 ^ residual_tNext z * residual_cNext z := by
  unfold residual_tNext residual_cNext
  exact twoAdicOddPart_factorization (243 * z + 215)
theorem residual_pullback_cNext_odd (z : Nat) :
    Odd (residual_cNext z) := by
  unfold residual_cNext
  exact twoAdicOddPart_odd (243 * z + 215) (residual_pullback_core_pos z)
theorem residual_cNext_not_dvd_three (z : Nat) :
    Not (Dvd.dvd 3 (residual_cNext z)) := by
  intro hc
  have hprod : Dvd.dvd 3 (2 ^ residual_tNext z * residual_cNext z) := by
    exact Dvd.dvd.mul_left hc (2 ^ residual_tNext z)
  have hn : Dvd.dvd 3 (243 * z + 215) := by
    rw [residual_pullback_factorization z]
    exact hprod
  have hmod : (243 * z + 215) % 3 = 2 := by omega
  have hmod0 : (243 * z + 215) % 3 = 0 := Nat.dvd_iff_mod_eq_zero.mp hn
  omega
theorem residual_cNext_mod12_cases (z : Nat) :
    Or (residual_cNext z % 12 = 1)
      (Or (residual_cNext z % 12 = 5)
      (Or (residual_cNext z % 12 = 7) (residual_cNext z % 12 = 11))) := by
  have hodd := residual_pullback_cNext_odd z
  have hnot3 := residual_cNext_not_dvd_three z
  cases hodd with
  | intro k hk =>
      have hmod := Nat.mod_add_div (residual_cNext z) 12
      have hnot0 : Not (residual_cNext z % 3 = 0) := by
        intro h0
        have hdiv : Dvd.dvd 3 (residual_cNext z) := Nat.dvd_iff_mod_eq_zero.mpr h0
        exact hnot3 hdiv
      omega
def residual_cNext_trivial_tail (z : Nat) : Prop :=
  residual_cNext z = 1 ∨ residual_cNext z = 5 ∨ residual_cNext z = 13
inductive ResidualIntrinsic11Tag (z : Nat) : Prop where
  | danger
      (hnotTail : Not (residual_cNext_trivial_tail z))
      (hmod : Or (residual_cNext z % 12 = 1) (residual_cNext z % 12 = 5))
  | exitTrivial
      (htail : residual_cNext_trivial_tail z)
  | exitMod
      (hmod : Or (residual_cNext z % 12 = 7) (residual_cNext z % 12 = 11))
theorem residual_intrinsic11_danger_exit_split (z : Nat) :
    ResidualIntrinsic11Tag z := by
  by_cases htail : residual_cNext_trivial_tail z
  · exact ResidualIntrinsic11Tag.exitTrivial htail
  · have hcases := residual_cNext_mod12_cases z
    cases hcases with
    | inl h1 =>
        exact ResidualIntrinsic11Tag.danger htail (Or.inl h1)
    | inr hrest1 =>
        cases hrest1 with
        | inl h5 =>
            exact ResidualIntrinsic11Tag.danger htail (Or.inr h5)
        | inr hrest2 =>
            cases hrest2 with
            | inl h7 =>
                exact ResidualIntrinsic11Tag.exitMod (Or.inl h7)
            | inr h11 =>
                exact ResidualIntrinsic11Tag.exitMod (Or.inr h11)
def residual_joint_layer_target (t s : Nat) : Nat :=
  2 ^ t * (2 ^ s - 1)
theorem residual_joint_layer_residue_exists (t s : Nat) :
    Exists (fun z : Nat =>
      Nat.ModEq (2 ^ (t + s + 1)) (243 * z + 215) (residual_joint_layer_target t s)) := by
  exact residual_affine243_surjective_mod_pow2 (t + s + 1)
    (residual_joint_layer_target t s)
theorem residual_joint_layer_residue_unique (t s z1 z2 : Nat)
    (h1 : Nat.ModEq (2 ^ (t + s + 1)) (243 * z1 + 215) (residual_joint_layer_target t s))
    (h2 : Nat.ModEq (2 ^ (t + s + 1)) (243 * z2 + 215) (residual_joint_layer_target t s)) :
    Nat.ModEq (2 ^ (t + s + 1)) z1 z2 := by
  have h12 : Nat.ModEq (2 ^ (t + s + 1)) (243 * z1 + 215) (243 * z2 + 215) :=
    h1.trans h2.symm
  exact residual_affine243_injective_mod_pow2 (t + s + 1) z1 z2 h12
theorem residual_joint_layer_single_residue_class (t s : Nat) :
    Exists (fun z0 : Nat =>
      Nat.ModEq (2 ^ (t + s + 1)) (243 * z0 + 215) (residual_joint_layer_target t s) ∧
        forall z : Nat,
          Nat.ModEq (2 ^ (t + s + 1)) (243 * z + 215) (residual_joint_layer_target t s) ->
            Nat.ModEq (2 ^ (t + s + 1)) z z0) := by
  match residual_joint_layer_residue_exists t s with
  | Exists.intro z0 hz0 =>
      refine Exists.intro z0 ?_
      constructor
      · exact hz0
      · intro z hz
        exact residual_joint_layer_residue_unique t s z z0 hz hz0
noncomputable def residual_LNext (z : Nat) : Nat :=
  padicValNat 2 (residual_cNext z + 1)
noncomputable def residual_QNext (z : Nat) : Nat :=
  twoAdicOddPart (residual_cNext z + 1)
theorem residual_cNext_succ_pos (z : Nat) :
    Ne (residual_cNext z + 1) 0 := by
  omega
theorem residual_LNext_pos (z : Nat) :
    1 <= residual_LNext z := by
  unfold residual_LNext
  have hEven : Even (residual_cNext z + 1) :=
    Odd.add_one (residual_pullback_cNext_odd z)
  have hmod : (residual_cNext z + 1) % 2 = 0 := Nat.even_iff.mp hEven
  have h2dvd : Dvd.dvd 2 (residual_cNext z + 1) := Nat.dvd_iff_mod_eq_zero.mpr hmod
  exact one_le_padicValNat_of_dvd (residual_cNext_succ_pos z) h2dvd
theorem residual_QNext_factorization (z : Nat) :
    residual_cNext z + 1 = 2 ^ residual_LNext z * residual_QNext z := by
  unfold residual_LNext residual_QNext
  exact twoAdicOddPart_factorization (residual_cNext z + 1)
theorem residual_QNext_odd (z : Nat) :
    Odd (residual_QNext z) := by
  unfold residual_QNext
  exact twoAdicOddPart_odd (residual_cNext z + 1) (residual_cNext_succ_pos z)
def residual_Q4 (z : Nat) : Nat :=
  1296 * z + 1147
noncomputable def residual_QReentry (z : Nat) : Nat :=
  3 ^ (residual_LNext z - 1) * residual_QNext z
theorem residual_Q4_scaled_from_pullback (z : Nat) :
    (3 : Int) * (residual_Q4 z : Int) =
      (2 : Int) ^ (residual_tNext z + 4) * (residual_cNext z : Int) + 1 := by
  have hnat : 3 * residual_Q4 z = 16 * (243 * z + 215) + 1 := by
    unfold residual_Q4
    omega
  have hfac := residual_pullback_factorization z
  have hnat2 : 3 * residual_Q4 z =
      2 ^ (residual_tNext z + 4) * residual_cNext z + 1 := by
    rw [hnat, hfac]
    rw [Nat.pow_add]
    norm_num
    ring
  exact_mod_cast hnat2
theorem residual_QReentry_scaled (z : Nat) :
    3 * residual_QReentry z = 3 ^ residual_LNext z * residual_QNext z := by
  unfold residual_QReentry
  have hs : 1 <= residual_LNext z := residual_LNext_pos z
  have hpow : 3 ^ residual_LNext z = 3 ^ (residual_LNext z - 1) * 3 := by
    nth_rewrite 1 [show residual_LNext z = (residual_LNext z - 1) + 1 by
      omega]
    rw [Nat.pow_succ]
  rw [hpow]
  ring
theorem residual_tail_sign_identity_int (z : Nat) :
    (3 : Int) * ((residual_Q4 z : Int) - (residual_QReentry z : Int)) =
      (residual_QNext z : Int) *
          ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) -
        (2 : Int) ^ (residual_tNext z + 4) + 1 := by
  have hs : 1 <= residual_LNext z := residual_LNext_pos z
  have hQ4 := residual_Q4_scaled_from_pullback z
  have hc_nat := residual_QNext_factorization z
  have hc : (residual_cNext z : Int) + 1 =
      (2 : Int) ^ residual_LNext z * (residual_QNext z : Int) := by
    exact_mod_cast hc_nat
  have h3qr_nat := residual_QReentry_scaled z
  have h3qr : (3 : Int) * (residual_QReentry z : Int) =
      (3 : Int) ^ residual_LNext z * (residual_QNext z : Int) := by
    exact_mod_cast h3qr_nat
  have hc' : (residual_cNext z : Int) =
      (2 : Int) ^ residual_LNext z * (residual_QNext z : Int) - 1 := by
    omega
  calc
    (3 : Int) * ((residual_Q4 z : Int) - (residual_QReentry z : Int)) =
        (3 : Int) * (residual_Q4 z : Int) -
          (3 : Int) * (residual_QReentry z : Int) := by ring
    _ = ((2 : Int) ^ (residual_tNext z + 4) * (residual_cNext z : Int) + 1) -
          ((3 : Int) ^ residual_LNext z * (residual_QNext z : Int)) := by
        rw [hQ4, h3qr]
    _ = ((2 : Int) ^ (residual_tNext z + 4) *
            ((2 : Int) ^ residual_LNext z * (residual_QNext z : Int) - 1) + 1) -
          ((3 : Int) ^ residual_LNext z * (residual_QNext z : Int)) := by
        rw [hc']
    _ = (residual_QNext z : Int) *
          ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) -
        (2 : Int) ^ (residual_tNext z + 4) + 1 := by
        have hpow : (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) =
            (2 : Int) ^ (residual_tNext z + 4) * (2 : Int) ^ residual_LNext z := by
          have hidx : residual_tNext z + residual_LNext z + 4 =
              (residual_tNext z + 4) + residual_LNext z := by omega
          rw [hidx, pow_add]
        rw [hpow]
        ring
theorem residual_QNext_pos (z : Nat) :
    1 <= residual_QNext z := by
  exact Nat.succ_le_of_lt (Odd.pos (residual_QNext_odd z))
theorem residual_tail_growth_of_coeff_negative (z : Nat)
    (hneg : (3 : Int) ^ residual_LNext z >
      (2 : Int) ^ (residual_tNext z + residual_LNext z + 4)) :
    (residual_QReentry z : Int) > (residual_Q4 z : Int) := by
  have hsign := residual_tail_sign_identity_int z
  have hcoeff :
      (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z <= -1 := by
    omega
  have hB : (1 : Int) <= (2 : Int) ^ (residual_tNext z + 4) := by
    exact one_le_pow₀ (by norm_num : (1 : Int) <= 2)
  have hq : (1 : Int) <= (residual_QNext z : Int) := by
    exact_mod_cast residual_QNext_pos z
  have hnegative :
      (residual_QNext z : Int) *
          ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
            (3 : Int) ^ residual_LNext z) -
        (2 : Int) ^ (residual_tNext z + 4) + 1 < 0 := by
    have hmul :
        (residual_QNext z : Int) *
            ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
              (3 : Int) ^ residual_LNext z) <=
          (residual_QNext z : Int) * (-1) := by
      exact mul_le_mul_of_nonneg_left hcoeff (by omega)
    have hqneg : (residual_QNext z : Int) * (-1) <= -1 := by
      nlinarith
    nlinarith
  rw [Eq.symm hsign] at hnegative
  nlinarith
theorem residual_tail_contracting_non_strict_of_coeff_large (z : Nat)
    (hlarge :
      (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z >=
        (2 : Int) ^ (residual_tNext z + 4) - 1) :
    (residual_QReentry z : Int) <= (residual_Q4 z : Int) := by
  have hsign := residual_tail_sign_identity_int z
  have hcoeff_nonneg :
      0 <=
        (2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
          (3 : Int) ^ residual_LNext z := by
    have hB : (1 : Int) <= (2 : Int) ^ (residual_tNext z + 4) := by
      exact one_le_pow₀ (by norm_num : (1 : Int) <= 2)
    nlinarith
  have hq : (1 : Int) <= (residual_QNext z : Int) := by
    exact_mod_cast residual_QNext_pos z
  have hnonneg :
      0 <=
        (residual_QNext z : Int) *
            ((2 : Int) ^ (residual_tNext z + residual_LNext z + 4) -
              (3 : Int) ^ residual_LNext z) -
