  decide
theorem r4r3m0_target_lowbit_table :
    r4r3m0TargetLowBits 3 = 7 ∧
    r4r3m0TargetLowBits 6 = 7 ∧
    r4r3m0TargetLowBits 9 = 7 ∧
    r4r3m0TargetLowBits 12 = 3591 := by
  decide
theorem r4m2_compatible_iff (L : TerminalLetter) :
    matchesR4M2Target L ↔ L = TerminalLetter.r4m2 := by
  cases L <;> simp [matchesR4M2Target, terminalP, terminalK, r4m2TargetLowBits]
theorem r4r3m0_compatible_iff (L : TerminalLetter) :
    matchesR4R3M0Target L ↔ L = TerminalLetter.r4r3m0 := by
  cases L <;> simp [matchesR4R3M0Target, terminalP, terminalK, r4r3m0TargetLowBits]
theorem r4m2_first_letter_forced (L : TerminalLetter)
    (h : matchesR4M2Target L) :
    L = TerminalLetter.r4m2 :=
  (r4m2_compatible_iff L).mp h
theorem r4r3m0_first_letter_forced (L : TerminalLetter)
    (h : matchesR4R3M0Target L) :
    L = TerminalLetter.r4r3m0 :=
  (r4r3m0_compatible_iff L).mp h
def wordK : List TerminalLetter -> Nat
  | [] => 0
  | L :: U => terminalK L + wordK U
def wordP : List TerminalLetter -> Nat
  | [] => 0
  | L :: U => terminalP L + (2 ^ terminalK L) * wordP U
def r4m2TargetEquation (W : List TerminalLetter) : Prop :=
  (63 : Int) * (wordP W : Int) =
    23 * (((2 ^ wordK W : Nat) : Int) - 1)
def r4r3m0TargetEquation (W : List TerminalLetter) : Prop :=
  (73 : Int) * (wordP W : Int) =
    (((2 ^ wordK W : Nat) : Int) - 1)
def r4m2FixedCoordinateEquation (W : List TerminalLetter) : Prop :=
  (23 : Int) * ((2 ^ wordK W : Nat) : Int) =
    (63 : Int) * (wordP W : Int) + 23
def r4r3m0FixedCoordinateEquation (W : List TerminalLetter) : Prop :=
  ((2 ^ wordK W : Nat) : Int) = (73 : Int) * (wordP W : Int) + 1
def r4m2FixedPointNumerator : Int := 23
def r4m2FixedPointDenominator : Int := 63
def r4r3m0FixedPointNumerator : Int := 1
def r4r3m0FixedPointDenominator : Int := 73
def terminalAffineMapFixedPointCondition (W : List TerminalLetter)
    (x_num x_den : Int) : Prop :=
  ((2 ^ wordK W : Nat) : Int) * x_num =
    (wordP W : Int) * x_den + x_num
theorem r4m2_fixed_coordinate_iff_target (W : List TerminalLetter) :
    r4m2FixedCoordinateEquation W ↔ r4m2TargetEquation W := by
  simp [r4m2FixedCoordinateEquation, r4m2TargetEquation]
  omega
theorem r4r3m0_fixed_coordinate_iff_target (W : List TerminalLetter) :
    r4r3m0FixedCoordinateEquation W ↔ r4r3m0TargetEquation W := by
  simp [r4r3m0FixedCoordinateEquation, r4r3m0TargetEquation]
  omega
theorem r4m2_composed_affine_map_fixed_point_iff_fixed_coordinate
    (W : List TerminalLetter) :
    terminalAffineMapFixedPointCondition W r4m2FixedPointNumerator
      r4m2FixedPointDenominator ↔ r4m2FixedCoordinateEquation W := by
  simp [terminalAffineMapFixedPointCondition, r4m2FixedPointNumerator,
    r4m2FixedPointDenominator, r4m2FixedCoordinateEquation]
  omega
theorem r4r3m0_composed_affine_map_fixed_point_iff_fixed_coordinate
    (W : List TerminalLetter) :
    terminalAffineMapFixedPointCondition W r4r3m0FixedPointNumerator
