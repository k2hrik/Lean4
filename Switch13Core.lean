      exact l1_dangerous_contraction q qNext hq h
theorem l1_episode_contraction (q : Nat -> Nat) (hpos : forall i, 1 <= q i) (j : Nat)
    (hstep : forall i, i < j -> L1NonExitStep (q i) (q (i + 1))) :
    4 ^ j * (q j - 1) <= 3 ^ j * (q 0 - 1) := by
  induction j with
  | zero =>
      simp
  | succ j ih =>
      have ih' : 4 ^ j * (q j - 1) <= 3 ^ j * (q 0 - 1) := by
        apply ih
        intro i hi
        exact hstep i (Nat.lt_trans hi (Nat.lt_succ_self j))
      have hloc := l1_nonexit_step_contraction (q j) (q (j + 1)) (hpos j)
        (hstep j (Nat.lt_succ_self j))
      have hloc_mul :
          4 ^ j * (4 * (q (j + 1) - 1)) <= 4 ^ j * (3 * (q j - 1)) :=
        Nat.mul_le_mul_left (4 ^ j) hloc
      have hih_mul : 3 * (4 ^ j * (q j - 1)) <= 3 * (3 ^ j * (q 0 - 1)) :=
        Nat.mul_le_mul_left 3 ih'
      have hmid : 4 ^ j * (3 * (q j - 1)) <= 3 * (3 ^ j * (q 0 - 1)) := by
        nlinarith [hih_mul]
      have hchain := le_trans hloc_mul hmid
      rw [pow_succ, pow_succ]
      nlinarith
