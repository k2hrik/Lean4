  | r5m4r3
  | r4m2
  | r4m6r3
  | r4r3m0
  | r4r3m4r3
  deriving DecidableEq, Repr
def terminalK : TerminalLetter -> Nat
  | TerminalLetter.m2 => 3
  | TerminalLetter.m6r3 => 6
  | TerminalLetter.r5m0 => 6
  | TerminalLetter.r5m4r3 => 9
  | TerminalLetter.r4m2 => 6
  | TerminalLetter.r4m6r3 => 9
  | TerminalLetter.r4r3m0 => 9
  | TerminalLetter.r4r3m4r3 => 12
def terminalP : TerminalLetter -> Nat
  | TerminalLetter.m2 => 2
  | TerminalLetter.m6r3 => 6
  | TerminalLetter.r5m0 => 4
  | TerminalLetter.r5m4r3 => 36
  | TerminalLetter.r4m2 => 23
  | TerminalLetter.r4m6r3 => 55
  | TerminalLetter.r4r3m0 => 7
  | TerminalLetter.r4r3m4r3 => 263
theorem terminal_macro_letter_table :
    terminalK TerminalLetter.m2 = 3 ∧ terminalP TerminalLetter.m2 = 2 ∧
    terminalK TerminalLetter.m6r3 = 6 ∧ terminalP TerminalLetter.m6r3 = 6 ∧
    terminalK TerminalLetter.r5m0 = 6 ∧ terminalP TerminalLetter.r5m0 = 4 ∧
    terminalK TerminalLetter.r5m4r3 = 9 ∧ terminalP TerminalLetter.r5m4r3 = 36 ∧
    terminalK TerminalLetter.r4m2 = 6 ∧ terminalP TerminalLetter.r4m2 = 23 ∧
    terminalK TerminalLetter.r4m6r3 = 9 ∧ terminalP TerminalLetter.r4m6r3 = 55 ∧
    terminalK TerminalLetter.r4r3m0 = 9 ∧ terminalP TerminalLetter.r4r3m0 = 7 ∧
    terminalK TerminalLetter.r4r3m4r3 = 12 ∧
    terminalP TerminalLetter.r4r3m4r3 = 263 := by
  decide
def r4m2TargetLowBits : Nat -> Nat
  | 3 => 7
  | 6 => 23
  | 9 => 471
  | 12 => 1495
  | _ => 0
def r4r3m0TargetLowBits : Nat -> Nat
  | 3 => 7
  | 6 => 7
  | 9 => 7
  | 12 => 3591
  | _ => 0
def matchesR4M2Target (L : TerminalLetter) : Prop :=
  terminalP L = r4m2TargetLowBits (terminalK L)
def matchesR4R3M0Target (L : TerminalLetter) : Prop :=
  terminalP L = r4r3m0TargetLowBits (terminalK L)
theorem r4m2_target_lowbit_table :
    r4m2TargetLowBits 3 = 7 ∧
    r4m2TargetLowBits 6 = 23 ∧
    r4m2TargetLowBits 9 = 471 ∧
