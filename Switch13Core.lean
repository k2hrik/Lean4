theorem rat_pow_le_pow_of_nonneg_of_le (a b : Rat) (n : Nat)
    (ha : 0 <= a) (hab : a <= b) :
    a ^ n <= b ^ n := by
  induction n with
  | zero =>
      norm_num
  | succ n ih =>
      rw [pow_succ, pow_succ]
      have hb : 0 <= b := le_trans ha hab
      exact mul_le_mul ih hab ha (pow_nonneg hb n)
theorem rat_pow_lt_pow_of_nonneg_of_lt (a b : Rat) (n : Nat)
    (hn : 1 <= n) (ha : 0 <= a) (hab : a < b) :
    a ^ n < b ^ n := by
  cases Nat.exists_eq_add_of_le hn with
  | intro k hk =>
      rw [hk]
      rw [pow_add, pow_add]
      rw [pow_one, pow_one]
      have hpow_le : a ^ k <= b ^ k := rat_pow_le_pow_of_nonneg_of_le a b k ha hab.le
      have hb_pos : 0 < b := lt_of_le_of_lt ha hab
      exact mul_lt_mul_of_lt_of_le_of_nonneg_of_pos hab hpow_le ha (pow_pos hb_pos k)
