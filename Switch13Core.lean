def C5AffineFamilyCenteredAt
    (family : C5TerminalAffineFamily) (kState : C5KState) : Prop :=
  2 ^ family.centeredExponent ∣ 3 * family.qB - 1 ∧
  kState.centeredC = (3 * family.qB - 1) / (2 ^ family.centeredExponent)
def C5PiTermStateRealizesTerminalAffineK
    (state : C5PiTermState)
    (family : C5TerminalAffineFamily)
    (kState : C5KState) : Prop :=
  family.qM = 2 ^ family.centeredExponent * 3 ^ 16 ∧
  family.qB = state.centeredB ∧
  family.centeredExponent = state.centeredExponent ∧
  family.tailModulus = state.cylinderModulus ∧
  family.tailExponent = state.cylinderExponent ∧
  family.tailResidue = state.cylinderResidue ∧
  family.terminalSteps = state.terminalSteps ∧
  family.tailModulus = 2 ^ family.tailExponent ∧
  family.tailResidue < family.tailModulus ∧
  kState.centeredC = state.centeredC ∧
  kState.tParity = state.tParity ∧
  kState.tParity = c5ParityOfExponent family.centeredExponent ∧
  kState.pairLabel = state.pairLabel ∧
  C5AffineFamilyCenteredAt family kState ∧
  kState.centeredC < 3 ^ 17
def c5TerminalAffineFamilyOfPiTermState
    (state : C5PiTermState) : C5TerminalAffineFamily :=
  { qM := 2 ^ state.centeredExponent * 3 ^ 16
    qB := state.centeredB
    centeredExponent := state.centeredExponent
    tailModulus := state.cylinderModulus
    tailExponent := state.cylinderExponent
    tailResidue := state.cylinderResidue
    terminalSteps := state.terminalSteps }
def c5KStateOfPiTermState (state : C5PiTermState) : C5KState :=
  { centeredC := state.centeredC
