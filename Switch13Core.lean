      c13Qexit 13 <= (3 * q + 1) / 8 -> C13Closeout q 13) := by
  constructor
  · intro q hq hbound
    exact c13_row_specific_closeout q 1 C13BoundedTail.one hq hbound
  · constructor
    · intro q hq hbound
      exact c13_row_specific_closeout q 5 C13BoundedTail.five hq hbound
    · intro q hq hbound
