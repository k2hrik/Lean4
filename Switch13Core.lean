    (hstep : L1NonExitStep q qNext) :
    4 * (qNext - 1) <= 3 * (q - 1) := by
  cases hstep with
  | type11 h =>
      exact le_of_eq (l1_type11_contraction q qNext hq h)
  | type21 h =>
      exact l1_type21_contraction q qNext hq h
