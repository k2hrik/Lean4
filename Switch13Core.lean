import Mathlib
import Mathlib.RingTheory.ZMod.UnitsCyclic
/-
  Switch13Core.lean

  Standalone Lean artifact, part 1 of 3.

  This file collects the basic arithmetic definitions, finite tables, and
  checked helper theorems used by the public switch statement.  It imports
  Mathlib only; the remaining project code needed by later files is included
  directly below.
-/
open scoped BigOperators
def c3V2 : Nat -> Nat
  | 0 => 0
  | n + 1 => if (n + 1) % 2 = 0 then 1 + c3V2 ((n + 1) / 2) else 0
def c3OddStep (n : Nat) : Nat :=
  (3 * n + 1) / 2 ^ c3V2 (3 * n + 1)
theorem c3_v2_dvd : (n : Nat) -> 0 < n -> 2 ^ c3V2 n ∣ n
  | 0, h => absurd h (by omega)
  | m + 1, _ => by
      unfold c3V2
      split
      · next he =>
          have hpos : 0 < (m + 1) / 2 := by omega
          have ih := c3_v2_dvd ((m + 1) / 2) hpos
          have hexp : 1 + c3V2 ((m + 1) / 2) = c3V2 ((m + 1) / 2) + 1 := by
            omega
          rw [hexp, Nat.pow_succ]
          have hmd : m + 1 = 2 * ((m + 1) / 2) := by omega
          obtain ⟨c, hc⟩ := ih
          revert hc hmd
          generalize 2 ^ c3V2 ((m + 1) / 2) = e
          intro hmd hc
          refine ⟨c, ?_⟩
          rw [hmd, hc]
          ac_rfl
      · next _he =>
          rw [Nat.pow_zero]
          exact Nat.one_dvd _
  termination_by n _ => n
  decreasing_by omega
theorem c3_v2_quot_odd : (n : Nat) -> 0 < n -> (n / 2 ^ c3V2 n) % 2 = 1
  | 0, h => absurd h (by omega)
  | m + 1, _ => by
      unfold c3V2
      split
      · next _he =>
          have hpos : 0 < (m + 1) / 2 := by omega
          have ih := c3_v2_quot_odd ((m + 1) / 2) hpos
          have hexp : 1 + c3V2 ((m + 1) / 2) = c3V2 ((m + 1) / 2) + 1 := by
            omega
          rw [hexp, Nat.pow_succ]
          have hmd : m + 1 = 2 * ((m + 1) / 2) := by omega
          revert ih hmd
          generalize 2 ^ c3V2 ((m + 1) / 2) = e
          intro ih hmd
          rw [hmd, Nat.mul_comm e 2, ← Nat.div_div_eq_div_mul,
            Nat.mul_div_cancel_left _ (by omega : 0 < 2)]
          exact ih
      · next _he =>
          rw [Nat.pow_zero, Nat.div_one]
          omega
  termination_by n _ => n
  decreasing_by omega
theorem c3_v2_not_dvd_succ (n : Nat) (hpos : 0 < n) :
    ¬ 2 ^ (c3V2 n + 1) ∣ n := by
  intro hdvd
  have hodd := c3_v2_quot_odd n hpos
  obtain ⟨q, hq⟩ := c3_v2_dvd n hpos
  have hpp : 0 < 2 ^ c3V2 n := Nat.pow_pos (by omega)
  have hqval : n / 2 ^ c3V2 n = q := by
    have h1 : 2 ^ c3V2 n * q / 2 ^ c3V2 n = q :=
      Nat.mul_div_cancel_left q hpp
    rw [← h1]
    exact congrArg (· / 2 ^ c3V2 n) hq
  rw [hqval] at hodd
  obtain ⟨c, hc⟩ := hdvd
  have key : 2 ^ c3V2 n * q = 2 ^ c3V2 n * (2 * c) := by
    have e : 2 ^ c3V2 n * q = 2 ^ (c3V2 n + 1) * c := by
      rw [← hq, ← hc]
    rw [e, Nat.pow_succ, Nat.mul_assoc]
  have hq2 : q = 2 * c := Nat.eq_of_mul_eq_mul_left hpp key
  omega
theorem c3_v2_eq_of (n h : Nat) (hpos : 0 < n)
    (hd : 2 ^ h ∣ n) (hnd : ¬ 2 ^ (h + 1) ∣ n) :
    c3V2 n = h := by
  rcases Nat.lt_trichotomy (c3V2 n) h with hlt | heq | hgt
  · exfalso
    exact c3_v2_not_dvd_succ n hpos
      (Nat.dvd_trans (Nat.pow_dvd_pow 2 (by omega : c3V2 n + 1 <= h)) hd)
  · exact heq
  · exfalso
    exact hnd
      (Nat.dvd_trans (Nat.pow_dvd_pow 2 (by omega : h + 1 <= c3V2 n))
        (c3_v2_dvd n hpos))
theorem c3OddStep_tunnel (nm nb h am ab : Nat)
    (hae : am % 2 = 0) (hbo : ab % 2 = 1)
    (hm : 3 * nm = 2 ^ h * am)
    (hb : 3 * nb + 1 = 2 ^ h * ab) (u : Nat) :
    c3OddStep (nm * u + nb) = am * u + ab := by
  have hpp : 0 < 2 ^ h := Nat.pow_pos (by omega)
  have hcof_odd : (am * u + ab) % 2 = 1 := by
    have ham2 : am * u = 2 * ((am / 2) * u) := by
      have hh : am = 2 * (am / 2) := by omega
      calc
        am * u = (2 * (am / 2)) * u := by rw [← hh]
        _ = 2 * ((am / 2) * u) := by rw [Nat.mul_assoc]
    omega
  have hpos : 0 < am * u + ab := by omega
  have heq : 3 * (nm * u + nb) + 1 = 2 ^ h * (am * u + ab) := by
    have e1 : 3 * (nm * u + nb) + 1 = (3 * nm) * u + (3 * nb + 1) := by
      rw [Nat.mul_add, ← Nat.mul_assoc]
      omega
    rw [e1, hm, hb, Nat.mul_add, Nat.mul_assoc]
  have hv : c3V2 (2 ^ h * (am * u + ab)) = h := by
    refine c3_v2_eq_of _ h (Nat.mul_pos hpp hpos) ⟨am * u + ab, rfl⟩ ?_
    intro hdvd
    obtain ⟨c, hc⟩ := hdvd
    have key : 2 ^ h * (am * u + ab) = 2 ^ h * (2 * c) := by
      rw [hc, Nat.pow_succ, Nat.mul_assoc]
    have hev : am * u + ab = 2 * c := Nat.eq_of_mul_eq_mul_left hpp key
    omega
  unfold c3OddStep
  rw [heq, hv, Nat.mul_div_cancel_left _ hpp]
theorem c3_v2_sum_min (a b : Nat) (ha : 0 < a) (hb : 0 < b)
    (hlt : c3V2 a < c3V2 b) :
    c3V2 (a + b) = c3V2 a := by
  apply c3_v2_eq_of (a + b) (c3V2 a) (by omega)
  · exact Nat.dvd_add (c3_v2_dvd a ha)
      (Nat.dvd_trans (Nat.pow_dvd_pow 2 (Nat.le_of_lt hlt)) (c3_v2_dvd b hb))
  · intro hdab
    have hdb : 2 ^ (c3V2 a + 1) ∣ b :=
      Nat.dvd_trans (Nat.pow_dvd_pow 2 (by omega : c3V2 a + 1 <= c3V2 b))
        (c3_v2_dvd b hb)
    have hda : 2 ^ (c3V2 a + 1) ∣ a := by
      obtain ⟨c1, hc1⟩ := hdab
      obtain ⟨c2, hc2⟩ := hdb
      refine ⟨c1 - c2, ?_⟩
      have hdist : 2 ^ (c3V2 a + 1) * (c1 - c2)
          = 2 ^ (c3V2 a + 1) * c1 - 2 ^ (c3V2 a + 1) * c2 := by
        rw [Nat.mul_comm (2 ^ (c3V2 a + 1)) (c1 - c2), Nat.sub_mul,
          Nat.mul_comm c1, Nat.mul_comm c2]
      rw [hdist]
      omega
    exact c3_v2_not_dvd_succ a ha hda
theorem c3_v2_add_high_left (a b : Nat) (ha : 0 < a) (hb : 0 < b)
    (hlt : c3V2 b < c3V2 a) :
    c3V2 (a + b) = c3V2 b := by
  rw [Nat.add_comm]
  exact c3_v2_sum_min b a hb ha hlt
theorem c3_pow_dvd_le_v2 (k m : Nat) (hm : 0 < m) (hd : 2 ^ k ∣ m) :
    k <= c3V2 m := by
  rcases Nat.lt_or_ge (c3V2 m) k with h | h
  · exact absurd
      (Nat.dvd_trans (Nat.pow_dvd_pow 2 (show c3V2 m + 1 <= k by omega)) hd)
      (c3_v2_not_dvd_succ m hm)
  · exact h
theorem c3_v2_le_mul (a u : Nat) (ha : 0 < a) (hu : 0 < u) :
    c3V2 a <= c3V2 (a * u) :=
  c3_pow_dvd_le_v2 (c3V2 a) (a * u) (Nat.mul_pos ha hu)
    (Nat.dvd_trans (c3_v2_dvd a ha) (Nat.dvd_mul_right a u))
theorem c3_v2_affine_uniform (am bb u : Nat) (ham : 0 < am) (hbb : 0 < bb)
    (huni : c3V2 bb < c3V2 am) :
    c3V2 (am * u + bb) = c3V2 bb := by
  rcases Nat.eq_zero_or_pos u with hu | hu
  · subst hu
    rw [Nat.mul_zero, Nat.zero_add]
  · exact c3_v2_add_high_left (am * u) bb (Nat.mul_pos ham hu) hbb
      (Nat.lt_of_lt_of_le huni (c3_v2_le_mul am u ham hu))
theorem c3_affine_div (a b d u : Nat) (hd : 0 < d) (hda : d ∣ a) (hdb : d ∣ b) :
    (a * u + b) / d = (a / d) * u + b / d := by
  obtain ⟨a', rfl⟩ := hda
  obtain ⟨b', rfl⟩ := hdb
  rw [Nat.mul_div_cancel_left a' hd, Nat.mul_div_cancel_left b' hd]
  have h : d * a' * u + d * b' = d * (a' * u + b') := by
    rw [Nat.mul_assoc, ← Nat.mul_add]
  rw [h, Nat.mul_div_cancel_left (a' * u + b') hd]
theorem c3_raw_affine (qm qb u : Nat) (hqb : 1 <= qb) :
    3 * (qm * u + qb) - 1 = (3 * qm) * u + (3 * qb - 1) := by
  have h : (3 * qm) * u = 3 * (qm * u) := by rw [Nat.mul_assoc]
  rw [h]
  omega
def c3TwoStep (raw : Nat) : Nat :=
  (raw / 2 ^ c3V2 raw + 1) / 2 ^ c3V2 (raw / 2 ^ c3V2 raw + 1)
def c3TermStep (q : Nat) : Nat :=
  c3TwoStep (3 * q - 1)
theorem c3TwoStep_affine (am bb u : Nat) (ham : 0 < am) (hbb : 0 < bb)
    (h1 : c3V2 bb < c3V2 am)
    (h2 : c3V2 (bb / 2 ^ c3V2 bb + 1) < c3V2 (am / 2 ^ c3V2 bb)) :
    c3TwoStep (am * u + bb)
      = (am / 2 ^ c3V2 bb / 2 ^ c3V2 (bb / 2 ^ c3V2 bb + 1)) * u
        + (bb / 2 ^ c3V2 bb + 1) / 2 ^ c3V2 (bb / 2 ^ c3V2 bb + 1) := by
  have hdb : (2 : Nat) ^ c3V2 bb ∣ bb := c3_v2_dvd bb hbb
  have hdam : (2 : Nat) ^ c3V2 bb ∣ am :=
    Nat.dvd_trans (Nat.pow_dvd_pow 2 (Nat.le_of_lt h1)) (c3_v2_dvd am ham)
  have hval : c3V2 (am * u + bb) = c3V2 bb :=
    c3_v2_affine_uniform am bb u ham hbb h1
  have hM : (am * u + bb) / 2 ^ c3V2 (am * u + bb)
      = (am / 2 ^ c3V2 bb) * u + bb / 2 ^ c3V2 bb := by
    rw [hval]
    exact c3_affine_div am bb (2 ^ c3V2 bb) u (Nat.pow_pos (by omega)) hdam hdb
  have hmnm : 0 < am / 2 ^ c3V2 bb :=
    Nat.div_pos (Nat.le_of_dvd ham hdam) (Nat.pow_pos (by omega))
  unfold c3TwoStep
  rw [hM, Nat.add_assoc]
  have hval2 : c3V2 ((am / 2 ^ c3V2 bb) * u + (bb / 2 ^ c3V2 bb + 1))
      = c3V2 (bb / 2 ^ c3V2 bb + 1) :=
    c3_v2_affine_uniform (am / 2 ^ c3V2 bb) (bb / 2 ^ c3V2 bb + 1) u
      hmnm (Nat.succ_pos _) h2
  rw [hval2]
  have hd2m : (2 : Nat) ^ c3V2 (bb / 2 ^ c3V2 bb + 1) ∣ (am / 2 ^ c3V2 bb) :=
    Nat.dvd_trans (Nat.pow_dvd_pow 2 (Nat.le_of_lt h2)) (c3_v2_dvd _ hmnm)
  have hd2b : (2 : Nat) ^ c3V2 (bb / 2 ^ c3V2 bb + 1)
      ∣ (bb / 2 ^ c3V2 bb + 1) :=
    c3_v2_dvd _ (Nat.succ_pos _)
  exact c3_affine_div (am / 2 ^ c3V2 bb) (bb / 2 ^ c3V2 bb + 1)
    (2 ^ c3V2 (bb / 2 ^ c3V2 bb + 1)) u (Nat.pow_pos (by omega)) hd2m hd2b
theorem c3TermStep_family (qm qb u : Nat) (hqm : 0 < qm) (hqb : 1 <= qb)
    (h1 : c3V2 (3 * qb - 1) < c3V2 (3 * qm))
    (h2 : c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1)
            < c3V2 ((3 * qm) / 2 ^ c3V2 (3 * qb - 1))) :
    c3TermStep (qm * u + qb)
      = ((3 * qm) / 2 ^ c3V2 (3 * qb - 1)
          / 2 ^ c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1)) * u
        + ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1)
          / 2 ^ c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1) := by
  unfold c3TermStep
  rw [c3_raw_affine qm qb u hqb]
  exact c3TwoStep_affine (3 * qm) (3 * qb - 1) u (by omega) (by omega) h1 h2
theorem c3TermStep_land (qm qb a b : Nat) (hqm : 0 < qm) (hqb : 1 <= qb)
    (h1 : c3V2 (3 * qb - 1) < c3V2 (3 * qm))
    (h2 : c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1)
            < c3V2 ((3 * qm) / 2 ^ c3V2 (3 * qb - 1)))
    (ha : (3 * qm) / 2 ^ c3V2 (3 * qb - 1)
            / 2 ^ c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1) = a)
    (hb : ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1)
            / 2 ^ c3V2 ((3 * qb - 1) / 2 ^ c3V2 (3 * qb - 1) + 1) = b)
    (n : Nat) :
    c3TermStep (qm * n + qb) = a * n + b := by
  rw [c3TermStep_family qm qb n hqm hqb h1 h2, ha, hb]
def c3OddPart (n : Nat) : Nat :=
  n / 2 ^ c3V2 n
structure C3ExactBreakData (q r cNext L Q : Nat) : Prop where
  raw_factor : 3 * q - 1 = 2 ^ r * cNext
  cNext_odd : cNext % 2 = 1
  next_factor : cNext + 1 = 2 ^ L * Q
  Q_odd : Q % 2 = 1
  termStep_eq : c3TermStep q = Q
structure C3ResidualBreakData (q r cNext L0 tail : Nat) : Prop where
  raw_factor : 3 * q - 1 = 2 ^ r * cNext
  cNext_odd : cNext % 2 = 1
  next_factor : cNext + 1 = 2 ^ L0 * tail
  L_formula : c3V2 (cNext + 1) = L0 + c3V2 tail
  termStep_eq : c3TermStep q = c3OddPart tail
theorem c3_v2_two_mul_core (x : Nat) (hx : 0 < x) :
    c3V2 (2 * x) = c3V2 x + 1 := by
  refine c3_v2_eq_of (2 * x) (c3V2 x + 1) (by omega) ?_ ?_
  · have hd : 2 ^ c3V2 x ∣ x := c3_v2_dvd x hx
    have hmd : 2 * 2 ^ c3V2 x ∣ 2 * x := Nat.mul_dvd_mul_left 2 hd
    have heq : 2 * 2 ^ c3V2 x = 2 ^ (c3V2 x + 1) := by
      rw [Nat.pow_succ]
      ac_rfl
    rwa [heq] at hmd
  · intro hdvd
    obtain ⟨c, hc⟩ := hdvd
    apply c3_v2_not_dvd_succ x hx
    refine ⟨c, ?_⟩
    have hexp : c3V2 x + 2 = (c3V2 x + 1) + 1 := by omega
    have hh : (2 : Nat) * x = 2 * (2 ^ (c3V2 x + 1) * c) := by
      rw [hc, hexp, Nat.pow_succ]
      ac_rfl
    omega
theorem c3_v2_pow_two_mul (k x : Nat) (hx : 0 < x) :
    c3V2 (2 ^ k * x) = k + c3V2 x := by
  induction k with
  | zero =>
      simp
  | succ k ih =>
      rw [Nat.pow_succ]
      rw [show (2 ^ k * 2) * x = 2 * (2 ^ k * x) by ac_rfl]
      rw [c3_v2_two_mul_core (2 ^ k * x) (Nat.mul_pos (Nat.pow_pos (by omega)) hx), ih]
      omega
theorem c3_v2_power_times_odd (r c : Nat) (hcpos : 0 < c) (hcodd : c % 2 = 1) :
    c3V2 (2 ^ r * c) = r := by
  have hpp : 0 < 2 ^ r := Nat.pow_pos (by omega)
  refine c3_v2_eq_of _ r (Nat.mul_pos hpp hcpos) ⟨c, rfl⟩ ?_
  intro hdvd
  obtain ⟨d, hd⟩ := hdvd
  have key : 2 ^ r * c = 2 ^ r * (2 * d) := by
    rw [hd, Nat.pow_succ, Nat.mul_assoc]
  have hc : c = 2 * d := Nat.eq_of_mul_eq_mul_left hpp key
  omega
theorem c3_residual_break_data_of
    (q r cNext L0 tail : Nat)
    (hraw : 3 * q - 1 = 2 ^ r * cNext)
    (hcodd : cNext % 2 = 1)
    (hnext : cNext + 1 = 2 ^ L0 * tail)
    (htail : 0 < tail) :
    C3ResidualBreakData q r cNext L0 tail := by
  have hcpos : 0 < cNext := by omega
  have hvraw : c3V2 (3 * q - 1) = r := by
    rw [hraw]
    exact c3_v2_power_times_odd r cNext hcpos hcodd
  have hvnext : c3V2 (cNext + 1) = L0 + c3V2 tail := by
    rw [hnext]
    exact c3_v2_pow_two_mul L0 tail htail
  refine ⟨hraw, hcodd, hnext, hvnext, ?_⟩
  unfold c3TermStep c3TwoStep c3OddPart
  rw [hvraw, hraw, Nat.mul_div_cancel_left _ (Nat.pow_pos (by omega))]
  rw [hvnext, hnext, Nat.pow_add]
  rw [← Nat.div_div_eq_div_mul, Nat.mul_div_cancel_left _ (Nat.pow_pos (by omega))]
theorem c3_v2_two_mul (x : Nat) (hx : 0 < x) :
    c3V2 (2 * x) = c3V2 x + 1 := by
  refine c3_v2_eq_of (2 * x) (c3V2 x + 1) (by omega) ?_ ?_
  · have hd : 2 ^ c3V2 x ∣ x := c3_v2_dvd x hx
    have hmd : 2 * 2 ^ c3V2 x ∣ 2 * x := Nat.mul_dvd_mul_left 2 hd
    have heq : 2 * 2 ^ c3V2 x = 2 ^ (c3V2 x + 1) := by
      rw [Nat.pow_succ]
      ac_rfl
    rwa [heq] at hmd
  · intro hdvd
    obtain ⟨c, hc⟩ := hdvd
    apply c3_v2_not_dvd_succ x hx
    refine ⟨c, ?_⟩
    have hexp : c3V2 x + 2 = (c3V2 x + 1) + 1 := by omega
    have hh : (2 : Nat) * x = 2 * (2 ^ (c3V2 x + 1) * c) := by
      rw [hc, hexp, Nat.pow_succ]
      ac_rfl
    omega
theorem c3_v2_three_mul (x : Nat) (hx : 0 < x) :
    c3V2 (3 * x) = c3V2 x := by
  refine c3_v2_eq_of (3 * x) (c3V2 x) (by omega) ?_ ?_
  · exact Nat.dvd_trans (c3_v2_dvd x hx) (Nat.dvd_mul_left x 3)
  · intro hdvd
    obtain ⟨c, hc⟩ := hdvd
    obtain ⟨d, hd⟩ := c3_v2_dvd x hx
    have hpp : 0 < 2 ^ c3V2 x := Nat.pow_pos (by omega)
    have hdq : x / 2 ^ c3V2 x = d := by
      have hmd := Nat.mul_div_cancel_left d hpp
      rw [← hd] at hmd
      exact hmd
    have hodd := c3_v2_quot_odd x hx
    rw [hdq] at hodd
    have hsub : 3 * (2 ^ c3V2 x * d) = 2 ^ (c3V2 x + 1) * c := by
      rw [← hd]
      exact hc
    have key : 2 ^ c3V2 x * (3 * d) = 2 ^ c3V2 x * (2 * c) := by
      have e1 : 2 ^ c3V2 x * (3 * d) = 3 * (2 ^ c3V2 x * d) := by ac_rfl
      have e2 : 2 ^ c3V2 x * (2 * c) = 2 ^ (c3V2 x + 1) * c := by
        rw [Nat.pow_succ]
        ac_rfl
      rw [e1, e2]
      exact hsub
    have h3d : 3 * d = 2 * c := Nat.eq_of_mul_eq_mul_left hpp key
    omega
theorem c3_gap_first_step (q : Nat) :
    c3OddStep (16 * q + 13) = 6 * q + 5 :=
  c3OddStep_tunnel 16 13 3 6 5
    (by decide) (by decide) (by decide) (by decide) q
theorem c3_gap_L_eq (q : Nat) :
    c3V2 (c3OddStep (16 * q + 13) + 1) = 1 + c3V2 (q + 1) := by
  rw [c3_gap_first_step]
  have h6 : 6 * q + 5 + 1 = 2 * (3 * (q + 1)) := by omega
  rw [h6, c3_v2_two_mul (3 * (q + 1)) (by omega),
    c3_v2_three_mul (q + 1) (by omega)]
  omega
theorem c3_gap_pos_small (L : Nat) (hL1 : 1 <= L) (hL : L <= 3) :
    3 ^ L < 2 ^ (L + 2) := by
  rcases L with _ | _ | _ | _ | L
  · omega
  · decide
  · decide
  · decide
  · omega
theorem c3_gap_neg_large (L : Nat) (hL : 4 <= L) :
    2 ^ (L + 2) < 3 ^ L := by
  have aux : ∀ M, 2 ^ (M + 6) < 3 ^ (M + 4) := by
    intro M
    induction M with
    | zero => decide
    | succ K ih =>
        have hk1 : K + 1 + 6 = (K + 6) + 1 := by omega
        have e1 : 2 ^ (K + 1 + 6) = 2 ^ (K + 6) * 2 := by
          rw [hk1, Nat.pow_succ]
        have hk2 : K + 1 + 4 = (K + 4) + 1 := by omega
        have e2 : 3 ^ (K + 1 + 4) = 3 ^ (K + 4) * 3 := by
          rw [hk2, Nat.pow_succ]
        have hpos : 0 < 3 ^ (K + 4) := Nat.pow_pos (by omega)
        omega
  have key := aux (L - 4)
  have e3 : (L - 4) + 6 = L + 2 := by omega
  have e4 : (L - 4) + 4 = L := by omega
  rw [e3, e4] at key
  exact key
theorem c3_gap_sign_dichotomy (q : Nat) :
    (c3V2 (q + 1) <= 2 →
      3 ^ (1 + c3V2 (q + 1)) < 2 ^ (1 + c3V2 (q + 1) + 2)) ∧
    (3 <= c3V2 (q + 1) →
      2 ^ (1 + c3V2 (q + 1) + 2) < 3 ^ (1 + c3V2 (q + 1))) := by
  refine ⟨fun h => ?_, fun h => ?_⟩
  · exact c3_gap_pos_small (1 + c3V2 (q + 1)) (by omega) (by omega)
