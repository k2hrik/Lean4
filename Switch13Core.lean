      simpa [l1PatternDepth, l1PatternResidue] using odd_modEq_two_one (q 0) hoddTerminal
  | cons a rest ih =>
      let qtail : Nat -> Nat := fun i => q (i + 1)
      have htail : Nat.ModEq (2 ^ l1PatternDepth rest) (qtail 0) (l1PatternResidue rest) := by
        have hposTail : forall i, 1 <= qtail i := by
          intro i
          exact hpos (i + 1)
        have hoddTail : Odd (qtail rest.length) := by
          simpa [qtail] using hoddTerminal
        have hstepTail : forall i b, rest[i]? = some b ->
            3 * qtail i = 1 + 2 ^ b * (2 * qtail (i + 1) - 1) := by
          intro i b hb
          simpa [qtail] using hstep (i + 1) b (by simpa using hb)
        exact ih qtail hposTail hoddTail hstepTail
      have hhead : 3 * q 0 = 1 + 2 ^ a * (2 * q 1 - 1) := by
        exact hstep 0 a (by simp)
      have hheadResidue :
          Nat.ModEq (2 ^ (a + l1PatternDepth rest + 1)) (q 0)
            (l1OneStepPullbackPositiveResidue a (l1PatternDepth rest) (l1PatternResidue rest)) := by
        exact (l1_one_step_pullback_positive_residue a (l1PatternDepth rest)
          (l1PatternResidue rest) (q 0)).mp
          (l1_exact_step_to_pullback_target a (l1PatternDepth rest) (l1PatternResidue rest)
            (q 0) (q 1) (l1PatternResidue_pos rest) (hpos 1) hhead htail)
      simpa [l1PatternDepth, l1PatternResidue, qtail] using hheadResidue
theorem l1_finite_depth_pattern_pullback_forward_C1
    (ds : List Nat) (q : Nat -> Nat)
    (hpos : forall i, 1 <= q i)
    (hoddTerminal : Odd (q ds.length))
    (hstep : forall i a, ds[i]? = some a ->
      3 * q i = 1 + 2 ^ a * (2 * q (i + 1) - 1)) :
    Nat.ModEq (2 ^ (ds.sum + ds.length + 1)) (q 0) (l1PatternResidue ds) := by
  have h := l1_finite_depth_pattern_pullback_forward ds q hpos hoddTerminal hstep
  simpa [l1PatternDepth_eq_sum_length ds] using h
theorem mul_pred_lt_mul (A B : Nat) (hA : 2 <= A) (hB : 1 <= B) :
    1 + A * (B - 1) < A * B := by
  have hlt : 1 + A * (B - 1) < A + A * (B - 1) := by
    exact Nat.add_lt_add_right (by omega : 1 < A) (A * (B - 1))
  have hprod : A * B = A * (B - 1) + A := by
    cases Nat.exists_eq_add_of_le hB with
    | intro k hk =>
        rw [hk]
        simp
        ring
  omega
theorem l1PullbackTarget_lt_modulus (a t c : Nat)
    (ha : 1 <= a) (hc : 1 <= c) (hcb : c <= 2 ^ t) :
    l1PullbackTarget a c < 2 ^ (a + t + 1) := by
  have hA : 2 <= 2 ^ a := by
    cases Nat.exists_eq_add_of_le ha with
    | intro k hk =>
        rw [hk, show 1 + k = k + 1 by omega, pow_succ]
        have hk1 : 1 <= 2 ^ k := Nat.one_le_pow k 2 (by norm_num : 0 < 2)
        nlinarith
  have hBpos : 1 <= 2 ^ (t + 1) := Nat.one_le_pow (t + 1) 2 (by norm_num : 0 < 2)
  have h2c_pred : 2 * c - 1 <= 2 ^ (t + 1) - 1 := by
    have h2c : 2 * c <= 2 * 2 ^ t := Nat.mul_le_mul_left 2 hcb
    have hpow : 2 * 2 ^ t = 2 ^ (t + 1) := by rw [pow_succ']
    omega
  have hmain : l1PullbackTarget a c <= 1 + 2 ^ a * (2 ^ (t + 1) - 1) := by
    unfold l1PullbackTarget
    exact Nat.add_le_add_left (Nat.mul_le_mul_left (2 ^ a) h2c_pred) 1
  have hcap : 1 + 2 ^ a * (2 ^ (t + 1) - 1) < 2 ^ a * 2 ^ (t + 1) :=
    mul_pred_lt_mul (2 ^ a) (2 ^ (t + 1)) hA hBpos
  have hpowfinal : 2 ^ a * 2 ^ (t + 1) = 2 ^ (a + t + 1) := by
    have hidx : a + (t + 1) = a + t + 1 := by omega
    rw [Eq.symm (Nat.pow_add 2 a (t + 1)), hidx]
  rw [Eq.symm hpowfinal]
  exact lt_of_le_of_lt hmain hcap
theorem l1_reverse_step_algebra (a t c e : Nat) (hc : 1 <= c) :
    1 + 2 ^ a * (2 * c - 1) + (2 ^ a * (2 * 2 ^ t)) * e =
      1 + 2 ^ a * (2 * (c + 2 ^ t * e) - 1) := by
  have hleft : 2 * (c + 2 ^ t * e) - 1 = (2 * c - 1) + (2 * 2 ^ t) * e := by
    rw [Nat.mul_add]
    rw [show 2 * (2 ^ t * e) = (2 * 2 ^ t) * e by ring]
    omega
  rw [hleft]
  ring
theorem l1_pullback_target_to_exact_step
    (a t c q : Nat) (ha : 1 <= a) (hc : 1 <= c) (hcb : c <= 2 ^ t)
    (htarget : Nat.ModEq (2 ^ (a + t + 1)) (3 * q) (l1PullbackTarget a c)) :
    Exists (fun qNext : Nat =>
      And (1 <= qNext)
        (And (3 * q = 1 + 2 ^ a * (2 * qNext - 1))
          (Nat.ModEq (2 ^ t) qNext c))) := by
  let e : Nat := (3 * q) / (2 ^ (a + t + 1))
  refine Exists.intro (c + 2 ^ t * e) ?_
  have hlt : l1PullbackTarget a c < 2 ^ (a + t + 1) :=
    l1PullbackTarget_lt_modulus a t c ha hc hcb
  have htargetMod : (3 * q) % (2 ^ (a + t + 1)) = l1PullbackTarget a c := by
    unfold Nat.ModEq at htarget
    rw [Nat.mod_eq_of_lt hlt] at htarget
    exact htarget
  have hdecomp : l1PullbackTarget a c + 2 ^ (a + t + 1) * e = 3 * q := by
    have h0 := Nat.mod_add_div (3 * q) (2 ^ (a + t + 1))
    dsimp [e]
    rw [htargetMod] at h0
    exact h0
  have hM : 2 ^ (a + t + 1) = 2 ^ a * (2 * 2 ^ t) := by
    calc
      2 ^ (a + t + 1) = 2 ^ (a + (t + 1)) := by
        have hidx : a + t + 1 = a + (t + 1) := by omega
        rw [hidx]
      _ = 2 ^ a * 2 ^ (t + 1) := Nat.pow_add 2 a (t + 1)
      _ = 2 ^ a * (2 * 2 ^ t) := by rw [pow_succ']
  have hposNext : 1 <= c + 2 ^ t * e := by omega
  have hstepNext : 3 * q = 1 + 2 ^ a * (2 * (c + 2 ^ t * e) - 1) := by
    rw [Eq.symm hdecomp]
    unfold l1PullbackTarget
    rw [hM]
    exact l1_reverse_step_algebra a t c e hc
  have hmodNext : Nat.ModEq (2 ^ t) (c + 2 ^ t * e) c := by
    exact Nat.ModEq.symm (Nat.modEq_iff_dvd.mpr (by use e; omega))
  exact And.intro hposNext (And.intro hstepNext hmodNext)
theorem l1_pullback_positive_residue_to_exact_step
    (a t c q : Nat) (ha : 1 <= a) (hc : 1 <= c) (hcb : c <= 2 ^ t)
    (hres : Nat.ModEq (2 ^ (a + t + 1)) q (l1OneStepPullbackPositiveResidue a t c)) :
    Exists (fun qNext : Nat =>
      And (1 <= qNext)
        (And (3 * q = 1 + 2 ^ a * (2 * qNext - 1))
          (Nat.ModEq (2 ^ t) qNext c))) := by
  exact l1_pullback_target_to_exact_step a t c q ha hc hcb
    ((l1_one_step_pullback_positive_residue a t c q).mpr hres)
def mkPath (q0 : Nat) (tail : Nat -> Nat) : Nat -> Nat
  | 0 => q0
  | Nat.succ i => tail i
def PathPositive (q : Nat -> Nat) : Prop :=
  forall i, 1 <= q i
def PathSteps (ds : List Nat) (q : Nat -> Nat) : Prop :=
  forall i a, ds[i]? = some a ->
    3 * q i = 1 + 2 ^ a * (2 * q (i + 1) - 1)
def PathRealizes (ds : List Nat) (q : Nat -> Nat) : Prop :=
  And (PathPositive q) (And (Odd (q ds.length)) (PathSteps ds q))
theorem modEq_two_one_odd (q : Nat) (h : Nat.ModEq 2 q 1) :
    Odd q := by
  apply Nat.not_even_iff_odd.mp
  intro he
  have hq0 : q % 2 = 0 := Nat.even_iff.mp he
  unfold Nat.ModEq at h
  omega
theorem modEq_two_one_pos (q : Nat) (h : Nat.ModEq 2 q 1) :
    1 <= q := by
  unfold Nat.ModEq at h
  omega
theorem mkPath_steps_cons (a : Nat) (rest : List Nat) (q0 qNext : Nat) (tail : Nat -> Nat)
    (hlink : tail 0 = qNext)
    (htail : PathRealizes rest tail)
    (hhead : 3 * q0 = 1 + 2 ^ a * (2 * qNext - 1)) :
    PathSteps (a :: rest) (mkPath q0 tail) := by
  intro i b hb
  cases i with
  | zero =>
      simp at hb
      have hb' : b = a := hb.symm
      subst b
      simpa [mkPath, hlink] using hhead
  | succ j =>
      have hbTail : rest[j]? = some b := by simpa using hb
      have htailSteps := htail.2.2
      simpa [mkPath] using htailSteps j b hbTail
theorem l1_finite_depth_pattern_pullback_reverse
    (ds : List Nat) (q0 : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a)
    (hres : Nat.ModEq (2 ^ l1PatternDepth ds) q0 (l1PatternResidue ds)) :
    Exists (fun q : Nat -> Nat => q 0 = q0 ∧ PathRealizes ds q) := by
  induction ds generalizing q0 with
  | nil =>
      refine Exists.intro (fun _ => q0) ?_
      have hodd : Odd q0 := by
        simpa [l1PatternDepth, l1PatternResidue] using modEq_two_one_odd q0 hres
      have hpos : 1 <= q0 := by
        simpa [l1PatternDepth, l1PatternResidue] using modEq_two_one_pos q0 hres
      constructor
      · rfl
      · exact And.intro (by intro i; exact hpos)
          (And.intro hodd (by intro i a h; simp at h))
  | cons a rest ih =>
      have haHead : 1 <= a := ha 0 a (by simp)
      have hresHead :
          Nat.ModEq (2 ^ (a + l1PatternDepth rest + 1)) q0
            (l1OneStepPullbackPositiveResidue a (l1PatternDepth rest) (l1PatternResidue rest)) := by
        simpa [l1PatternDepth, l1PatternResidue] using hres
      match l1_pullback_positive_residue_to_exact_step a (l1PatternDepth rest)
          (l1PatternResidue rest) q0 haHead (l1PatternResidue_pos rest)
          (l1PatternResidue_le_modulus rest) hresHead with
      | Exists.intro qNext hNext =>
          have htailRes : Nat.ModEq (2 ^ l1PatternDepth rest) qNext (l1PatternResidue rest) :=
            hNext.2.2
          have haTail : forall (i : Nat) (b : Nat), rest[i]? = some b -> 1 <= b := by
            intro i b hb
            exact ha (i + 1) b (by simpa using hb)
          match ih qNext haTail htailRes with
          | Exists.intro tail htail =>
              refine Exists.intro (mkPath q0 tail) ?_
              have htailRealizes : PathRealizes rest tail := htail.2
              have hlink : tail 0 = qNext := htail.1
              have hq0pos : 1 <= q0 := by
                have hstepPos := hNext.2.1
                omega
              constructor
              · rfl
              · exact And.intro
                  (by
                    intro i
                    cases i with
                    | zero => simpa [mkPath] using hq0pos
                    | succ j => simpa [mkPath] using htailRealizes.1 j)
                  (And.intro
                    (by
                      have hlen : mkPath q0 tail (List.length (a :: rest)) =
                          tail rest.length := by rfl
                      rw [hlen]
                      exact htailRealizes.2.1)
                    (mkPath_steps_cons a rest q0 qNext tail hlink htailRealizes hNext.2.1))
theorem l1_finite_depth_pattern_pullback_reverse_C1
    (ds : List Nat) (q0 : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a)
    (hres : Nat.ModEq (2 ^ (ds.sum + ds.length + 1)) q0 (l1PatternResidue ds)) :
    Exists (fun q : Nat -> Nat => q 0 = q0 ∧ PathRealizes ds q) := by
  apply l1_finite_depth_pattern_pullback_reverse ds q0 ha
  simpa [l1PatternDepth_eq_sum_length ds] using hres
theorem l1_finite_depth_pattern_pullback_iff_C1
    (ds : List Nat) (q0 : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a) :
    (Exists (fun q : Nat -> Nat => q 0 = q0 ∧ PathRealizes ds q)) <->
      Nat.ModEq (2 ^ (ds.sum + ds.length + 1)) q0 (l1PatternResidue ds) := by
  constructor
  · intro hex
    match hex with
    | Exists.intro q hq =>
        have hforward :=
          l1_finite_depth_pattern_pullback_forward_C1 ds q hq.2.1 hq.2.2.1 hq.2.2.2
        simpa [hq.1] using hforward
  · intro hres
    exact l1_finite_depth_pattern_pullback_reverse_C1 ds q0 ha hres
theorem l1_exact_step_source_odd (a q qNext : Nat) (ha : 1 <= a)
    (hstep : 3 * q = 1 + 2 ^ a * (2 * qNext - 1)) :
    Odd q := by
  apply Nat.not_even_iff_odd.mp
  intro he
  have hq0 : q % 2 = 0 := Nat.even_iff.mp he
  have hleft : (3 * q) % 2 = 0 := by
    rw [Nat.mul_mod, hq0]
  have hpow0 : (2 ^ a) % 2 = 0 := by
    exact Nat.dvd_iff_mod_eq_zero.mp (pow_dvd_pow 2 ha)
  have hright : (1 + 2 ^ a * (2 * qNext - 1)) % 2 = 1 := by
    rw [Nat.add_mod, Nat.mul_mod, hpow0]
    norm_num
  have hmod := congrArg (fun n : Nat => n % 2) hstep
  simp [hleft, hright] at hmod
theorem l1PatternResidue_odd_of_depths
    (ds : List Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a) :
    Odd (l1PatternResidue ds) := by
  cases ds with
  | nil =>
      simp [l1PatternResidue]
  | cons a rest =>
      have hres :
          Nat.ModEq (2 ^ ((a :: rest).sum + (a :: rest).length + 1))
            (l1PatternResidue (a :: rest)) (l1PatternResidue (a :: rest)) :=
        Nat.ModEq.refl _
      match l1_finite_depth_pattern_pullback_reverse_C1 (a :: rest)
          (l1PatternResidue (a :: rest)) ha hres with
      | Exists.intro q hq =>
          have hstep0 := hq.2.2.2 0 a (by simp)
          have hq0odd := l1_exact_step_source_odd a (q 0) (q 1) (ha 0 a (by simp)) hstep0
          simpa [hq.1] using hq0odd
theorem l1PatternDepth_pos (ds : List Nat) :
    1 <= l1PatternDepth ds := by
  rw [l1PatternDepth_eq_sum_length ds]
  omega
theorem l1PatternResidue_lt_modulus_of_depths
    (ds : List Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a) :
    l1PatternResidue ds < 2 ^ l1PatternDepth ds := by
  have hle := l1PatternResidue_le_modulus ds
  by_contra hnot
  have heq : l1PatternResidue ds = 2 ^ l1PatternDepth ds := by omega
  have hEven : Even (l1PatternResidue ds) := by
    rw [heq]
    rw [even_iff_two_dvd]
    exact pow_dvd_pow 2 (l1PatternDepth_pos ds)
  exact (Nat.not_even_iff_odd.mpr (l1PatternResidue_odd_of_depths ds ha)) hEven
def oddResidueLift (D r u : Nat) : Nat :=
  r + 2 ^ D * u
theorem oddResidueLift_lt_pow (D M r u : Nat)
    (hDM : D <= M) (hr : r < 2 ^ D) (hu : u < 2 ^ (M - D)) :
    oddResidueLift D r u < 2 ^ M := by
  unfold oddResidueLift
  have hpow : 2 ^ D * 2 ^ (M - D) = 2 ^ M := by
    calc
      2 ^ D * 2 ^ (M - D) = 2 ^ (D + (M - D)) := by
        exact (Nat.pow_add 2 D (M - D)).symm
      _ = 2 ^ M := by congr 1; omega
  have hsum : r + 2 ^ D * u < 2 ^ D + 2 ^ D * u := by
    exact Nat.add_lt_add_right hr (2 ^ D * u)
  have hnext : 2 ^ D + 2 ^ D * u <= 2 ^ D * 2 ^ (M - D) := by
    have hsucc : u + 1 <= 2 ^ (M - D) := by omega
    calc
      2 ^ D + 2 ^ D * u = 2 ^ D * (u + 1) := by ring
      _ <= 2 ^ D * 2 ^ (M - D) := Nat.mul_le_mul_left (2 ^ D) hsucc
  omega
theorem oddResidueLift_lt_succ_pow (D M r u : Nat)
    (hDM : D <= M) (hr : r <= 2 ^ D) (hu : u < 2 ^ (M - D)) :
    oddResidueLift D r u < 2 ^ M + 1 := by
  unfold oddResidueLift
  have hpow : 2 ^ D * 2 ^ (M - D) = 2 ^ M := by
    calc
      2 ^ D * 2 ^ (M - D) = 2 ^ (D + (M - D)) := by
        exact (Nat.pow_add 2 D (M - D)).symm
      _ = 2 ^ M := by congr 1; omega
  have hsum : r + 2 ^ D * u <= 2 ^ D + 2 ^ D * u := by
    exact Nat.add_le_add_right hr (2 ^ D * u)
  have hnext : 2 ^ D + 2 ^ D * u <= 2 ^ D * 2 ^ (M - D) := by
    have hsucc : u + 1 <= 2 ^ (M - D) := by omega
    calc
      2 ^ D + 2 ^ D * u = 2 ^ D * (u + 1) := by ring
      _ <= 2 ^ D * 2 ^ (M - D) := Nat.mul_le_mul_left (2 ^ D) hsucc
  omega
theorem oddResidueLift_modEq (D r u : Nat) :
    Nat.ModEq (2 ^ D) (oddResidueLift D r u) r := by
  unfold oddResidueLift
  exact Nat.ModEq.symm (Nat.modEq_iff_dvd.mpr (by use u; omega))
theorem oddResidueLift_odd (D r u : Nat) (hD : 1 <= D) (hodd : Odd r) :
    Odd (oddResidueLift D r u) := by
  unfold oddResidueLift
  have hEven : Even (2 ^ D * u) := by
    rw [even_iff_two_dvd]
    refine dvd_mul_of_dvd_left ?_ u
    exact pow_dvd_pow 2 hD
  exact Odd.add_even hodd hEven
theorem oddResidueLift_injective (D r u v : Nat)
    (h : oddResidueLift D r u = oddResidueLift D r v) :
    u = v := by
  unfold oddResidueLift at h
  have hmul : 2 ^ D * u = 2 ^ D * v := by omega
  exact Nat.eq_of_mul_eq_mul_left (pow_pos (by norm_num : 0 < 2) D) hmul
theorem oddResidueLift_surjective_in_window (D M r q : Nat)
    (hDM : D <= M) (hr : r < 2 ^ D) (hq : q < 2 ^ M)
    (hmod : Nat.ModEq (2 ^ D) q r) :
    Exists (fun u : Nat => And (u < 2 ^ (M - D)) (q = oddResidueLift D r u)) := by
  let u : Nat := q / 2 ^ D
  refine Exists.intro u ?_
  have hmodEq : q % 2 ^ D = r := by
    unfold Nat.ModEq at hmod
    rw [Nat.mod_eq_of_lt hr] at hmod
    exact hmod
  have hdecomp : r + 2 ^ D * u = q := by
    have h0 := Nat.mod_add_div q (2 ^ D)
    dsimp [u]
    rw [hmodEq] at h0
    exact h0
  have hpow : 2 ^ D * 2 ^ (M - D) = 2 ^ M := by
    calc
      2 ^ D * 2 ^ (M - D) = 2 ^ (D + (M - D)) := by
        exact (Nat.pow_add 2 D (M - D)).symm
      _ = 2 ^ M := by congr 1; omega
  have hu : u < 2 ^ (M - D) := by
    by_contra hnot
    have hge : 2 ^ (M - D) <= u := by omega
    have hmul : 2 ^ D * 2 ^ (M - D) <= 2 ^ D * u := Nat.mul_le_mul_left (2 ^ D) hge
    omega
  exact And.intro hu hdecomp.symm
theorem oddResidueLift_image_card (D r N : Nat) :
    ((Finset.range N).image (fun u => oddResidueLift D r u)).card = N := by
  calc
    ((Finset.range N).image (fun u => oddResidueLift D r u)).card = (Finset.range N).card := by
      apply Finset.card_image_of_injective
      intro u v h
      exact oddResidueLift_injective D r u v h
    _ = N := Finset.card_range N
theorem l1_finite_depth_pattern_lift_realizes_C1
    (ds : List Nat) (u : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a) :
    Exists (fun q : Nat -> Nat =>
      q 0 = oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u ∧
        PathRealizes ds q) := by
  apply (l1_finite_depth_pattern_pullback_iff_C1 ds
    (oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u) ha).mpr
  exact oddResidueLift_modEq (ds.sum + ds.length + 1) (l1PatternResidue ds) u
theorem l1_finite_depth_pattern_lift_lt_succ_window_C1
    (ds : List Nat) (M u : Nat)
    (hM : ds.sum + ds.length + 1 <= M)
    (hu : u < 2 ^ (M - (ds.sum + ds.length + 1))) :
    oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u < 2 ^ M + 1 := by
  apply oddResidueLift_lt_succ_pow
  · exact hM
  · simpa [l1PatternDepth_eq_sum_length ds] using l1PatternResidue_le_modulus ds
  · exact hu
theorem l1_finite_depth_pattern_lift_lt_window_C1
    (ds : List Nat) (M u : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a)
    (hM : ds.sum + ds.length + 1 <= M)
    (hu : u < 2 ^ (M - (ds.sum + ds.length + 1))) :
    oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u < 2 ^ M := by
  apply oddResidueLift_lt_pow
  · exact hM
  · simpa [l1PatternDepth_eq_sum_length ds] using
      l1PatternResidue_lt_modulus_of_depths ds ha
  · exact hu
theorem l1_finite_depth_pattern_lift_odd_C1
    (ds : List Nat) (u : Nat)
    (ha : forall (i : Nat) (a : Nat), ds[i]? = some a -> 1 <= a) :
    Odd (oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u) := by
  apply oddResidueLift_odd
  · omega
  · exact l1PatternResidue_odd_of_depths ds ha
theorem l1_finite_depth_pattern_lift_image_card_C1
    (ds : List Nat) (M : Nat) :
    ((Finset.range (2 ^ (M - (ds.sum + ds.length + 1)))).image
      (fun u => oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u)).card =
        2 ^ (M - (ds.sum + ds.length + 1)) := by
  exact oddResidueLift_image_card (ds.sum + ds.length + 1) (l1PatternResidue ds)
    (2 ^ (M - (ds.sum + ds.length + 1)))
theorem l1_finite_depth_pattern_odd_density_ratio_C1
    (ds : List Nat) (M : Nat)
    (hM : ds.sum + ds.length + 1 <= M) :
    ((((Finset.range (2 ^ (M - (ds.sum + ds.length + 1)))).image
      (fun u => oddResidueLift (ds.sum + ds.length + 1) (l1PatternResidue ds) u)).card : Nat) : Rat) /
        ((2 ^ (M - 1) : Nat) : Rat) =
      (1 : Rat) / (2 ^ (ds.sum + ds.length)) := by
  rw [l1_finite_depth_pattern_lift_image_card_C1]
  norm_num
  have hidx : M - 1 =
      (M - (ds.sum + ds.length + 1)) + (ds.sum + ds.length) := by
    omega
  rw [hidx, pow_add]
  field_simp
theorem l1_dangerous_depth_pattern_density_exponent_bound
    (ds : List Nat)
    (hdanger : forall (i : Nat) (a : Nat), ds[i]? = some a -> 3 <= a) :
    4 * ds.length <= ds.sum + ds.length := by
  induction ds with
  | nil =>
