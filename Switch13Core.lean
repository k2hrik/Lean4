theorem c7_ceiling_kill_from_affine_terminal_drop
    (S k A m n_end : Nat)
    (_hm : 0 < m)
    (_hA : 0 < A)
    (haffine : 2 ^ S * n_end = 3 ^ k * m + A)
    (hdrop : n_end < m) :
    0 < c7WordDefect S k ∧ c7NormalizedDefect S k A < m := by
  unfold c7WordDefect c7NormalizedDefect
  have hterm_lt : 3 ^ k * m + A < 2 ^ S * m := by
    rw [← haffine]
    exact (Nat.mul_lt_mul_left (pow_pos (by norm_num : 0 < 2) S)).mpr hdrop
  have hSpow : 3 ^ k < 2 ^ S := by
    by_contra hnot
    have hle : 2 ^ S ≤ 3 ^ k := le_of_not_gt hnot
    have hleq : 2 ^ S * m ≤ 3 ^ k * m + A := by
      calc
        2 ^ S * m ≤ 3 ^ k * m := Nat.mul_le_mul_right m hle
        _ ≤ 3 ^ k * m + A := Nat.le_add_right _ A
    omega
  have hDpos : 0 < 2 ^ S - 3 ^ k := by omega
  have hAm : A < (2 ^ S - 3 ^ k) * m := by
    have hmulsub : (2 ^ S - 3 ^ k) * m + 3 ^ k * m = 2 ^ S * m := by
      rw [← Nat.add_mul, Nat.sub_add_cancel (Nat.le_of_lt hSpow)]
    have hlt : A + 3 ^ k * m < (2 ^ S - 3 ^ k) * m + 3 ^ k * m := by
      simpa [hmulsub, Nat.add_comm] using hterm_lt
    omega
  exact ⟨hDpos, Nat.div_lt_of_lt_mul hAm⟩
def c7FirstChildAffineConstant (P : C7ParentCylinder) : Nat :=
  2 ^ (P.S + 1) * P.beta - 3 ^ (P.r + 1) * P.m
def c7FirstChildDefect (P : C7ParentCylinder) (h : Nat) : Nat :=
  2 ^ (P.S + h) - 3 ^ (P.r + 1)
theorem c7_first_child_affine_constant_eq
    (P : C7ParentCylinder) :
    c7FirstChildAffineConstant P = 3 * P.A + 2 ^ P.S := by
  unfold c7FirstChildAffineConstant
  have hsum :
      2 ^ (P.S + 1) * P.beta =
        3 * P.A + 2 ^ P.S + 3 ^ (P.r + 1) * P.m := by
    rw [P.beta_eq]
    ring
  exact Nat.sub_eq_of_eq_add hsum
theorem c7_contracting_first_child_ceiling_kill
    (P : C7ParentCylinder) (h : Nat)
    (hh : 1 <= h)
    (hcontract : 3 ^ (P.r + 1) < 2 ^ (P.S + h))
    (hsmall : P.beta < 2 ^ (h - 1) * P.m) :
    0 < c7FirstChildDefect P h ∧
      c7FirstChildAffineConstant P / c7FirstChildDefect P h < P.m := by
  unfold c7FirstChildAffineConstant c7FirstChildDefect
  have hDpos : 0 < 2 ^ (P.S + h) - 3 ^ (P.r + 1) := by omega
  have hpow :
      2 ^ (P.S + 1) * (2 ^ (h - 1) * P.m) =
        2 ^ (P.S + h) * P.m := by
    have hexp : P.S + 1 + (h - 1) = P.S + h := by omega
    rw [← Nat.mul_assoc, ← pow_add, hexp]
  have hbeta_mul :
      2 ^ (P.S + 1) * P.beta <
        2 ^ (P.S + h) * P.m := by
    calc
      2 ^ (P.S + 1) * P.beta
          < 2 ^ (P.S + 1) * (2 ^ (h - 1) * P.m) :=
            (Nat.mul_lt_mul_left
              (Nat.pow_pos (by norm_num : 0 < 2))).mpr hsmall
      _ = 2 ^ (P.S + h) * P.m := hpow
  have hA_lt :
      2 ^ (P.S + 1) * P.beta - 3 ^ (P.r + 1) * P.m <
        (2 ^ (P.S + h) - 3 ^ (P.r + 1)) * P.m := by
    have hright :
        (2 ^ (P.S + h) - 3 ^ (P.r + 1)) * P.m + 3 ^ (P.r + 1) * P.m =
          2 ^ (P.S + h) * P.m := by
      rw [← Nat.add_mul, Nat.sub_add_cancel (Nat.le_of_lt hcontract)]
    have hleft :
        (2 ^ (P.S + 1) * P.beta - 3 ^ (P.r + 1) * P.m) +
            3 ^ (P.r + 1) * P.m =
          2 ^ (P.S + 1) * P.beta := by
      rw [Nat.sub_add_cancel]
      rw [P.beta_eq]
      calc
        3 ^ (P.r + 1) * P.m
            <= 3 ^ (P.r + 1) * P.m + (3 * P.A + 2 ^ P.S) :=
          Nat.le_add_right _ _
        _ = 3 ^ (P.r + 1) * P.m + 3 * P.A + 2 ^ P.S := by ring
    have hlt :
        (2 ^ (P.S + 1) * P.beta - 3 ^ (P.r + 1) * P.m) +
            3 ^ (P.r + 1) * P.m <
          (2 ^ (P.S + h) - 3 ^ (P.r + 1)) * P.m +
            3 ^ (P.r + 1) * P.m := by
      simpa [hleft, hright] using hbeta_mul
    exact (Nat.add_lt_add_iff_right).mp hlt
  exact ⟨hDpos, Nat.div_lt_of_lt_mul hA_lt⟩
theorem c7_low_zone_beta_small_for_h1_h2
    (P : C7ParentCylinder)
    (hbeta : P.beta = 2 ∨ P.beta = 8)
    (hm : 9 <= P.m) :
    P.beta < 2 ^ (1 - 1) * P.m ∧
      P.beta < 2 ^ (2 - 1) * P.m := by
  have hb_le : P.beta <= 8 := by
    rcases hbeta with h2 | h8 <;> omega
  constructor
  · norm_num
    omega
  · norm_num
    omega
theorem c7_low_zone_contracting_first_child_h1
    (P : C7ParentCylinder)
    (hbeta : P.beta = 2 ∨ P.beta = 8)
    (hm : 9 <= P.m)
    (hAchild_pos : 0 < c7FirstChildAffineConstant P) :
    3 ^ (P.r + 1) < 2 ^ (P.S + 1) := by
  unfold c7FirstChildAffineConstant at hAchild_pos
  have hb_le : P.beta <= 8 := by
    rcases hbeta with h2 | h8 <;> omega
  by_contra hnot
  have hle : 2 ^ (P.S + 1) <= 3 ^ (P.r + 1) := le_of_not_gt hnot
  have hmul :
      2 ^ (P.S + 1) * P.beta <= 3 ^ (P.r + 1) * P.m := by
    calc
      2 ^ (P.S + 1) * P.beta <= 2 ^ (P.S + 1) * P.m :=
        Nat.mul_le_mul_left _ (by omega)
      _ <= 3 ^ (P.r + 1) * P.m := Nat.mul_le_mul_right _ hle
  omega
theorem c7_contracting_first_child_h2_of_h1
    (P : C7ParentCylinder)
    (hcontract1 : 3 ^ (P.r + 1) < 2 ^ (P.S + 1)) :
    3 ^ (P.r + 1) < 2 ^ (P.S + 2) := by
  calc
    3 ^ (P.r + 1) < 2 ^ (P.S + 1) := hcontract1
    _ <= 2 ^ (P.S + 2) :=
      Nat.pow_le_pow_right (by norm_num : 1 <= 2) (by omega : P.S + 1 <= P.S + 2)
theorem c7_low_zone_kills_first_children_h1_h2
    (P : C7ParentCylinder)
    (hbeta : P.beta = 2 ∨ P.beta = 8)
    (hm : 9 <= P.m)
    (hAchild_pos : 0 < c7FirstChildAffineConstant P) :
    (0 < c7FirstChildDefect P 1 ∧
        c7FirstChildAffineConstant P / c7FirstChildDefect P 1 < P.m) ∧
      (0 < c7FirstChildDefect P 2 ∧
        c7FirstChildAffineConstant P / c7FirstChildDefect P 2 < P.m) := by
  have hsmall := c7_low_zone_beta_small_for_h1_h2 P hbeta hm
  have hcontract1 := c7_low_zone_contracting_first_child_h1 P hbeta hm hAchild_pos
  have hcontract2 := c7_contracting_first_child_h2_of_h1 P hcontract1
  exact ⟨
    c7_contracting_first_child_ceiling_kill P 1 (by omega) hcontract1 hsmall.1,
    c7_contracting_first_child_ceiling_kill P 2 (by omega) hcontract2 hsmall.2⟩

def c13V2Fuel : Nat -> Nat -> Nat
  | 0, _ => 0
  | fuel + 1, n =>
      if n = 0 then
        0
      else if n % 2 = 0 then
        1 + c13V2Fuel fuel (n / 2)
      else
        0
