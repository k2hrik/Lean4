noncomputable def l1PreludeWeight (x : Fin 2) : Rat :=
  (1 : Rat) / (2 ^ (x.val + 2))
theorem l1_prelude_one_step_mass :
    (Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) = (3 : Rat) / 8 := by
  rw [show (Finset.univ : Finset (Fin 2)) = {0, 1} by native_decide]
  simp [l1PreludeWeight]
  norm_num
noncomputable def l1PreludeTupleMass (m : Nat) : Rat :=
