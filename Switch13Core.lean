    c13Qexit c = 1 ∨ c13Qexit c = 3 ∨ c13Qexit c = 7 := by
  cases c13_bounded_tail_endpoint_exact c hc with
  | inl h1 =>
      exact Or.inl h1.2
  | inr hrest =>
      cases hrest with
      | inl h5 =>
          exact Or.inr (Or.inl h5.2)
      | inr h13 =>
          exact Or.inr (Or.inr h13.2)
