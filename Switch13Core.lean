theorem r4m2_target_peel_identity (U : List TerminalLetter) :
    r4m2TargetEquation (TerminalLetter.r4m2 :: U) ↔
      r4m2TargetEquation U := by
  simp [r4m2TargetEquation, wordP, wordK, terminalP, terminalK, Nat.pow_add]
  omega
theorem r4r3m0_target_peel_identity (U : List TerminalLetter) :
    r4r3m0TargetEquation (TerminalLetter.r4r3m0 :: U) ↔
      r4r3m0TargetEquation U := by
  simp [r4r3m0TargetEquation, wordP, wordK, terminalP, terminalK, Nat.pow_add]
  omega
theorem r4m2_target_first_letter_forced_from_equation
    (L : TerminalLetter) (U : List TerminalLetter)
    (h : r4m2TargetEquation (L :: U)) :
    L = TerminalLetter.r4m2 := by
  cases L <;>
    simp [r4m2TargetEquation, wordP, wordK, terminalP, terminalK, Nat.pow_add] at h ⊢ <;>
    omega
theorem r4r3m0_target_first_letter_forced_from_equation
    (L : TerminalLetter) (U : List TerminalLetter)
    (h : r4r3m0TargetEquation (L :: U)) :
    L = TerminalLetter.r4r3m0 := by
  cases L <;>
    simp [r4r3m0TargetEquation, wordP, wordK, terminalP, terminalK, Nat.pow_add] at h ⊢ <;>
    omega
def allLettersAre (target : TerminalLetter) : List TerminalLetter -> Prop
  | [] => True
  | L :: U => L = target ∧ allLettersAre target U
theorem r4m2_target_equation_forces_all_self_extremal :
    ∀ W : List TerminalLetter,
      r4m2TargetEquation W -> allLettersAre TerminalLetter.r4m2 W
  | [], _ => trivial
  | L :: U, h => by
      have hL : L = TerminalLetter.r4m2 :=
        r4m2_target_first_letter_forced_from_equation L U h
      subst L
      have hU : r4m2TargetEquation U := (r4m2_target_peel_identity U).mp h
      exact ⟨rfl, r4m2_target_equation_forces_all_self_extremal U hU⟩
theorem r4r3m0_target_equation_forces_all_self_extremal :
    ∀ W : List TerminalLetter,
      r4r3m0TargetEquation W -> allLettersAre TerminalLetter.r4r3m0 W
  | [], _ => trivial
  | L :: U, h => by
      have hL : L = TerminalLetter.r4r3m0 :=
        r4r3m0_target_first_letter_forced_from_equation L U h
      subst L
      have hU : r4r3m0TargetEquation U := (r4r3m0_target_peel_identity U).mp h
      exact ⟨rfl, r4r3m0_target_equation_forces_all_self_extremal U hU⟩
