  | baseTemplate
  | finiteFunnel
  | returnedCoordinate
  | terminalStock
  | downstreamStock
  deriving DecidableEq, Repr
def c5PiTermAllowedNonDOutcomes : List C5PiTermNonDOutcome :=
  [C5PiTermNonDOutcome.baseTemplate,
   C5PiTermNonDOutcome.finiteFunnel,
   C5PiTermNonDOutcome.returnedCoordinate,
   C5PiTermNonDOutcome.terminalStock,
   C5PiTermNonDOutcome.downstreamStock]
inductive C5PiTermStep where
  | pureD (letter : TerminalLetter) (childKey : C5PiTermKey)
  | nonD (outcome : C5PiTermNonDOutcome)
  deriving DecidableEq, Repr
structure C5PiTermState where
  key : C5PiTermKey
  centeredC : Nat
  tParity : Bool
  pairLabel : Nat
  centeredExponent : Nat
  centeredB : Nat
  cylinderModulus : Nat
  cylinderExponent : Nat
  cylinderResidue : Nat
  affineQM : Nat
  affineQB : Nat
