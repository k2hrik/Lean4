    by_contra hnot
    have hge : 2 <= q t - 1 := by omega
    have hpowpos : 0 < 4 ^ t := pow_pos (by norm_num : 0 < 4) t
    have hmul : 2 * 4 ^ t <= 4 ^ t * (q t - 1) := by nlinarith
    omega
  have hle : q t <= 2 := by omega
  cases hodd with
  | intro k hk =>
      have hk' := hk
      rw [hk'] at hle
      omega
