def c17GeneratedLeafOutcome (i : Nat) (u : Nat) : FinalTerminalOutcome :=
  match c17ListGet? c17GeneratedLeafRows i with
  | some (qm, qb) => FinalTerminalOutcome.baseTemplate (qm * u + qb) i
  | none => FinalTerminalOutcome.allDImpossible 0
theorem c17GeneratedLeafOutcome_sound_of_get
    {i qm qb u : Nat}
    (hget : c17ListGet? c17GeneratedLeafRows i = some (qm, qb))
    (hrow : c17BaseTemplateRowOK (qm, qb)) :
    (c17GeneratedLeafOutcome i u).Sound := by
  unfold c17BaseTemplateRowOK at hrow
  unfold c17GeneratedLeafOutcome
  rw [hget]
  exact c17TerminalOutcomeCert_baseTemplate_family_sound qm qb u i hrow.1 hrow.2
theorem c17GeneratedLeafOutcome_sound
    (i u : Nat) (hi : i < c17GeneratedLeafCount) :
    (c17GeneratedLeafOutcome i u).Sound := by
  have hiRows : i < c17GeneratedLeafRows.length := by
    rw [c17GeneratedLeafRows_length]
    exact hi
  obtain ⟨row, hget⟩ := c17ListGet?_exists_of_lt c17GeneratedLeafRows i hiRows
  cases row with
  | mk qm qb =>
      exact c17GeneratedLeafOutcome_sound_of_get hget
        (c17AllBaseTemplateRowsOKBool_get? c17GeneratedLeafRows i (qm, qb)
          c17GeneratedLeafRows_mod6_checked hget)
