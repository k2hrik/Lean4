def c17BaseTemplateRowOK : Nat × Nat -> Prop
  | (qm, qb) => qm % 6 = 0 ∧ (qb % 6 = 1 ∨ qb % 6 = 3)
def c17BaseTemplateRowOKBool : Nat × Nat -> Bool
  | (qm, qb) => qm % 6 == 0 && (qb % 6 == 1 || qb % 6 == 3)
theorem c17BaseTemplateRowOK_of_bool (row : Nat × Nat)
    (h : c17BaseTemplateRowOKBool row = true) :
    c17BaseTemplateRowOK row := by
  cases row with
  | mk qm qb =>
      unfold c17BaseTemplateRowOKBool at h
      unfold c17BaseTemplateRowOK
      simp at h
      exact h
def c17AllBaseTemplateRowsOKBool : List (Nat × Nat) -> Bool
  | [] => true
  | row :: rows =>
      c17BaseTemplateRowOKBool row && c17AllBaseTemplateRowsOKBool rows
theorem c17AllBaseTemplateRowsOKBool_get? :
    ∀ rows i row,
      c17AllBaseTemplateRowsOKBool rows = true ->
      c17ListGet? rows i = some row ->
      c17BaseTemplateRowOK row
  | [], 0, row, _hall, hget => by
      cases hget
  | [], _i + 1, row, _hall, hget => by
      cases hget
  | head :: tail, 0, row, hall, hget => by
      unfold c17ListGet? at hget
      cases hget
      have hhead : c17BaseTemplateRowOKBool head = true := by
        unfold c17AllBaseTemplateRowsOKBool at hall
        simp at hall
        exact hall.1
      exact c17BaseTemplateRowOK_of_bool head hhead
  | head :: tail, i + 1, row, hall, hget => by
      unfold c17ListGet? at hget
      have htail : c17AllBaseTemplateRowsOKBool tail = true := by
        unfold c17AllBaseTemplateRowsOKBool at hall
        simp at hall
        exact hall.2
      exact c17AllBaseTemplateRowsOKBool_get? tail i row htail hget
theorem c17ListGet?_exists_of_lt :
    ∀ (rows : List (Nat × Nat)) i,
      i < rows.length -> ∃ row : Nat × Nat, c17ListGet? rows i = some row
  | [], i, hi => by
      simp at hi
  | row :: rows, 0, _hi => by
      exact ⟨row, rfl⟩
  | row :: rows, i + 1, hi => by
      have hi' : i < rows.length := by
        simp at hi
        omega
      exact c17ListGet?_exists_of_lt rows i hi'
