def l1PreludeBurstCutoffM : Nat -> Nat
  | 1 => 24
  | 2 => 19
  | 3 => 16
  | 4 => 12
  | 5 => 9
  | 6 => 5
  | 7 => 2
  | _ => 0
def L1FiniteCutoffFamily (m n : Nat) (d : Nat -> Nat) : Prop :=
  1 <= n ∧ n <= 7 ∧ m <= l1PreludeBurstCutoffM n ∧
    forall j, j < n -> 3 <= d j ∧ d j <= 12
structure C1EntranceLaunchedBurst where
  m : Nat
  n : Nat
  qIn : Nat
  qStar : Nat
  qLast : Nat
  d : Nat -> Nat
  q : Nat -> Nat
  hnpos : 1 <= n
  hqIn : qIn < 2048
  hprelude : 4 ^ m * (qStar - 1) <= 3 ^ m * (qIn - 1)
  hdanger : 8 ^ (n - 1) * qLast < 3 ^ (n - 1) * qStar
  hlast : 3 <= qLast
  hdepthDanger : forall j, j < n -> 3 <= d j
  hqWindow : forall j, j < n -> q j < 2048
  hqNextPos : forall j, j < n -> 1 <= q (j + 1)
  hsteps : forall j, j < n ->
    3 * q j = 1 + 2 ^ d j * (2 * q (j + 1) - 1)
def C1Rlt2048 (B : C1EntranceLaunchedBurst) : Prop :=
  1 <= B.n ∧
    B.qIn < 2048 ∧
    4 ^ B.m * (B.qStar - 1) <= 3 ^ B.m * (B.qIn - 1) ∧
    8 ^ (B.n - 1) * B.qLast < 3 ^ (B.n - 1) * B.qStar ∧
    3 <= B.qLast ∧
    (forall j, j < B.n -> 3 <= B.d j) ∧
    (forall j, j < B.n -> B.q j < 2048) ∧
    (forall j, j < B.n -> 1 <= B.q (j + 1)) ∧
    (forall j, j < B.n ->
      3 * B.q j = 1 + 2 ^ B.d j * (2 * B.q (j + 1) - 1))
def C1RleMnLe12 (B : C1EntranceLaunchedBurst) : Prop :=
  L1FiniteCutoffFamily B.m B.n B.d
theorem l1_entrance_lt2048_full_skeleton_mem_cutoff_family
    (m n qIn qStar qLast : Nat)
    (d q : Nat -> Nat)
    (hnpos : 1 <= n)
    (hqIn : qIn < 2048)
    (hprelude : 4 ^ m * (qStar - 1) <= 3 ^ m * (qIn - 1))
    (hdanger : 8 ^ (n - 1) * qLast < 3 ^ (n - 1) * qStar)
    (hlast : 3 <= qLast)
    (hdepthDanger : forall j, j < n -> 3 <= d j)
    (hqWindow : forall j, j < n -> q j < 2048)
    (hqNextPos : forall j, j < n -> 1 <= q (j + 1))
    (hsteps : forall j, j < n ->
      3 * q j = 1 + 2 ^ d j * (2 * q (j + 1) - 1)) :
    L1FiniteCutoffFamily m n d := by
  have hbounds :=
    l1_entrance_lt2048_full_relaunch_skeleton_bounds m n qIn qStar qLast d q
      hqIn hprelude hdanger hlast hdepthDanger hqWindow hqNextPos hsteps
  unfold L1FiniteCutoffFamily
  refine ⟨hnpos, hbounds.1, ?_, hbounds.2.2⟩
  have hrows := hbounds.2.1
  have hnle : n <= 7 := hbounds.1
  interval_cases n <;> simp [l1PreludeBurstCutoffM] at * <;> assumption
theorem C1EntranceLaunchedBurst.mem_cutoff_family (B : C1EntranceLaunchedBurst) :
    L1FiniteCutoffFamily B.m B.n B.d :=
  l1_entrance_lt2048_full_skeleton_mem_cutoff_family
    B.m B.n B.qIn B.qStar B.qLast B.d B.q
    B.hnpos B.hqIn B.hprelude B.hdanger B.hlast
    B.hdepthDanger B.hqWindow B.hqNextPos B.hsteps
theorem c1_Rlt2048_subset_RleMnLe12 (B : C1EntranceLaunchedBurst) :
    C1Rlt2048 B -> C1RleMnLe12 B := by
  intro hB
  rcases hB with
    ⟨hnpos, hqIn, hprelude, hdanger, hlast,
      hdepthDanger, hqWindow, hqNextPos, hsteps⟩
  exact
    l1_entrance_lt2048_full_skeleton_mem_cutoff_family
      B.m B.n B.qIn B.qStar B.qLast B.d B.q
      hnpos hqIn hprelude hdanger hlast
      hdepthDanger hqWindow hqNextPos hsteps
theorem C1EntranceLaunchedBurst.mem_Rlt2048 (B : C1EntranceLaunchedBurst) :
    C1Rlt2048 B := by
  exact
    ⟨B.hnpos, B.hqIn, B.hprelude, B.hdanger, B.hlast,
      B.hdepthDanger, B.hqWindow, B.hqNextPos, B.hsteps⟩
theorem C1EntranceLaunchedBurst.mem_RleMnLe12 (B : C1EntranceLaunchedBurst) :
    C1RleMnLe12 B := by
