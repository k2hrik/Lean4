    norm_num
  rw [hpow]
  norm_num
  nlinarith
theorem pow2_s8_contracting_boundary (t : Nat) (ht : 1 <= t) :
    (2 : Int) ^ (t + 12) - (3 : Int) ^ 8 >= (2 : Int) ^ (t + 4) - 1 := by
  have h32 := pow2_ge_32_of_ge1 t ht
  have hpow : (2 : Int) ^ (t + 12) = (2 : Int) ^ (t + 4) * 256 := by
    have hidx : t + 12 = (t + 4) + 8 := by omega
