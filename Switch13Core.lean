theorem dyadic_subwindow_density_ratio (M k : Nat) (hM : k <= M) :
    (((2 ^ (M - k) : Nat) : Rat) / ((2 ^ M : Nat) : Rat)) =
      (1 : Rat) / ((2 ^ k : Nat) : Rat) := by
  have hpowNat : 2 ^ M = 2 ^ (M - k) * 2 ^ k := by
    calc
      2 ^ M = 2 ^ ((M - k) + k) := by congr 1; omega
