    (P : C7ParentCylinder) (n_r h : Nat) (hh : 1 <= h)
    (hbeta : c3V2 P.beta = h - 1)
    (hparam : P.Param P.m 0)
    (haffine : P.AffineTerminal P.m n_r) :
    c3V2 (3 * n_r + 1) = h := by
  have := c7_carry_over_next_valuation_at_zero P P.m n_r h hh hparam haffine
