theorem residual_tail_growth_t0_of_s_ge7 (z : Nat)
    (ht : residual_tNext z = 0) (hs : 7 <= residual_LNext z) :
    (residual_QReentry z : Int) > (residual_Q4 z : Int) := by
  apply residual_tail_growth_of_coeff_negative
