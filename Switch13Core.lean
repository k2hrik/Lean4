    (by decide) (by decide) (by decide) (by decide) (q / 16)
theorem c10_odd_descent_implies_all_odd_reach_one
    (hdesc : c10OddDescentStatement) :
    forall n : Nat, 0 < n -> Odd n -> c10ReachesOneOdd n := by
  intro n
  refine Nat.strong_induction_on n ?_
  intro n ih hpos hodd
  by_cases hle : n <= 1
  · have hn1 : n = 1 := by omega
    exact ⟨0, hn1⟩
  · have hgt : 1 < n := by omega
    cases hdesc n hpos hodd hgt with
    | inl hone =>
        exact hone
    | inr hsmaller =>
        rcases hsmaller with ⟨k, m, hmpos, hmodd, hmlt, hiter⟩
        have hmreach : c10ReachesOneOdd m := ih m hmlt hmpos hmodd
        exact c10_reaches_one_trans n m ⟨k, hiter⟩ hmreach
structure C10EvenToOddReduction (n m : Nat) : Prop where
  positive : 0 < m
  odd : Odd m
  factor : ∃ k : Nat, n = 2 ^ k * m
theorem c10_even_to_odd_reduction_exists :
    forall n : Nat, 0 < n ->
      Exists (fun m : Nat => C10EvenToOddReduction n m) := by
  intro n
  refine Nat.strong_induction_on n ?_
  intro n ih hn
  by_cases hodd : Odd n
  · exact ⟨n, hn, hodd, ⟨0, by simp⟩⟩
  · have heven : n % 2 = 0 := by
      have hmod : n % 2 < 2 := Nat.mod_lt n (by decide)
      have hnot1 : n % 2 ≠ 1 := by
        intro h1
        exact hodd (Nat.odd_iff.mpr h1)
      omega
    have hhalf_pos : 0 < n / 2 := by
      have hn_ge_two : 2 <= n := by
        by_contra hlt
        have hn1 : n = 1 := by omega
        exact hodd (by rw [hn1]; decide)
      exact Nat.div_pos hn_ge_two (by decide)
    have hhalf_lt : n / 2 < n := Nat.div_lt_self hn (by decide)
    rcases ih (n / 2) hhalf_lt hhalf_pos with ⟨m, hm⟩
    rcases hm.factor with ⟨k, hk⟩
    refine ⟨m, hm.positive, hm.odd, ?_⟩
    refine ⟨k + 1, ?_⟩
    have hn_split : n = 2 * (n / 2) := by
      exact (Nat.two_mul_div_two_of_even (Nat.even_iff.mpr heven)).symm
    rw [hn_split, hk]
    ring
theorem c10_positive_integer_closeout
    (hdesc : c10OddDescentStatement) :
    forall n : Nat, 0 < n ->
      Exists (fun m : Nat => C10EvenToOddReduction n m ∧ c10ReachesOneOdd m) := by
  intro n hn
  rcases c10_even_to_odd_reduction_exists n hn with ⟨m, hm⟩
  exact ⟨m, hm, c10_odd_descent_implies_all_odd_reach_one hdesc m hm.positive hm.odd⟩
theorem c10_minimal_counterexample_bridge_core :
    c10OddDescentStatement ->
      (forall n : Nat, 0 < n -> Odd n -> c10ReachesOneOdd n) := by
  intro hdesc
  exact c10_odd_descent_implies_all_odd_reach_one hdesc

def v2 (n : Nat) : Nat :=
  if h : n = 0 ∨ n % 2 ≠ 0 then 0
  else 1 + v2 (n / 2)
termination_by n
def t_odd (n : Nat) : Nat :=
  (3 * n + 1) / 2 ^ v2 (3 * n + 1)
def reaches_15 (n : Nat) : Nat → Bool
  | 0      => n == 1 || n == 5
  | fuel+1 => if n == 1 || n == 5 then true
              else reaches_15 (t_odd n) fuel
theorem v2_pow2 : ∀ k : Fin 32, v2 (2 ^ k.val) = k.val := by
  native_decide
theorem t_odd_three : t_odd 3 = 5 := by native_decide
theorem bounded_kernel_reaches_15_fuel65 : ∀ k : Fin 1024,
    reaches_15 (2 * k.val + 1) 65 = true := by
  native_decide
theorem bounded_kernel_reaches_15 : ∀ k : Fin 1024,
    reaches_15 (2 * k.val + 1) 200 = true := by
  native_decide
theorem terminal_set_absorbing :
    t_odd 1 = 1 ∧ t_odd 5 = 1 := by
  native_decide
theorem hardest_case_witness :
    reaches_15 1161 65 = true ∧ reaches_15 1161 64 = false := by
  native_decide
theorem fuel64_not_uniform :
    ∃ k : Fin 1024, reaches_15 (2 * k.val + 1) 64 = false := by
  exact ⟨⟨580, by decide⟩, by native_decide⟩
theorem t_odd_preserves_odd : ∀ k : Fin 1024,
    (t_odd (2 * k.val + 1)) % 2 = 1 := by
  native_decide
theorem t_odd_fixed_point_unique : ∀ k : Fin 1024,
    t_odd (2 * k.val + 1) = 2 * k.val + 1 → k.val = 0 := by
  native_decide
theorem terminal_valuation_depths :
    v2 (3 * 1 + 1) = 2 ∧ v2 (3 * 5 + 1) = 4 := by
  native_decide
theorem terminal_parent_beta_pairs :
    (3 * 1 + 1) / 2 = 2 ∧ (3 * 5 + 1) / 2 = 8 := by
  native_decide
private theorem reaches_15_step (k : Nat) : ∀ n : Nat,
    reaches_15 n k = true → reaches_15 n (k + 1) = true := by
  induction k with
  | zero =>
    intro n h
    unfold reaches_15 at h ⊢
    simp [h]
  | succ k ih =>
    intro n h
    unfold reaches_15 at h ⊢
    cases hb : (n == 1 || n == 5)
    · simp only [hb] at h ⊢
      exact ih (t_odd n) h
    · simp
theorem reaches_15_mono (n k : Nat) (h : reaches_15 n k = true) :
    ∀ m : Nat, reaches_15 n (k + m) = true := by
  intro m
  induction m with
  | zero => simpa
  | succ m ih =>
    have heq : k + (m + 1) = k + m + 1 := by omega
    rw [heq]
    exact reaches_15_step (k + m) n ih
theorem c7_v2_eq_c3V2 (n : Nat) :
    v2 n = c3V2 n := by
  induction n using Nat.strong_induction_on with
  | h n ih =>
      cases n with
      | zero =>
          simp [v2, c3V2]
      | succ m =>
          unfold v2 c3V2
          by_cases heven : (m + 1) % 2 = 0
          · have hnot : ¬(m + 1 = 0 ∨ (m + 1) % 2 ≠ 0) := by omega
            simp [heven]
            have hlt : (m + 1) / 2 < m + 1 := by
              exact Nat.div_lt_self (by omega) (by decide)
            exact ih ((m + 1) / 2) hlt
          · have hodd : m + 1 = 0 ∨ (m + 1) % 2 ≠ 0 := by
              exact Or.inr heven
            simp [heven]
theorem c7_t_odd_eq_c10TOdd (n : Nat) :
    t_odd n = c10TOdd n := by
  unfold t_odd c10TOdd
  rw [c7_v2_eq_c3V2, c10V2_eq_c3V2]
theorem reaches_15_true_to_c10_terminal
    (n fuel : Nat) (h : reaches_15 n fuel = true) :
    Exists (fun k : Nat =>
      k <= fuel ∧ (c10TOddIter n k = 1 ∨ c10TOddIter n k = 5)) := by
  induction fuel generalizing n with
  | zero =>
      unfold reaches_15 at h
      have hterm : n = 1 ∨ n = 5 := by
        simpa using h
      cases hterm with
      | inl hn =>
          exact ⟨0, by omega, Or.inl (by simp [c10TOddIter, hn])⟩
      | inr hn =>
          exact ⟨0, by omega, Or.inr (by simp [c10TOddIter, hn])⟩
  | succ fuel ih =>
      unfold reaches_15 at h
      cases hb : (n == 1 || n == 5)
      · simp only [hb] at h
        rcases ih (t_odd n) h with ⟨k, hkle, hend⟩
        refine ⟨1 + k, by omega, ?_⟩
        have hprefix :
            c10TOddIter n (1 + k) = c10TOddIter (t_odd n) k := by
          rw [← c10_iter_append n 1 k]
          simp [c10TOddIter, c7_t_odd_eq_c10TOdd]
        cases hend with
        | inl h1 => exact Or.inl (by rw [hprefix, h1])
        | inr h5 => exact Or.inr (by rw [hprefix, h5])
      · have hterm : n = 1 ∨ n = 5 := by
          simpa using hb
        cases hterm with
        | inl hn =>
            exact ⟨0, by omega, Or.inl (by simp [c10TOddIter, hn])⟩
        | inr hn =>
            exact ⟨0, by omega, Or.inr (by simp [c10TOddIter, hn])⟩
theorem bounded_kernel_c10_terminal_fuel65 (k : Fin 1024) :
    Exists (fun j : Nat =>
      j <= 65 ∧
        (c10TOddIter (2 * k.val + 1) j = 1 ∨
          c10TOddIter (2 * k.val + 1) j = 5)) :=
  reaches_15_true_to_c10_terminal
    (2 * k.val + 1) 65 (bounded_kernel_reaches_15_fuel65 k)
theorem c7_c10_terminal_five_reaches_one :
    c10TOddIter 5 1 = 1 := by
  simp only [c10TOddIter]
  rw [← c7_t_odd_eq_c10TOdd 5]
  exact terminal_set_absorbing.2
theorem bounded_kernel_c10_reaches_one_fuel65 (k : Fin 1024) :
    c10ReachesOneOdd (2 * k.val + 1) := by
  rcases bounded_kernel_c10_terminal_fuel65 k with ⟨j, _hjle, hend⟩
  cases hend with
  | inl h1 =>
      exact ⟨j, h1⟩
  | inr h5 =>
      refine ⟨j + 1, ?_⟩
      rw [← c10_iter_append (2 * k.val + 1) j 1, h5]
      exact c7_c10_terminal_five_reaches_one
theorem bounded_kernel_c10_reaches_one
    (q : Nat) (hodd : q % 2 = 1) (hlt : q < 2048) :
    c10ReachesOneOdd q := by
  let k : Nat := q / 2
  have hq : q = 2 * k + 1 := by
    dsimp [k]
    omega
  have hk : k < 1024 := by
    dsimp [k]
    omega
  let fk : Fin 1024 := ⟨k, hk⟩
  have hcert := bounded_kernel_c10_reaches_one_fuel65 fk
  simpa [fk, hq] using hcert

structure C7ParentCylinder where
  r : Nat
  S : Nat
  A : Nat
  m : Nat
  beta : Nat
  m_pos : 0 < m
  beta_pos : 0 < beta
  beta_eq :
    2 ^ (S + 1) * beta = 3 ^ (r + 1) * m + 3 * A + 2 ^ S
def C7ParentCylinder.Param (P : C7ParentCylinder) (n t : Nat) : Prop :=
  n = P.m + 2 ^ (P.S + 1) * t
def C7ParentCylinder.AffineTerminal
    (P : C7ParentCylinder) (n n_r : Nat) : Prop :=
  2 ^ P.S * n_r = 3 ^ P.r * n + P.A
def C7ParentCylinder.nextResidual
    (P : C7ParentCylinder) (t : Nat) : Nat :=
  3 ^ (P.r + 1) * t + P.beta
def C7ParentCylinder.nextValuation
    (P : C7ParentCylinder) (t : Nat) : Nat :=
  1 + c3V2 (P.nextResidual t)
theorem c7_parent_cylinder_next_raw_identity
    (P : C7ParentCylinder) (n n_r t : Nat)
    (hparam : P.Param n t)
    (haffine : P.AffineTerminal n n_r) :
    3 * n_r + 1 = 2 * P.nextResidual t := by
  unfold C7ParentCylinder.Param at hparam
  unfold C7ParentCylinder.AffineTerminal at haffine
  unfold C7ParentCylinder.nextResidual
  have hleft :
      2 ^ P.S * (3 * n_r + 1) =
        3 ^ (P.r + 1) * n + 3 * P.A + 2 ^ P.S := by
    calc
      2 ^ P.S * (3 * n_r + 1)
          = 3 * (2 ^ P.S * n_r) + 2 ^ P.S := by ring
      _ = 3 * (3 ^ P.r * n + P.A) + 2 ^ P.S := by rw [haffine]
      _ = 3 ^ (P.r + 1) * n + 3 * P.A + 2 ^ P.S := by
        rw [pow_succ]
        ring
  have hright :
      3 ^ (P.r + 1) * n + 3 * P.A + 2 ^ P.S =
        2 ^ P.S * (2 * (3 ^ (P.r + 1) * t + P.beta)) := by
    rw [hparam]
    have hbeta :
        3 ^ (P.r + 1) * P.m + 3 * P.A + 2 ^ P.S =
          2 ^ (P.S + 1) * P.beta := by
      rw [P.beta_eq]
    calc
      3 ^ (P.r + 1) * (P.m + 2 ^ (P.S + 1) * t) + 3 * P.A + 2 ^ P.S
          = (3 ^ (P.r + 1) * P.m + 3 * P.A + 2 ^ P.S) +
              2 ^ (P.S + 1) * (3 ^ (P.r + 1) * t) := by ring
      _ = 2 ^ (P.S + 1) * P.beta +
              2 ^ (P.S + 1) * (3 ^ (P.r + 1) * t) := by rw [hbeta]
      _ = 2 ^ P.S * (2 * (3 ^ (P.r + 1) * t + P.beta)) := by
        rw [pow_succ]
        ring
  have hmul :
      2 ^ P.S * (3 * n_r + 1) =
        2 ^ P.S * (2 * (3 ^ (P.r + 1) * t + P.beta)) :=
    hleft.trans hright
  exact Nat.eq_of_mul_eq_mul_left (Nat.pow_pos (by norm_num : 0 < 2)) hmul
theorem c7_parent_cylinder_next_valuation_identity
    (P : C7ParentCylinder) (n n_r t : Nat)
    (hparam : P.Param n t)
    (haffine : P.AffineTerminal n n_r) :
    c3V2 (3 * n_r + 1) = P.nextValuation t := by
  rw [c7_parent_cylinder_next_raw_identity P n n_r t hparam haffine]
  unfold C7ParentCylinder.nextValuation C7ParentCylinder.nextResidual
  rw [c3_v2_two_mul (3 ^ (P.r + 1) * t + P.beta)
    (Nat.lt_of_lt_of_le P.beta_pos (Nat.le_add_left P.beta (3 ^ (P.r + 1) * t)))]
  omega
theorem c7_parent_cylinder_exact_order_iff
    (P : C7ParentCylinder) (n n_r t h : Nat)
    (hh : 1 <= h)
    (hparam : P.Param n t)
    (haffine : P.AffineTerminal n n_r) :
    c3V2 (3 * n_r + 1) = h ↔
      c3V2 (P.nextResidual t) = h - 1 := by
  rw [c7_parent_cylinder_next_valuation_identity P n n_r t hparam haffine]
  unfold C7ParentCylinder.nextValuation
  omega
theorem c7_carry_over_next_valuation_at_zero
    (P : C7ParentCylinder) (n n_r h : Nat) (hh : 1 <= h)
    (hparam : P.Param n 0)
    (haffine : P.AffineTerminal n n_r) :
    c3V2 (3 * n_r + 1) = h ↔ c3V2 P.beta = h - 1 := by
  rw [c7_parent_cylinder_exact_order_iff P n n_r 0 h hh hparam haffine]
  simp [C7ParentCylinder.nextResidual]
theorem c7_terminal_state_progression_on_cylinder
    (P : C7ParentCylinder) (n n0 n_r t : Nat)
    (hparam : P.Param n t)
    (hleast : P.AffineTerminal P.m n0)
    (haffine : P.AffineTerminal n n_r) :
    n_r = n0 + 2 * 3 ^ P.r * t := by
  unfold C7ParentCylinder.Param at hparam
  unfold C7ParentCylinder.AffineTerminal at hleast haffine
  subst n
  have hmul :
      2 ^ P.S * n_r =
        2 ^ P.S * (n0 + 2 * 3 ^ P.r * t) := by
    calc
      2 ^ P.S * n_r
          = 3 ^ P.r * (P.m + 2 ^ (P.S + 1) * t) + P.A := haffine
      _ = (3 ^ P.r * P.m + P.A) + 2 ^ P.S * (2 * 3 ^ P.r * t) := by
        rw [pow_succ]
        ring
      _ = 2 ^ P.S * n0 + 2 ^ P.S * (2 * 3 ^ P.r * t) := by
        rw [hleast]
      _ = 2 ^ P.S * (n0 + 2 * 3 ^ P.r * t) := by ring
  exact Nat.eq_of_mul_eq_mul_left (Nat.pow_pos (by norm_num : 0 < 2)) hmul
theorem c7_terminal_state_one_or_five_forces_least_parameter
    (P : C7ParentCylinder) (n n0 n_r t : Nat)
    (hr : 1 <= P.r)
    (hn0 : 0 < n0)
    (hparam : P.Param n t)
    (hleast : P.AffineTerminal P.m n0)
    (haffine : P.AffineTerminal n n_r)
    (hend : n_r = 1 ∨ n_r = 5) :
    t = 0 ∧ n = P.m := by
  have hprog :=
    c7_terminal_state_progression_on_cylinder P n n0 n_r t hparam hleast haffine
  have ht0 : t = 0 := by
    by_contra ht
    have htpos : 0 < t := Nat.pos_of_ne_zero ht
    have ht1 : 1 <= t := Nat.succ_le_of_lt htpos
    have hpow : 3 <= 3 ^ P.r := by
      calc
        3 = 3 ^ 1 := by norm_num
        _ <= 3 ^ P.r := Nat.pow_le_pow_right (by norm_num : 1 <= 3) hr
    have hmul : 6 <= 2 * 3 ^ P.r * t := by
      calc
        6 = (2 * 3) * 1 := by norm_num
        _ <= (2 * 3 ^ P.r) * t :=
          Nat.mul_le_mul (Nat.mul_le_mul_left 2 hpow) ht1
        _ = 2 * 3 ^ P.r * t := by ring
    have hge : 7 <= n_r := by
      rw [hprog]
      calc
        7 = 1 + 6 := by norm_num
        _ <= n0 + 2 * 3 ^ P.r * t :=
          Nat.add_le_add (Nat.succ_le_of_lt hn0) hmul
    rcases hend with rfl | rfl <;> omega
  constructor
  · exact ht0
  · unfold C7ParentCylinder.Param at hparam
    rw [ht0] at hparam
    simpa using hparam
theorem c7_parent_beta_terminal_state_identity
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    3 * n0 + 1 = 2 * P.beta := by
  have hparam : P.Param P.m 0 := by
    unfold C7ParentCylinder.Param
    simp
  have hraw := c7_parent_cylinder_next_raw_identity P P.m n0 0 hparam hleast
  simpa [C7ParentCylinder.nextResidual] using hraw
theorem c7_parent_beta_eq_terminal_state_half
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    P.beta = (3 * n0 + 1) / 2 := by
  rw [c7_parent_beta_terminal_state_identity P n0 hleast]
  exact (Nat.mul_div_right P.beta (by norm_num : 0 < 2)).symm
theorem c7_terminal_state_eq_parent_beta_third
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    n0 = (2 * P.beta - 1) / 3 := by
  have h := c7_parent_beta_terminal_state_identity P n0 hleast
  have hsub : 2 * P.beta - 1 = 3 * n0 := by omega
  rw [hsub]
  exact (Nat.mul_div_right n0 (by norm_num : 0 < 3)).symm
theorem c7_parent_beta_eq_two_iff_terminal_one
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    P.beta = 2 ↔ n0 = 1 := by
  constructor
  · intro hbeta
    have h := c7_parent_beta_terminal_state_identity P n0 hleast
    omega
  · intro hn0
    rw [c7_parent_beta_eq_terminal_state_half P n0 hleast, hn0]
theorem c7_parent_beta_eq_eight_iff_terminal_five
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    P.beta = 8 ↔ n0 = 5 := by
  constructor
  · intro hbeta
    have h := c7_parent_beta_terminal_state_identity P n0 hleast
    omega
  · intro hn0
    rw [c7_parent_beta_eq_terminal_state_half P n0 hleast, hn0]
theorem c7_parent_beta_two_or_eight_iff_terminal_one_or_five
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0) :
    P.beta = 2 ∨ P.beta = 8 ↔ n0 = 1 ∨ n0 = 5 := by
  constructor
  · intro hbeta
    rcases hbeta with h2 | h8
    · exact Or.inl ((c7_parent_beta_eq_two_iff_terminal_one P n0 hleast).mp h2)
    · exact Or.inr ((c7_parent_beta_eq_eight_iff_terminal_five P n0 hleast).mp h8)
  · intro hn
    rcases hn with h1 | h5
    · exact Or.inl ((c7_parent_beta_eq_two_iff_terminal_one P n0 hleast).mpr h1)
    · exact Or.inr ((c7_parent_beta_eq_eight_iff_terminal_five P n0 hleast).mpr h5)
theorem c7_terminal_five_forces_beta_eight_mod8
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hn0 : n0 = 5) :
    P.beta = 8 ∧ Nat.ModEq 8 P.beta 0 := by
  have hbeta := (c7_parent_beta_eq_eight_iff_terminal_five P n0 hleast).mpr hn0
  constructor
  · exact hbeta
  · rw [hbeta]
    norm_num [Nat.ModEq]
theorem c7_terminal_one_forces_beta_two_mod8
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hn0 : n0 = 1) :
    P.beta = 2 ∧ Nat.ModEq 8 P.beta 2 := by
  have hbeta := (c7_parent_beta_eq_two_iff_terminal_one P n0 hleast).mpr hn0
  constructor
  · exact hbeta
  · rw [hbeta]
theorem c7_beta_phase_zero_or_two_disjoint_from_one_or_six
    (beta : Nat)
    (hphase : Nat.ModEq 8 beta 0 ∨ Nat.ModEq 8 beta 2) :
    ¬ Nat.ModEq 8 beta 1 ∧ ¬ Nat.ModEq 8 beta 6 := by
  constructor
  · intro hbad
    rcases hphase with h0 | h2
    · have hb0 : beta % 8 = 0 := by simpa [Nat.ModEq] using h0
      have hb1 : beta % 8 = 1 := by simpa [Nat.ModEq] using hbad
      omega
    · have hb2 : beta % 8 = 2 := by simpa [Nat.ModEq] using h2
      have hb1 : beta % 8 = 1 := by simpa [Nat.ModEq] using hbad
      omega
  · intro hbad
    rcases hphase with h0 | h2
    · have hb0 : beta % 8 = 0 := by simpa [Nat.ModEq] using h0
      have hb6 : beta % 8 = 6 := by simpa [Nat.ModEq] using hbad
      omega
    · have hb2 : beta % 8 = 2 := by simpa [Nat.ModEq] using h2
      have hb6 : beta % 8 = 6 := by simpa [Nat.ModEq] using hbad
      omega
theorem c7_prefix_non_drop_beta_two_forces_least_one
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hbeta : P.beta = 2) :
    P.m = 1 := by
  have hn0 := (c7_parent_beta_eq_two_iff_terminal_one P n0 hleast).mp hbeta
  rw [hn0] at hprefix
  have hmpos : 1 <= P.m := Nat.succ_le_of_lt P.m_pos
  omega
theorem c7_prefix_non_drop_beta_eight_forces_least_le_five
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hbeta : P.beta = 8) :
    P.m <= 5 := by
  have hn0 := (c7_parent_beta_eq_eight_iff_terminal_five P n0 hleast).mp hbeta
  rwa [hn0] at hprefix
theorem c7_prefix_non_drop_beta_eight_forces_least_three_or_five
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hodd : P.m % 2 = 1)
    (hm_ne_one : P.m ≠ 1)
    (hbeta : P.beta = 8) :
    P.m = 3 ∨ P.m = 5 := by
  have hmle : P.m <= 5 :=
    c7_prefix_non_drop_beta_eight_forces_least_le_five P n0 hleast hprefix hbeta
  interval_cases P.m <;> simp at hodd hm_ne_one ⊢
theorem c7_terminal_five_next_state_one_and_valuation_four :
    c3V2 (3 * 5 + 1) = 4 ∧ c3OddStep 5 = 1 := by
  native_decide
theorem c7_terminal_one_fixed_state_and_valuation_two :
    c3V2 (3 * 1 + 1) = 2 ∧ c3OddStep 1 = 1 := by
  native_decide
theorem c7_prefix_non_drop_beta_eight_first_carry_over_drops
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hodd : P.m % 2 = 1)
    (hm_ne_one : P.m ≠ 1)
    (hbeta : P.beta = 8) :
    c3OddStep n0 = 1 ∧ c3V2 (3 * n0 + 1) = 4 ∧ 1 < P.m := by
  have hn0 := (c7_parent_beta_eq_eight_iff_terminal_five P n0 hleast).mp hbeta
  have hm35 :=
    c7_prefix_non_drop_beta_eight_forces_least_three_or_five
      P n0 hleast hprefix hodd hm_ne_one hbeta
  have hstep := c7_terminal_five_next_state_one_and_valuation_four
  constructor
  · rw [hn0]
    exact hstep.2
  · constructor
    · rw [hn0]
      exact hstep.1
    · rcases hm35 with h3 | h5 <;> omega
theorem c7_prefix_non_drop_beta_two_forces_least_and_terminal_one
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hbeta : P.beta = 2) :
    P.m = 1 ∧ n0 = 1 := by
  exact ⟨c7_prefix_non_drop_beta_two_forces_least_one P n0 hleast hprefix hbeta,
    (c7_parent_beta_eq_two_iff_terminal_one P n0 hleast).mp hbeta⟩
theorem c7_prefix_non_drop_beta_two_fixed_carry_over_step
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hbeta : P.beta = 2) :
    P.m = 1 ∧ n0 = 1 ∧ c3OddStep n0 = 1 ∧ c3V2 (3 * n0 + 1) = 2 := by
  have hmn :=
    c7_prefix_non_drop_beta_two_forces_least_and_terminal_one P n0 hleast hprefix hbeta
  have hstep := c7_terminal_one_fixed_state_and_valuation_two
  constructor
  · exact hmn.1
  · constructor
    · exact hmn.2
    · constructor
      · rw [hmn.2]
        exact hstep.2
      · rw [hmn.2]
        exact hstep.1
theorem c7_low_parent_zone_prefix_non_drop_split
    (P : C7ParentCylinder) (n0 : Nat)
    (hleast : P.AffineTerminal P.m n0)
    (hprefix : P.m <= n0)
    (hodd : P.m % 2 = 1)
    (hm_ne_one_of_beta_eight : P.beta = 8 -> P.m ≠ 1)
    (hbeta : P.beta = 2 ∨ P.beta = 8) :
    (P.beta = 2 ∧ P.m = 1 ∧ n0 = 1 ∧ c3OddStep n0 = 1 ∧
        c3V2 (3 * n0 + 1) = 2) ∨
      (P.beta = 8 ∧ c3OddStep n0 = 1 ∧ c3V2 (3 * n0 + 1) = 4 ∧
        1 < P.m) := by
  rcases hbeta with h2 | h8
  · have hfixed :=
      c7_prefix_non_drop_beta_two_fixed_carry_over_step P n0 hleast hprefix h2
    exact Or.inl ⟨h2, hfixed.1, hfixed.2.1, hfixed.2.2.1, hfixed.2.2.2⟩
  · have hdrop :=
      c7_prefix_non_drop_beta_eight_first_carry_over_drops
        P n0 hleast hprefix hodd (hm_ne_one_of_beta_eight h8) h8
    exact Or.inr ⟨h8, hdrop.1, hdrop.2.1, hdrop.2.2⟩
structure C7FixedContinuationCylinder (P : C7ParentCylinder) where
  S_v : Nat
  fullResidue : Nat
  residualClass : Nat
  refinement :
    Nat.ModEq (2 ^ (P.S + 1)) fullResidue P.m
  residual_eq :
    Nat.ModEq (2 ^ (P.S + 1 + S_v))
      fullResidue (P.m + 2 ^ (P.S + 1) * residualClass)
theorem c7_fixed_continuation_full_of_residual
    (P : C7ParentCylinder) (C : C7FixedContinuationCylinder P)
    (n t : Nat)
    (hparam : P.Param n t)
    (ht : Nat.ModEq (2 ^ C.S_v) t C.residualClass) :
    Nat.ModEq (2 ^ (P.S + 1 + C.S_v)) n C.fullResidue := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have hmul :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * C.residualClass) := by
    have hraw :
        Nat.ModEq (2 ^ (P.S + 1) * 2 ^ C.S_v)
          (2 ^ (P.S + 1) * t)
          (2 ^ (P.S + 1) * C.residualClass) :=
      Nat.ModEq.mul_left' (2 ^ (P.S + 1)) ht
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hraw
  have hadd := Nat.ModEq.add_left P.m hmul
  exact Nat.ModEq.trans hadd (Nat.ModEq.symm C.residual_eq)
theorem c7_fixed_continuation_residual_of_full
    (P : C7ParentCylinder) (C : C7FixedContinuationCylinder P)
    (n t : Nat)
    (hparam : P.Param n t)
    (hfull : Nat.ModEq (2 ^ (P.S + 1 + C.S_v)) n C.fullResidue) :
    Nat.ModEq (2 ^ C.S_v) t C.residualClass := by
  unfold C7ParentCylinder.Param at hparam
  subst n
  have htarget :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        (P.m + 2 ^ (P.S + 1) * t)
        (P.m + 2 ^ (P.S + 1) * C.residualClass) :=
    Nat.ModEq.trans hfull C.residual_eq
  have hcancel_add :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * C.residualClass) :=
    Nat.ModEq.add_left_cancel' P.m htarget
  have hrewrite :
      Nat.ModEq (2 ^ (P.S + 1) * 2 ^ C.S_v)
        (2 ^ (P.S + 1) * t)
        (2 ^ (P.S + 1) * C.residualClass) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hcancel_add
  exact Nat.ModEq.mul_left_cancel'
    (pow_ne_zero (P.S + 1) (by norm_num : (2 : Nat) ≠ 0)) hrewrite
theorem c7_fixed_continuation_residual_iff_full
    (P : C7ParentCylinder) (C : C7FixedContinuationCylinder P)
    (n t : Nat)
    (hparam : P.Param n t) :
    Nat.ModEq (2 ^ C.S_v) t C.residualClass ↔
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v)) n C.fullResidue := by
  constructor
  · exact c7_fixed_continuation_full_of_residual P C n t hparam
  · exact c7_fixed_continuation_residual_of_full P C n t hparam
theorem c7_fixed_continuation_residual_class_unique
    (P : C7ParentCylinder) (C : C7FixedContinuationCylinder P)
    (c : Nat)
    (hres :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        C.fullResidue (P.m + 2 ^ (P.S + 1) * c)) :
    Nat.ModEq (2 ^ C.S_v) c C.residualClass := by
  have htarget :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        (P.m + 2 ^ (P.S + 1) * c)
        (P.m + 2 ^ (P.S + 1) * C.residualClass) :=
    Nat.ModEq.trans (Nat.ModEq.symm hres) C.residual_eq
  have hcancel_add :
      Nat.ModEq (2 ^ (P.S + 1 + C.S_v))
        (2 ^ (P.S + 1) * c)
        (2 ^ (P.S + 1) * C.residualClass) :=
    Nat.ModEq.add_left_cancel' P.m htarget
  have hrewrite :
      Nat.ModEq (2 ^ (P.S + 1) * 2 ^ C.S_v)
        (2 ^ (P.S + 1) * c)
        (2 ^ (P.S + 1) * C.residualClass) := by
    simpa [pow_add, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hcancel_add
  exact Nat.ModEq.mul_left_cancel'
    (pow_ne_zero (P.S + 1) (by norm_num : (2 : Nat) ≠ 0)) hrewrite
def c7ResidualAffine (a beta q : Nat) : Nat :=
  a * q + beta
theorem c7_residual_h1_iff_odd (a beta q : Nat) (hpos : 0 < a * q + beta) :
    c3V2 (c7ResidualAffine a beta q) = 0 ↔
      (a * q + beta) % 2 = 1 := by
  unfold c7ResidualAffine
  constructor
  · intro hv
    have hodd := c3_v2_quot_odd (a * q + beta) hpos
    rw [hv] at hodd
    simpa using hodd
  · intro hodd
    simpa using c3_v2_power_times_odd 0 (a * q + beta) hpos hodd
theorem c7_least_residual_h1_zero_of_beta_odd
    (a beta : Nat) (hbeta_pos : 0 < beta) (hbeta_odd : beta % 2 = 1) :
    c3V2 (c7ResidualAffine a beta 0) = 0 := by
  unfold c7ResidualAffine
  simp
  simpa using c3_v2_power_times_odd 0 beta hbeta_pos hbeta_odd
theorem c7_least_residual_h1_zero_fails_of_beta_even
    (a beta : Nat) (hbeta_pos : 0 < beta) (hbeta_even : beta % 2 = 0) :
    c3V2 (c7ResidualAffine a beta 0) ≠ 0 := by
  intro hv
  have hodd := (c7_residual_h1_iff_odd a beta 0 (by simpa [c7ResidualAffine] using hbeta_pos)).mp hv
  simp [hbeta_even] at hodd
theorem c7_least_residual_h1_one_of_beta_even
    (a beta : Nat) (ha_odd : a % 2 = 1) (hbeta_even : beta % 2 = 0) :
    c3V2 (c7ResidualAffine a beta 1) = 0 := by
  unfold c7ResidualAffine
  have hodd : (a * 1 + beta) % 2 = 1 := by
    rw [Nat.add_mod, Nat.mul_mod, ha_odd, hbeta_even]
  simpa using c3_v2_power_times_odd 0 (a * 1 + beta) (by omega) hodd
theorem c7_residual_h2_iff_mod4_two (a beta q : Nat) (hpos : 0 < a * q + beta) :
    c3V2 (c7ResidualAffine a beta q) = 1 ↔
      Nat.ModEq 4 (a * q + beta) 2 := by
  unfold c7ResidualAffine
  constructor
  · intro hv
    have hdvd : 2 ^ 1 ∣ a * q + beta := by
      rw [← hv]
      exact c3_v2_dvd (a * q + beta) hpos
    have hnot : ¬ 2 ^ 2 ∣ a * q + beta := by
      simpa [hv] using c3_v2_not_dvd_succ (a * q + beta) hpos
    unfold Nat.ModEq
    have heven : (a * q + beta) % 2 = 0 := Nat.mod_eq_zero_of_dvd hdvd
    have hmod4lt : (a * q + beta) % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hmod4_even : ((a * q + beta) % 4) % 2 = 0 := by
      rw [Nat.mod_mod_of_dvd (a * q + beta) (by norm_num : 2 ∣ 4)]
      exact heven
    have hmod4_ne0 : (a * q + beta) % 4 ≠ 0 := by
      intro h0
      exact hnot (Nat.dvd_of_mod_eq_zero h0)
    omega
  · intro hmod
    unfold Nat.ModEq at hmod
    have hmod_eq : (a * q + beta) % 4 = 2 := by
      simpa using hmod
    refine c3_v2_eq_of (a * q + beta) 1 hpos ?_ ?_
    · exact Nat.dvd_of_mod_eq_zero (by
        have hmod2 : (a * q + beta) % 2 = 0 := by
          rw [← Nat.mod_mod_of_dvd (a * q + beta) (by norm_num : 2 ∣ 4), hmod_eq]
        exact hmod2)
    · intro hdiv4
      have h0 : (a * q + beta) % 4 = 0 := Nat.mod_eq_zero_of_dvd hdiv4
      omega
theorem c7_h2_mod4_solution_of_coeff_one
    (beta q : Nat) :
    Nat.ModEq 4 (1 * q + beta) 2 ↔
      Nat.ModEq 4 q ((2 + 4 - beta % 4) % 4) := by
  unfold Nat.ModEq
  constructor
  · intro h
    have hb : beta % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hq : q % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hcanon : (q % 4 + beta % 4) % 4 = 2 := by
      simpa [Nat.add_mod, Nat.mul_mod, Nat.mod_mod] using h
    omega
  · intro h
    have hb : beta % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hq : q % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hcanon : q % 4 = (2 + 4 - beta % 4) % 4 := by
      simpa [Nat.mod_mod] using h
    rw [Nat.add_mod, Nat.mul_mod]
    omega
theorem c7_h2_mod4_solution_of_coeff_three
    (beta q : Nat) :
    Nat.ModEq 4 (3 * q + beta) 2 ↔
      Nat.ModEq 4 q ((3 * ((2 + 4 - beta % 4) % 4)) % 4) := by
  unfold Nat.ModEq
  constructor <;> intro h
  · have hb : beta % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hq : q % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hcanon : (3 * (q % 4) + beta % 4) % 4 = 2 := by
      simpa [Nat.add_mod, Nat.mul_mod, Nat.mod_mod, Nat.mul_assoc] using h
    omega
  · have hb : beta % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hq : q % 4 < 4 := Nat.mod_lt _ (by norm_num)
    have hcanon : q % 4 = (3 * ((2 + 4 - beta % 4) % 4)) % 4 := by
      simpa [Nat.mod_mod] using h
    rw [Nat.add_mod, Nat.mul_mod]
    omega
theorem c7_h2_table_coeff_one (beta : Fin 4) :
    ((2 + 4 - beta.val % 4) % 4 =
      match beta.val with
      | 0 => 2
      | 1 => 1
      | 2 => 0
      | _ => 3) := by
  fin_cases beta <;> decide
theorem c7_h2_table_coeff_three (beta : Fin 4) :
    ((3 * ((2 + 4 - beta.val % 4) % 4)) % 4 =
      match beta.val with
      | 0 => 2
      | 1 => 3
      | 2 => 0
      | _ => 1) := by
  fin_cases beta <;> decide
def c7Coeff (r : Nat) : Nat :=
  3 ^ (r + 1)
theorem c7_coeff_pos (r : Nat) : 0 < c7Coeff r := by
  unfold c7Coeff
  exact pow_pos (by norm_num : 0 < 3) (r + 1)
theorem c7_coeff_odd (r : Nat) : c7Coeff r % 2 = 1 := by
  unfold c7Coeff
  rw [Nat.pow_mod]
  norm_num
theorem c7_pow3_mod4 (e : Nat) :
    3 ^ e % 4 = if e % 2 = 0 then 1 else 3 := by
  induction e with
  | zero => simp
  | succ e ih =>
      rw [pow_succ, Nat.mul_mod, ih]
      by_cases he : e % 2 = 0
      · have he1 : (e + 1) % 2 = 1 := by omega
        simp [he, he1]
      · have he0 : e % 2 = 1 := by omega
        have he1 : (e + 1) % 2 = 0 := by omega
        simp [he0, he1]
theorem c7_coeff_mod4 (r : Nat) :
    c7Coeff r % 4 = if r % 2 = 1 then 1 else 3 := by
  unfold c7Coeff
  rw [c7_pow3_mod4 (r + 1)]
  by_cases hr : r % 2 = 1
  · have hr1 : (r + 1) % 2 = 0 := by omega
    simp [hr, hr1]
  · have hr0 : r % 2 = 0 := by omega
    have hr1 : (r + 1) % 2 = 1 := by omega
    simp [hr0, hr1]
def c7LeastResidualH1 (beta : Nat) : Nat :=
  if beta % 2 = 0 then 1 else 0
def c7LeastResidualH2 (r beta : Nat) : Nat :=
  if r % 2 = 1 then
    (2 + 4 - beta % 4) % 4
  else
    (3 * ((2 + 4 - beta % 4) % 4)) % 4
def c7LeastResidual (r beta h : Nat) : Nat :=
  if h = 1 then
    c7LeastResidualH1 beta
  else
    c7LeastResidualH2 r beta
theorem c7_least_rep_mod4_le (q q2 : Nat) (hq2 : q2 < 4)
    (hmod : Nat.ModEq 4 q q2) :
    q2 <= q := by
  unfold Nat.ModEq at hmod
  omega
theorem c7_least_residual_h1_spec (r beta : Nat) (hbeta_pos : 0 < beta) :
    c3V2 (c7Coeff r * c7LeastResidualH1 beta + beta) = 0 := by
  unfold c7LeastResidualH1
  split_ifs with hbeta_even
  · exact c7_least_residual_h1_one_of_beta_even (c7Coeff r) beta (c7_coeff_odd r) hbeta_even
  · exact c7_least_residual_h1_zero_of_beta_odd (c7Coeff r) beta hbeta_pos (by omega)
theorem c7_least_residual_h1_min (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 0) :
    c7LeastResidualH1 beta <= q := by
  unfold c7LeastResidualH1
  split_ifs with hbeta_even
  · by_contra hlt
    have hq0 : q = 0 := by omega
    subst q
    exact c7_least_residual_h1_zero_fails_of_beta_even (c7Coeff r) beta hbeta_pos hbeta_even hq
  · omega
theorem c7_least_residual_h2_mod4 (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 1) :
    Nat.ModEq 4 q (c7LeastResidualH2 r beta) := by
  have hpos : 0 < c7Coeff r * q + beta := by
    have hdvd : 2 ^ 1 ∣ c7Coeff r * q + beta := by
      rw [← hq]
      exact c3_v2_dvd (c7Coeff r * q + beta) (by omega)
    omega
  have hres :
      Nat.ModEq 4 (c7Coeff r * q + beta) 2 :=
    (c7_residual_h2_iff_mod4_two (c7Coeff r) beta q hpos).mp hq
  unfold c7LeastResidualH2
  by_cases hr : r % 2 = 1
  · have hcoeff : Nat.ModEq 4 (c7Coeff r) 1 := by
      rw [Nat.ModEq, c7_coeff_mod4 r, hr]
      simp
    have hres' : Nat.ModEq 4 (1 * q + beta) 2 :=
      Nat.ModEq.trans (Nat.ModEq.add_right beta (hcoeff.mul_right q).symm) hres
    rw [Nat.ModEq]
    simp only [hr, ↓reduceIte]
    exact (c7_h2_mod4_solution_of_coeff_one beta q).mp hres'
  · have hr0 : r % 2 = 0 := by omega
    have hcoeff : Nat.ModEq 4 (c7Coeff r) 3 := by
      rw [Nat.ModEq, c7_coeff_mod4 r, hr0]
      simp
    have hres' : Nat.ModEq 4 (3 * q + beta) 2 :=
      Nat.ModEq.trans (Nat.ModEq.add_right beta (hcoeff.mul_right q).symm) hres
    rw [Nat.ModEq]
    simp only [hr0]
    exact (c7_h2_mod4_solution_of_coeff_three beta q).mp hres'
theorem c7_least_residual_h2_spec (r beta : Nat) (hbeta_pos : 0 < beta) :
    c3V2 (c7Coeff r * c7LeastResidualH2 r beta + beta) = 1 := by
  have hpos : 0 < c7Coeff r * c7LeastResidualH2 r beta + beta := by
    have hcoeff : 0 < c7Coeff r := c7_coeff_pos r
    omega
  have hmod :
      Nat.ModEq 4 (c7Coeff r * c7LeastResidualH2 r beta + beta) 2 := by
    by_cases hr : r % 2 = 1
    · have hcoeff : Nat.ModEq 4 (c7Coeff r) 1 := by
        rw [Nat.ModEq, c7_coeff_mod4 r, hr]; decide
      have hqmod :
          Nat.ModEq 4 (c7LeastResidualH2 r beta) ((2 + 4 - beta % 4) % 4) := by
        simp [Nat.ModEq, c7LeastResidualH2, hr]
      have hres' : Nat.ModEq 4 (1 * c7LeastResidualH2 r beta + beta) 2 :=
        (c7_h2_mod4_solution_of_coeff_one beta (c7LeastResidualH2 r beta)).mpr hqmod
      exact Nat.ModEq.trans
        (Nat.ModEq.add_right beta (hcoeff.mul_right (c7LeastResidualH2 r beta))) hres'
    · have hr0 : r % 2 = 0 := by omega
      have hcoeff : Nat.ModEq 4 (c7Coeff r) 3 := by
        rw [Nat.ModEq, c7_coeff_mod4 r, hr0]; decide
      have hqmod :
          Nat.ModEq 4 (c7LeastResidualH2 r beta)
            ((3 * ((2 + 4 - beta % 4) % 4)) % 4) := by
        simp [Nat.ModEq, c7LeastResidualH2, hr0]
      have hres' : Nat.ModEq 4 (3 * c7LeastResidualH2 r beta + beta) 2 :=
        (c7_h2_mod4_solution_of_coeff_three beta (c7LeastResidualH2 r beta)).mpr hqmod
      exact Nat.ModEq.trans
        (Nat.ModEq.add_right beta (hcoeff.mul_right (c7LeastResidualH2 r beta))) hres'
  exact (c7_residual_h2_iff_mod4_two (c7Coeff r) beta (c7LeastResidualH2 r beta) hpos).mpr hmod
theorem c7_least_residual_h2_min (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 1) :
    c7LeastResidualH2 r beta <= q := by
  have hlt : c7LeastResidualH2 r beta < 4 := by
    unfold c7LeastResidualH2
    split_ifs <;> omega
  exact c7_least_rep_mod4_le q (c7LeastResidualH2 r beta) hlt
    (c7_least_residual_h2_mod4 r beta q hbeta_pos hq)
theorem c7_least_residual_spec (r beta h : Nat) (hbeta_pos : 0 < beta)
    (hh : h = 1 ∨ h = 2) :
    c3V2 (c7Coeff r * c7LeastResidual r beta h + beta) = h - 1 := by
  rcases hh with hh1 | hh2
  · simp [c7LeastResidual, hh1, c7_least_residual_h1_spec r beta hbeta_pos]
  · simp [c7LeastResidual, hh2, c7_least_residual_h2_spec r beta hbeta_pos]
theorem c7_least_lift_h1_agrees_on_beta_mod4
    (beta beta' : Nat) (hb : beta % 4 = beta' % 4) :
    c7LeastResidualH1 beta = c7LeastResidualH1 beta' := by
  unfold c7LeastResidualH1
  have hparity : beta % 2 = beta' % 2 := by omega
  simp [hparity]
theorem c7_least_lift_h2_agrees_on_state
    (r r' beta beta' : Nat) (hr : r % 2 = r' % 2) (hb : beta % 4 = beta' % 4) :
    c7LeastResidualH2 r beta = c7LeastResidualH2 r' beta' := by
  unfold c7LeastResidualH2
  simp [hr, hb]
theorem c7_least_lift_agrees_on_finite_state
    (r r' beta beta' h : Nat) (hh : h = 1 ∨ h = 2)
    (hr : r % 2 = r' % 2) (hb : beta % 4 = beta' % 4) :
    c7LeastResidual r beta h = c7LeastResidual r' beta' h := by
  unfold c7LeastResidual
  rcases hh with hh1 | hh2
  · simp [hh1, c7_least_lift_h1_agrees_on_beta_mod4 beta beta' hb]
  · simp [hh2, c7_least_lift_h2_agrees_on_state r r' beta beta' hr hb]
theorem c7_child_beta_update_cleared
    (P : C7ParentCylinder) (h q beta_child : Nat) (hh : 1 <= h)
    (hchild_beta :
      2 ^ (P.S + h + 1) * beta_child =
        3 ^ (P.r + 2) * (P.m + 2 ^ (P.S + 1) * q) +
          3 * (3 * P.A + 2 ^ P.S) + 2 ^ (P.S + h)) :
    2 ^ h * beta_child =
      3 * P.beta + 3 ^ (P.r + 2) * q + 2 ^ (h - 1) := by
  have hpows_child :
      2 ^ (P.S + 1) * (2 ^ h * beta_child) =
        2 ^ (P.S + h + 1) * beta_child := by
    calc
      2 ^ (P.S + 1) * (2 ^ h * beta_child)
          = (2 ^ (P.S + 1) * 2 ^ h) * beta_child := by ring
      _ = 2 ^ (P.S + 1 + h) * beta_child := by rw [← pow_add]
      _ = 2 ^ (P.S + h + 1) * beta_child := by
        rw [show P.S + 1 + h = P.S + h + 1 by omega]
  have hpow_hminus :
      2 ^ (P.S + 1) * 2 ^ (h - 1) = 2 ^ (P.S + h) := by
    calc
      2 ^ (P.S + 1) * 2 ^ (h - 1)
          = 2 ^ (P.S + 1 + (h - 1)) := by rw [← pow_add]
      _ = 2 ^ (P.S + h) := by
        congr 1
        omega
  have hpow3 :
      3 ^ (P.r + 2) = 3 * 3 ^ (P.r + 1) := by
    calc
      3 ^ (P.r + 2) = 3 ^ (P.r + 1 + 1) := by
        rw [show P.r + 2 = P.r + 1 + 1 by omega]
      _ = 3 * 3 ^ (P.r + 1) := by
        rw [pow_succ]
        ring
  have hright :
      2 ^ (P.S + 1) *
          (3 * P.beta + 3 ^ (P.r + 2) * q + 2 ^ (h - 1)) =
        3 ^ (P.r + 2) * (P.m + 2 ^ (P.S + 1) * q) +
          3 * (3 * P.A + 2 ^ P.S) + 2 ^ (P.S + h) := by
    calc
      2 ^ (P.S + 1) *
          (3 * P.beta + 3 ^ (P.r + 2) * q + 2 ^ (h - 1))
          = 3 * (2 ^ (P.S + 1) * P.beta) +
              2 ^ (P.S + 1) * (3 ^ (P.r + 2) * q) +
              2 ^ (P.S + 1) * 2 ^ (h - 1) := by ring
      _ = 3 * (3 ^ (P.r + 1) * P.m + 3 * P.A + 2 ^ P.S) +
              2 ^ (P.S + 1) * (3 ^ (P.r + 2) * q) +
              2 ^ (P.S + 1) * 2 ^ (h - 1) := by rw [P.beta_eq]
      _ = 3 ^ (P.r + 2) * (P.m + 2 ^ (P.S + 1) * q) +
            3 * (3 * P.A + 2 ^ P.S) + 2 ^ (P.S + h) := by
        rw [hpow3, hpow_hminus]
        ring
  have hmul :
      2 ^ (P.S + 1) * (2 ^ h * beta_child) =
        2 ^ (P.S + 1) *
          (3 * P.beta + 3 ^ (P.r + 2) * q + 2 ^ (h - 1)) := by
    rw [hpows_child, hchild_beta, hright]
  exact Nat.eq_of_mul_eq_mul_left (Nat.pow_pos (by norm_num : 0 < 2)) hmul
theorem c7_child_beta_update
    (P : C7ParentCylinder) (h q beta_child : Nat) (hh : 1 <= h)
    (hchild_beta :
      2 ^ (P.S + h + 1) * beta_child =
        3 ^ (P.r + 2) * (P.m + 2 ^ (P.S + 1) * q) +
          3 * (3 * P.A + 2 ^ P.S) + 2 ^ (P.S + h)) :
    beta_child =
      (3 * P.beta + 3 ^ (P.r + 2) * q + 2 ^ (h - 1)) / 2 ^ h := by
  have hcleared :=
    c7_child_beta_update_cleared P h q beta_child hh hchild_beta
  rw [← hcleared]
  exact (Nat.mul_div_right beta_child (Nat.pow_pos (by norm_num : 0 < 2))).symm
def c7ChildBetaNumerator (r beta h q : Nat) : Nat :=
  if h = 1 then
    3 * beta + 3 ^ (r + 2) * q + 1
  else
    3 * beta + 3 ^ (r + 2) * q + 2
theorem c7_pow_r_plus_two (r : Nat) : 3 ^ (r + 2) = 3 * c7Coeff r := by
  unfold c7Coeff
  rw [pow_succ]
  ring
theorem c7_child_beta_numerator_div_h1 (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 0) :
    2 ∣ c7ChildBetaNumerator r beta 1 q := by
  have hodd : (c7Coeff r * q + beta) % 2 = 1 :=
    (c7_residual_h1_iff_odd (c7Coeff r) beta q (by omega)).mp hq
  unfold c7ChildBetaNumerator
  simp only
  have hnum :
      3 * beta + 3 ^ (r + 2) * q + 1 = 3 * (c7Coeff r * q + beta) + 1 := by
    rw [c7_pow_r_plus_two]
    ring
  rw [hnum]
  have hsum : (3 * (c7Coeff r * q + beta) + 1) % 2 = 0 := by
    rw [Nat.add_mod, Nat.mul_mod, hodd]
  exact Nat.dvd_of_mod_eq_zero hsum
theorem c7_child_beta_numerator_div_h2 (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 1) :
    4 ∣ c7ChildBetaNumerator r beta 2 q := by
  have hmod :
      Nat.ModEq 4 (c7Coeff r * q + beta) 2 :=
    (c7_residual_h2_iff_mod4_two (c7Coeff r) beta q (by omega)).mp hq
  unfold c7ChildBetaNumerator
  simp only [if_neg (by norm_num : (2 : Nat) ≠ 1)]
  have hnum :
      3 * beta + 3 ^ (r + 2) * q + 2 = 3 * (c7Coeff r * q + beta) + 2 := by
    rw [c7_pow_r_plus_two]
    ring
  rw [hnum]
  have hsum : Nat.ModEq 4 (3 * (c7Coeff r * q + beta) + 2) 0 := by
    have htriple := hmod.mul_left 3
    exact htriple.add_right 2
  exact Nat.dvd_of_mod_eq_zero hsum
def c7ChildBeta (r beta h q : Nat) : Nat :=
  if h = 1 then
    c7ChildBetaNumerator r beta 1 q / 2
  else
    c7ChildBetaNumerator r beta 2 q / 4
theorem c7_child_beta_h1_eq (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 0) :
    2 * c7ChildBeta r beta 1 q = c7ChildBetaNumerator r beta 1 q := by
  unfold c7ChildBeta c7ChildBetaNumerator
  simp
  exact Nat.mul_div_cancel' (c7_child_beta_numerator_div_h1 r beta q hbeta_pos hq)
theorem c7_child_beta_h2_eq (r beta q : Nat) (hbeta_pos : 0 < beta)
    (hq : c3V2 (c7Coeff r * q + beta) = 1) :
    4 * c7ChildBeta r beta 2 q = c7ChildBetaNumerator r beta 2 q := by
  unfold c7ChildBeta c7ChildBetaNumerator
  simp
  exact Nat.mul_div_cancel' (c7_child_beta_numerator_div_h2 r beta q hbeta_pos hq)
theorem c7_half_mod4_of_mod8
    (x y hx hy : Nat)
    (hxdef : x = 2 * hx) (hydef : y = 2 * hy)
    (hxy : Nat.ModEq 8 x y) :
    Nat.ModEq 4 hx hy := by
  subst x
  subst y
  have hrewrite : Nat.ModEq (2 * 4) (2 * hx) (2 * hy) := by
    simpa [Nat.mul_comm] using hxy
  exact Nat.ModEq.mul_left_cancel' (by norm_num : 2 ≠ 0) hrewrite
theorem c7_quarter_mod4_of_mod16
    (x y hx hy : Nat)
    (hxdef : x = 4 * hx) (hydef : y = 4 * hy)
    (hxy : Nat.ModEq 16 x y) :
    Nat.ModEq 4 hx hy := by
  subst x
  subst y
  have hrewrite : Nat.ModEq (4 * 4) (4 * hx) (4 * hy) := by
    simpa using hxy
  exact Nat.ModEq.mul_left_cancel' (by norm_num : 4 ≠ 0) hrewrite
theorem c7_pow3_mod16_of_exp_mod4
    (r₁ r₂ : Nat) (hr : Nat.ModEq 4 r₁ r₂) :
    Nat.ModEq 16 (3 ^ r₁) (3 ^ r₂) := by
  unfold Nat.ModEq at hr ⊢
  have hperiod : ∀ n : Nat, 3 ^ n % 16 = 3 ^ (n % 4) % 16 := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
        by_cases hn : n < 4
        · have hmod : n % 4 = n := Nat.mod_eq_of_lt hn
          rw [hmod]
        · have hn4 : 4 <= n := by omega
          obtain ⟨k, hk⟩ := Nat.exists_eq_add_of_le hn4
          have hlt : k < n := by omega
          have hmod : (k + 4) % 4 = k % 4 := by
            rw [Nat.add_mod_right]
          calc
            3 ^ n % 16 = 3 ^ (4 + k) % 16 := by rw [hk]
            _ = 3 ^ (k + 4) % 16 := by rw [Nat.add_comm 4 k]
            _ = (3 ^ k * 3 ^ 4) % 16 := by rw [pow_add]
            _ = (3 ^ k * 81) % 16 := by norm_num
            _ = 3 ^ k % 16 := by
              rw [Nat.mul_mod, show 81 % 16 = 1 by norm_num]
              simp
            _ = 3 ^ (k % 4) % 16 := ih k hlt
            _ = 3 ^ ((k + 4) % 4) % 16 := by rw [hmod]
            _ = 3 ^ ((4 + k) % 4) % 16 := by rw [Nat.add_comm 4 k]
            _ = 3 ^ (n % 4) % 16 := by rw [hk]
  have hcycle : ∀ k : Fin 4, 3 ^ k.val % 16 =
      match k.val with
      | 0 => 1
      | 1 => 3
      | 2 => 9
      | _ => 11 := by
    intro k
    fin_cases k <;> decide
  have hpow₁ :
      3 ^ r₁ % 16 =
        match r₁ % 4 with
        | 0 => 1
        | 1 => 3
