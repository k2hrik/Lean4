theorem fixed_branch_substitution_image_card (s c k u0 N : Nat) :
    ((Finset.range N).image
      (fun e => c + 2 ^ s * (oddResidueLift k u0 e))).card = N := by
  calc
    ((Finset.range N).image
      (fun e => c + 2 ^ s * (oddResidueLift k u0 e))).card =
        (Finset.range N).card := by
          apply Finset.card_image_of_injective
          intro u v h
          have h' : 2 ^ s * (oddResidueLift k u0 u) + c =
              2 ^ s * (oddResidueLift k u0 v) + c := by
            simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using h
          have hmul : 2 ^ s * (oddResidueLift k u0 u) =
              2 ^ s * (oddResidueLift k u0 v) :=
            Nat.add_right_cancel h'
          have hinner : oddResidueLift k u0 u = oddResidueLift k u0 v :=
            Nat.eq_of_mul_eq_mul_left (pow_pos (by norm_num : 0 < 2) s) hmul
          exact oddResidueLift_injective k u0 u v hinner
    _ = N := Finset.card_range N
theorem fixed_branch_substitution_absolute_odd_density
    (s c k M u0 : Nat) (hM : s + k <= M + 1) :
    ((((Finset.range (2 ^ (M - (s + k - 1)))).image
      (fun e => c + 2 ^ s * (oddResidueLift k u0 e))).card : Nat) : Rat) /
        ((2 ^ M : Nat) : Rat) =
      (1 : Rat) / ((2 ^ (s + k - 1) : Nat) : Rat) := by
  rw [fixed_branch_substitution_image_card]
  have hle : s + k - 1 <= M := by omega
  have hpowNat : 2 ^ M = 2 ^ (M - (s + k - 1)) * 2 ^ (s + k - 1) := by
    calc
      2 ^ M = 2 ^ ((M - (s + k - 1)) + (s + k - 1)) := by congr 1; omega
      _ = 2 ^ (M - (s + k - 1)) * 2 ^ (s + k - 1) := by
            exact Nat.pow_add 2 (M - (s + k - 1)) (s + k - 1)
  rw [hpowNat]
  norm_num
  field_simp
