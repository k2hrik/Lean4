theorem l1_dangerous_burst_launch_large_cross
    (n qStar qLast : Nat)
    (hdanger : 8 ^ (n - 1) * qLast < 3 ^ (n - 1) * qStar)
    (hlast : 3 <= qLast) :
    3 * 8 ^ (n - 1) < 3 ^ (n - 1) * qStar := by
  calc
    3 * 8 ^ (n - 1) <= qLast * 8 ^ (n - 1) := by
      exact Nat.mul_le_mul_right (8 ^ (n - 1)) hlast
    _ = 8 ^ (n - 1) * qLast := by ring
    _ < 3 ^ (n - 1) * qStar := hdanger
theorem l1_dangerous_burst_launch_minus_one_cross
    (n qStar : Nat)
    (hcross : 3 * 8 ^ (n - 1) < 3 ^ (n - 1) * qStar) :
    3 * 8 ^ (n - 1) - 3 ^ (n - 1) <
      3 ^ (n - 1) * (qStar - 1) := by
  let e := n - 1
  have hqStar : 1 <= qStar := by
    by_contra hnot
    have hzero : qStar = 0 := by omega
    rw [hzero] at hcross
    have hpos : 0 < 3 * 8 ^ (n - 1) := by positivity
    omega
  have h3le : 3 ^ e <= 3 * 8 ^ e := by
    have hpow : 3 ^ e <= 8 ^ e := Nat.pow_le_pow_left (by norm_num : 3 <= 8) e
    have hmul : 8 ^ e <= 3 * 8 ^ e := by
      calc
        8 ^ e = 1 * 8 ^ e := by ring
        _ <= 3 * 8 ^ e :=
          Nat.mul_le_mul_right (8 ^ e) (by norm_num : 1 <= (3 : Nat))
    exact le_trans hpow hmul
