    Finset.univ.prod (fun i : Fin m => l1PreludeWeight (f i)))
theorem l1_prelude_tuple_mass_formula (m : Nat) :
    l1PreludeTupleMass m = ((3 : Rat) / 8) ^ m := by
  unfold l1PreludeTupleMass
  have htuple :
      (Finset.univ.sum (fun f : Fin m -> Fin 2 =>
        Finset.univ.prod (fun i : Fin m => l1PreludeWeight (f i)))) =
        ((Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) ^ m) := by
    induction m with
    | zero =>
        simp [l1PreludeWeight]
    | succ m ih =>
        calc
          Finset.univ.sum (fun f : Fin (m + 1) -> Fin 2 =>
              Finset.univ.prod (fun i : Fin (m + 1) => l1PreludeWeight (f i)))
              = Finset.univ.sum (fun p : Prod (Fin 2) (Fin m -> Fin 2) =>
                  l1PreludeWeight p.1 *
                    Finset.univ.prod (fun i : Fin m => l1PreludeWeight (p.2 i))) := by
                apply Fintype.sum_equiv (Fin.consEquiv (fun _ : Fin (m + 1) => Fin 2)).symm
                intro f
                simp [Fin.prod_univ_succ, Fin.tail]
          _ = Finset.univ.sum (fun x : Fin 2 =>
                Finset.univ.sum (fun f : Fin m -> Fin 2 =>
                  l1PreludeWeight x *
                    Finset.univ.prod (fun i : Fin m => l1PreludeWeight (f i)))) := by
                rw [Fintype.sum_prod_type]
          _ = Finset.univ.sum (fun x : Fin 2 =>
                l1PreludeWeight x *
                  Finset.univ.sum (fun f : Fin m -> Fin 2 =>
                    Finset.univ.prod (fun i : Fin m => l1PreludeWeight (f i)))) := by
                simp [Finset.mul_sum]
          _ = (Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) *
                (Finset.univ.sum (fun f : Fin m -> Fin 2 =>
                  Finset.univ.prod (fun i : Fin m => l1PreludeWeight (f i)))) := by
                rw [Finset.sum_mul]
          _ = (Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) *
                ((Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) ^ m) := by
                rw [ih]
          _ = ((Finset.univ.sum (fun x : Fin 2 => l1PreludeWeight x)) ^ (m + 1)) := by
                rw [pow_succ]
                ring
  rw [htuple, l1_prelude_one_step_mass]
