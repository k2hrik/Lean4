theorem c7_div_pow2_mod_of_mod
    (M h x y dx dy : Nat)
    (hxdef : x = 2 ^ h * dx)
    (hydef : y = 2 ^ h * dy)
    (hxy : Nat.ModEq (2 ^ (M + h)) x y) :
    Nat.ModEq (2 ^ M) dx dy := by
  subst x
  subst y
  have hrewrite :
      Nat.ModEq (2 ^ h * 2 ^ M) (2 ^ h * dx) (2 ^ h * dy) := by
    simpa [pow_add, Nat.add_comm, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hxy
  exact Nat.ModEq.mul_left_cancel'
    (pow_ne_zero h (by norm_num : (2 : Nat) ≠ 0)) hrewrite
theorem c7_pow3_two_pow_periodicity_witness
    (t : Nat) :
    ∃ k, 3 ^ (2 ^ (t + 1)) = 1 + 2 ^ (t + 3) * k := by
  induction t with
  | zero =>
      exact ⟨1, by norm_num⟩
  | succ t ih =>
      obtain ⟨k, hk⟩ := ih
      refine ⟨k + 2 ^ (t + 2) * k ^ 2, ?_⟩
      have hexp : 2 ^ (t + 1 + 1) = 2 ^ (t + 1) * 2 := by
        rw [pow_succ]
      calc
        3 ^ (2 ^ (t + 1 + 1))
            = (3 ^ (2 ^ (t + 1))) ^ 2 := by
          rw [hexp, pow_mul]
        _ = (1 + 2 ^ (t + 3) * k) ^ 2 := by rw [hk]
        _ = 1 + 2 ^ (t + 3 + 1) * (k + 2 ^ (t + 2) * k ^ 2) := by
          ring_nf
theorem c7_pow3_two_pow_periodicity
    (s : Nat) (hs : 1 <= s) :
    Nat.ModEq (2 ^ (s + 2)) (3 ^ (2 ^ s)) 1 := by
  cases s with
  | zero =>
      omega
  | succ t =>
      obtain ⟨k, hk⟩ := c7_pow3_two_pow_periodicity_witness t
      rw [hk]
      rw [show t + 1 + 2 = t + 3 by omega]
      rw [Nat.add_comm 1 (2 ^ (t + 3) * k)]
      exact Nat.ModEq.modulus_mul_add
theorem c7_pow3_mod_pow_of_exp_mod
    (s e₁ e₂ : Nat) (hs : 1 <= s)
    (he : Nat.ModEq (2 ^ s) e₁ e₂) :
    Nat.ModEq (2 ^ (s + 2)) (3 ^ e₁) (3 ^ e₂) := by
  have hperiod := c7_pow3_two_pow_periodicity s hs
  rw [← ZMod.natCast_eq_natCast_iff]
  have hx : (3 : ZMod (2 ^ (s + 2))) ^ (2 ^ s) = 1 := by
    simpa [Nat.cast_pow] using
      (ZMod.natCast_eq_natCast_iff (3 ^ (2 ^ s)) 1 (2 ^ (s + 2))).mpr hperiod
  have heq := pow_eq_pow_of_modEq (x := (3 : ZMod (2 ^ (s + 2)))) he hx
  simpa [Nat.cast_pow] using heq
