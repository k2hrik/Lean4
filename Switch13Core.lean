theorem l1_dangerous_tuple_mass_factorization (N n : Nat) :
    l1DangerousTupleMassTruncation N n = l1DangerousTailMassTruncation N n := by
  unfold l1DangerousTupleMassTruncation l1DangerousTailMassTruncation
  have htuple :
      (Finset.univ.sum (fun f : Fin n -> Fin N =>
        Finset.univ.prod (fun i : Fin n => (1 : Rat) / (2 ^ ((f i).val + 4))))) =
        ((Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) ^ n) := by
    induction n with
    | zero =>
        simp
    | succ n ih =>
        calc
          Finset.univ.sum (fun f : Fin (n + 1) -> Fin N =>
              Finset.univ.prod (fun i : Fin (n + 1) => (1 : Rat) / (2 ^ ((f i).val + 4))))
              = Finset.univ.sum (fun p : Prod (Fin N) (Fin n -> Fin N) =>
                  ((1 : Rat) / (2 ^ (p.1.val + 4))) *
                    Finset.univ.prod (fun i : Fin n => (1 : Rat) / (2 ^ ((p.2 i).val + 4)))) := by
                apply Fintype.sum_equiv (Fin.consEquiv (fun _ : Fin (n + 1) => Fin N)).symm
                intro f
                simp [Fin.prod_univ_succ, Fin.tail, mul_comm]
          _ = Finset.univ.sum (fun x : Fin N =>
                Finset.univ.sum (fun f : Fin n -> Fin N =>
                  ((1 : Rat) / (2 ^ (x.val + 4))) *
                    Finset.univ.prod (fun i : Fin n => (1 : Rat) / (2 ^ ((f i).val + 4))))) := by
                rw [Fintype.sum_prod_type]
          _ = Finset.univ.sum (fun x : Fin N =>
                ((1 : Rat) / (2 ^ (x.val + 4))) *
                  Finset.univ.sum (fun f : Fin n -> Fin N =>
                    Finset.univ.prod (fun i : Fin n => (1 : Rat) / (2 ^ ((f i).val + 4))))) := by
                simp [Finset.mul_sum]
          _ = (Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) *
                (Finset.univ.sum (fun f : Fin n -> Fin N =>
                  Finset.univ.prod (fun i : Fin n => (1 : Rat) / (2 ^ ((f i).val + 4))))) := by
                rw [Finset.sum_mul]
          _ = (Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) *
                ((Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) ^ n) := by
                rw [ih]
          _ = ((Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) ^ (n + 1)) := by
                rw [pow_succ]
                ring
  rw [htuple]
  have hfin :
      (Finset.univ.sum (fun x : Fin N => (1 : Rat) / (2 ^ (x.val + 4)))) =
        (Finset.range N).sum (fun j => (1 : Rat) / (2 ^ (j + 4))) := by
    simpa using (Fin.sum_univ_eq_sum_range (fun j : Nat => (1 : Rat) / (2 ^ (j + 4))) N)
  rw [hfin]
