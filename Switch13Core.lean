  cases Nat.exists_eq_add_of_le ht with
  | intro k hk =>
      subst t
      have hp : (2 : Int) ^ (1 + k + 4) = (2 : Int) ^ k * 32 := by
        have hidx : 1 + k + 4 = k + 5 := by omega
        rw [hidx, pow_add]
        norm_num
      rw [hp]
      have hone : (1 : Int) <= (2 : Int) ^ k :=
        one_le_pow₀ (by norm_num : (1 : Int) <= 2)
      nlinarith
